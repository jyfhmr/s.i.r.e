---
interface Props {
  initialValue?: string;
  error?: string;
}

const { initialValue = "", error } = Astro.props;
---

<div class="w-full bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm">
  <form method="GET" action="" class="space-y-4">
    <div class="space-y-1">
      <label 
        for="search" 
        class="block font-display font-bold text-lg md:text-xl text-text-dark"
      >
        Buscar persona hospitalizada
      </label>
      <p class="text-sm md:text-base text-text-dark/60 leading-relaxed font-sans">
        Escribe la cédula de identidad, DNI o pasaporte de tu familiar para consultar su estado en tiempo real.
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 items-stretch mt-4">
      <div class="relative flex-grow">
        <!-- Icono de lupa interno (estilo minimalista) -->
        <span class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-text-dark/40">
          <svg 
            xmlns="http://www.w3.org/2000/svg" 
            width="20" 
            height="20" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </span>
        
        <input
          type="text"
          inputmode="numeric"
          pattern="[0-9]*"
          id="search"
          name="search"
          value={initialValue}
          placeholder="Ej: 12345678 (solo números, sin puntos)"
          required
          aria-required="true"
          aria-invalid={error ? "true" : "false"}
          class="w-full h-14 pl-12 pr-4 bg-white border border-border-subtle rounded-xl text-lg text-text-dark placeholder-text-dark/40 focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all shadow-2xs"
        />
        {error && (
          <p class="text-sm text-error-text font-semibold mt-1" role="alert">
            <span class="inline-flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
              {error}
            </span>
          </p>
        )}
      </div>
      
      <button
        type="submit"
        id="search-btn"
        class="h-14 px-8 bg-vzla-blue hover:bg-vzla-blue-hover active:bg-vzla-blue text-white font-display font-bold text-lg rounded-xl flex items-center justify-center gap-2 cursor-pointer shadow-xs hover:shadow transition-all shrink-0"
      >
        <svg id="search-spinner" class="animate-spin h-5 w-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span id="search-btn-text">Buscar Familiar</span>
      </button>
    </div>
  </form>

  <script>
    if (typeof window !== 'undefined') {
      const form = document.querySelector('form') as HTMLFormElement;
      const searchBtn = document.getElementById('search-btn') as HTMLButtonElement;
      const spinner = document.getElementById('search-spinner');
      const btnText = document.getElementById('search-btn-text');

      if (form && searchBtn) {
        form.addEventListener('submit', () => {
          if (searchBtn.disabled) return;
          searchBtn.disabled = true;
          if (spinner) spinner.classList.remove('hidden');
          if (btnText) btnText.textContent = 'Buscando...';
        });
      }
    }
  </script>

  <!-- Leyenda informativa -->
  <div class="mt-5 pt-4 border-t border-border-subtle/60 flex items-center gap-2 text-xs md:text-sm text-text-dark/50 font-sans">
    <div class="w-5 h-5 rounded-full bg-vzla-blue/5 border border-vzla-blue/10 flex items-center justify-center text-vzla-blue font-bold">i</div>
    <span>La consulta es totalmente gratuita y abierta al público las 24 horas del día.</span>
  </div>
</div>
