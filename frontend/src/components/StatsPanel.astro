---
// StatsPanel.astro - Panel de Estadísticas del Sistema
---

<div class="w-full space-y-4">
  <!-- Estadísticas -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <!-- Personas Registradas -->
    <div class="bg-white border-t-4 border-t-vzla-blue border-x border-b border-border-subtle rounded-xl p-5 text-center shadow-xs">
      <span class="block text-3xl font-bold text-vzla-blue tracking-tight">34.251</span>
      <span class="block text-sm font-display font-semibold text-text-dark/60 mt-1">Personas registradas</span>
    </div>

    <!-- Por Localizar -->
    <div class="bg-white border-t-4 border-t-error-border border-x border-b border-border-subtle rounded-xl p-5 text-center shadow-xs">
      <span class="block text-3xl font-bold text-error-text tracking-tight">24.477</span>
      <span class="block text-sm font-display font-semibold text-text-dark/60 mt-1">Por localizar</span>
    </div>

    <!-- Localizadas -->
    <div class="bg-white border-t-4 border-t-success-border border-x border-b border-border-subtle rounded-xl p-5 text-center shadow-xs">
      <span class="block text-3xl font-bold text-success-text tracking-tight">9.774</span>
      <span class="block text-sm font-display font-semibold text-text-dark/60 mt-1">Localizadas / De alta</span>
    </div>
  </div>
</div>
