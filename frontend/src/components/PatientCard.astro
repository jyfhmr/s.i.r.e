---
/**
 * PatientCard - Tarjeta de información pública de paciente
 * Actualizado para usar los estados reales del backend (@shared/common)
 */
import { PatientStatus } from '@shared/common';
import { getStatusConfig } from '../lib/patient-status';

export interface Patient {
  fullName: string;
  status: PatientStatus;
  location: string;
  lastUpdated: Date | string;
}

interface Props {
  patient: Patient;
}

const { patient } = Astro.props;

const config = getStatusConfig(patient.status);

// Formatear fecha
const formattedDate = typeof patient.lastUpdated === 'string' 
  ? new Date(patient.lastUpdated).toLocaleDateString('es-VE', { 
      year: 'numeric', 
      month: 'long', 
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    })
  : patient.lastUpdated.toLocaleDateString('es-VE', { 
      year: 'numeric', 
      month: 'long', 
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
---

<div class="w-full bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm flex flex-col gap-6 font-sans">
  <!-- Cabecera de la Tarjeta -->
  <div class="border-b border-border-subtle/50 pb-5">
    <span class="text-xs font-semibold text-text-dark/45 tracking-wider uppercase">Reporte Médico Oficial</span>
    <h2 class="font-display font-bold text-2xl md:text-3xl text-text-dark mt-0.5">{patient.fullName}</h2>
  </div>

  <!-- Estado del Paciente -->
  <div class={`border-l-4 p-5 rounded-r-xl flex flex-col gap-1.5 border-l-current ${config.bgClass}`}>
    <div class="flex items-center gap-2">
      <span class={`w-3.5 h-3.5 rounded-full ${config.badgeClass} block shrink-0`}></span>
      <span class="font-display font-bold text-lg md:text-xl tracking-tight">
        {config.label}
      </span>
    </div>
    <p class="text-sm md:text-base leading-relaxed opacity-90 font-sans">
      {config.description}
    </p>
  </div>

  <!-- Ubicación -->
  <div class="space-y-1">
    <h3 class="text-xs font-semibold text-text-dark/45 tracking-wider uppercase">Centro de Salud / Ubicación</h3>
    <p class="font-display font-bold text-lg text-vzla-blue">{patient.location}</p>
  </div>

  <!-- Footer de la Tarjeta -->
  <div class="border-t border-border-subtle/50 pt-5 mt-2 flex items-center justify-between gap-3 text-xs md:text-sm text-text-dark/50">
    <div class="flex items-center gap-1.5">
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="16" 
        height="16" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="2" 
        stroke-linecap="round" 
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <span>Última actualización: <strong>{formattedDate}</strong></span>
    </div>
    <span>Verificado por Personal Médico</span>
  </div>
</div>
