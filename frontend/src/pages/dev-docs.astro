const code9 = `{
  "totalPatients": 15234,
  "totalMedicalCenters": 47,
  "patientsByStatus": [
    { "status": "ESTABLE", "count": 5230 },
    { "status": "CR\u00cdTICO", "count": 1890 },
    { "status": "DESAPARECIDO", "count": 7200 },
    { "status": "CONTACTAR_INMEDIATO", "count": 456 },
    { "status": "NO ESPECIFICADO", "count": 458 }
  ],
  "lastUpdated": "2026-06-29T10:00:00.000Z"
}`;

const code10 = `{
  "name": "Juan L\u00f3pez",
  "email": "juan@ejemplo.com",
  "message": "Tengo acceso a las listas del Hospital de Los Teques y quiero colaborar."
}`;

