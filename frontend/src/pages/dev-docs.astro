  "success": true,
  "message": "Mensaje enviado correctamente"
}`;

const code12 = `{
  "fullName": "Dr. Juan L\u00f3pez",
  "dni": "87654321",
  "email": "dr.lopez@hospital.com",
  "phoneNumber": "0412-1234567",
  "position": "M\u00e9dico",
  "medicalCenterId": 1,
  "manualMedicalCenter": "Hospital de Los Teques (si no est\u00e1 en cat\u00e1logo)"
}`;

const code13 = `{
  "success": true,
  "message": "Solicitud enviada correctamente. El equipo de S.I.R.E. revisar\u00e1 tu solicitud."
}`;

const code14 = `enum PatientStatus {
  ESTABLE            = "ESTABLE",
  CR\u00cdTICO            = "CR\u00cdTICO",
  CONTACTAR_INMEDIATO = "CONTACTAR_INMEDIATO",
  DESAPARECIDO       = "DESAPARECIDO",
  NO_ESPECIFICADO    = "NO ESPECIFICADO"
}`;

const code15 = `enum RegistrationSource {
  MEDICAL_STAFF = "MEDICAL_STAFF",
  PUBLIC_LIST   = "PUBLIC_LIST"
}`;

const code16 = `const ROLES = {
  DIOS: 1,
  MEDICO: 2,
  USUARIO_COMUN: 3,
} as const;`;

const code17 = `{
  "statusCode": 400,
  "message": [
    {
      "property": "email",
      "constraints": { "isEmail": "email must be an email" }
    }
  ]
}`;
---

<Layout title="Documentación para Desarrolladores - S.I.R.E.">
  <div class="max-w-4xl mx-auto space-y-8 animate-fade-in px-4 pb-16">
    <!-- Título -->
    <div class="text-center space-y-2 pt-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-vzla-blue/10 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-vzla-blue">
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
      </div>
      <h1 class="font-display font-bold text-3xl md:text-4xl text-text-dark">Documentación para Desarrolladores</h1>
      <p class="font-sans text-base md:text-lg text-text-dark/65">
        API pública, arquitectura y guía de contribución al proyecto S.I.R.E.
      </p>
    </div>

    <!-- Índice de navegación rápida -->
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm">
      <h2 class="font-display font-bold text-xl text-text-dark mb-4">📑 Índice</h2>
      <ul class="space-y-2 text-sm font-sans">
        <li><a href="#intro" class="text-vzla-blue hover:text-vzla-blue-hover underline underline-offset-2">1. Introducción</a></li>
        <li><a href="#base-url" class="text-vzla-blue hover:text-vzla-blue-hover underline underline-offset-2">2. Base URL y autenticación</a></li>
        <li><a href="#rate-limiting" class="text-vzla-blue hover:text-vzla-blue-hover underline underline-offset-2">3. Rate Limiting</a></li>
        <li><a href="#endpoints-publicos" class="text-vzla-blue hover:text-vzla-blue-hover underline underline-offset-2">4. Endpoints Públicos</a>
          <ul class="ml-5 mt-1 space-y-1 text-text-dark/70">
            <li><a href="#ep-search-dni" class="text-vzla-blue/80 hover:text-vzla-blue underline underline-offset-2">4.1 GET /api/search/:dni</a></li>
            <li><a href="#ep-search-count" class="text-vzla-blue/80 hover:text-vzla-blue underline underline-offset-2">4.2 GET /api/search/count</a></li>
            <li><a href="#ep-public-patients" class="text-vzla-blue/80 hover:text-vzla-blue underline underline-offset-2">4.3 GET /api/public/patients</a></li>
            <li><a href="#ep-public-medical-centers" class="text-vzla-blue/80 hover:text-vzla-blue underline underline-offset-2">4.4 GET /api/public/medical-centers</a></li>
            <li><a href="#ep-public-medical-center" class="text-vzla-blue/80 hover:text-vzla-blue underline underline-offset-2">4.5 GET /api/public/medical-centers/:id</a></li>
            <li><a href="#ep-public-stats" class="text-vzla-blue/80 hover:text-vzla-blue underline underline-offset-2">4.6 GET /api/public/stats</a></li>
            <li><a href="#ep-contact" class="text-vzla-blue/80 hover:text-vzla-blue underline underline-offset-2">4.7 POST /api/contact</a></li>
            <li><a href="#ep-access-request" class="text-vzla-blue/80 hover:text-vzla-blue underline underline-offset-2">4.8 POST /api/auth/access-requests</a></li>
          </ul>
        </li>
        <li><a href="#enums" class="text-vzla-blue hover:text-vzla-blue-hover underline underline-offset-2">5. Tipos compartidos (Enums)</a></li>
        <li><a href="#codigos-error" class="text-vzla-blue hover:text-vzla-blue-hover underline underline-offset-2">6. Códigos de error</a></li>
        <li><a href="#endpoints-internos" class="text-vzla-blue hover:text-vzla-blue-hover underline underline-offset-2">7. Endpoints internos (con autenticación)</a></li>
        <li><a href="#contribuir" class="text-vzla-blue hover:text-vzla-blue-hover underline underline-offset-2">8. Cómo contribuir</a></li>
      </ul>
    </div>

    <!-- 1. INTRODUCCIÓN -->
    <section id="intro" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-4">
      <h2 class="font-display font-bold text-2xl text-text-dark flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-vzla-blue/10 flex items-center justify-center text-vzla-blue text-sm font-bold">1</span>
        Introducción
      </h2>
      <p class="font-sans text-base text-text-dark/80 leading-relaxed">
        <strong>S.I.R.E.</strong> expone una API REST que permite a otros sistemas consumir sus datos de forma pública y gratuita. 
        Esta documentación está dirigida a desarrolladores que quieran integrar sus propias iniciativas —mapas de desaparecidos, 
        centros de acopio, portales de búsqueda, etc.— con la base de datos centralizada de pacientes hospitalizados.
      </p>
      <div class="bg-vzla-blue/5 border border-vzla-blue/10 rounded-xl p-4 text-sm font-sans text-text-dark/70">
        <p class="font-semibold text-vzla-blue mb-1">🎯 ¿Para quién es esta API?</p>
        <ul class="list-disc list-inside space-y-1">
          <li>Desarrolladores de portales de búsqueda de desaparecidos</li>
          <li>Sistemas de centros de acopio y ayuda humanitaria</li>
          <li>Aplicaciones de mapas y visualización de datos de emergencia</li>
          <li>Cualquier proyecto que necesite información centralizada de pacientes hospitalizados</li>
        </ul>
      </div>
    </section>

    <!-- 2. BASE URL Y AUTENTICACIÓN -->
    <section id="base-url" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-4">
      <h2 class="font-display font-bold text-2xl text-text-dark flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-vzla-blue/10 flex items-center justify-center text-vzla-blue text-sm font-bold">2</span>
        Base URL y autenticación
      </h2>
      <div class="space-y-3">
        <div>
          <p class="font-sans text-sm text-text-dark/60 mb-1">Producción:</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-sm overflow-x-auto"><code>https://sire.example.com/api</code></pre>
        </div>
        <div>
          <p class="font-sans text-sm text-text-dark/60 mb-1">Desarrollo local:</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-sm overflow-x-auto"><code>http://localhost:3000/api</code></pre>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-sm font-sans">
          <p class="font-semibold text-green-700 mb-1">✅ Los endpoints públicos NO requieren autenticación</p>
          <p class="text-green-600">Puedes consumirlos directamente desde el cliente con <code class="bg-green-100 px-1.5 py-0.5 rounded text-xs">fetch()</code> o cualquier cliente HTTP.</p>
        </div>
      </div>
    </section>

    <!-- 3. RATE LIMITING -->
    <section id="rate-limiting" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-4">
      <h2 class="font-display font-bold text-2xl text-text-dark flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-vzla-blue/10 flex items-center justify-center text-vzla-blue text-sm font-bold">3</span>
        Rate Limiting
      </h2>
      <p class="font-sans text-base text-text-dark/80 leading-relaxed">
        Para garantizar la disponibilidad del servicio, los endpoints públicos tienen límites de peticiones por IP. 
        Si se excede el límite, la API responderá con <strong class="text-red-500">HTTP 429 Too Many Requests</strong>.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm font-sans border-collapse">
          <thead>
            <tr class="bg-bg-light border-b border-border-subtle">
              <th class="text-left py-2 px-3 font-semibold text-text-dark">Endpoint</th>
              <th class="text-left py-2 px-3 font-semibold text-text-dark">Límite</th>
              <th class="text-left py-2 px-3 font-semibold text-text-dark">Ventana</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-subtle">
            <tr><td class="py-2 px-3 font-mono text-xs">GET /api/search/:dni</td><td class="py-2 px-3">10</td><td class="py-2 px-3">1 minuto</td></tr>
            <tr><td class="py-2 px-3 font-mono text-xs">GET /api/search/count</td><td class="py-2 px-3">30</td><td class="py-2 px-3">1 minuto</td></tr>
            <tr><td class="py-2 px-3 font-mono text-xs">GET /api/public/patients</td><td class="py-2 px-3">20</td><td class="py-2 px-3">1 minuto</td></tr>
            <tr><td class="py-2 px-3 font-mono text-xs">GET /api/public/medical-centers</td><td class="py-2 px-3">30</td><td class="py-2 px-3">1 minuto</td></tr>
            <tr><td class="py-2 px-3 font-mono text-xs">GET /api/public/stats</td><td class="py-2 px-3">30</td><td class="py-2 px-3">1 minuto</td></tr>
            <tr><td class="py-2 px-3 font-mono text-xs">POST /api/contact</td><td class="py-2 px-3">3</td><td class="py-2 px-3">1 minuto</td></tr>
            <tr><td class="py-2 px-3 font-mono text-xs">POST /api/auth/access-requests</td><td class="py-2 px-3">3</td><td class="py-2 px-3">1 minuto</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 4. ENDPOINTS PÚBLICOS -->
    <section id="endpoints-publicos" class="space-y-6">
      <h2 class="font-display font-bold text-2xl text-text-dark flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-vzla-blue/10 flex items-center justify-center text-vzla-blue text-sm font-bold">4</span>
        Endpoints Públicos
      </h2>

      <!-- 4.1 Buscar por cédula -->
      <div id="ep-search-dni" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-4">
        <div class="flex items-center gap-3 flex-wrap">
          <span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">GET</span>
          <code class="font-mono text-sm bg-bg-light px-3 py-1.5 rounded-lg">/api/search/:dni</code>
        </div>
        <h3 class="font-display font-bold text-lg text-text-dark">Buscar paciente por cédula</h3>
        <p class="font-sans text-sm text-text-dark/70">Busca si una persona está registrada en el sistema. No expone información sensible del personal de salud.</p>
        
        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Parámetros:</p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm font-sans border-collapse">
              <thead><tr class="bg-bg-light border-b border-border-subtle"><th class="text-left py-2 px-3 font-semibold">Nombre</th><th class="text-left py-2 px-3 font-semibold">Tipo</th><th class="text-left py-2 px-3 font-semibold">Descripción</th></tr></thead>
              <tbody class="divide-y divide-border-subtle">
                <tr><td class="py-2 px-3 font-mono text-xs">dni</td><td class="py-2 px-3">string</td><td class="py-2 px-3">Número de cédula (solo dígitos)</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Ejemplo request:</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto"><code>GET /api/search/12345678</code></pre>
        </div>

        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Response (encontrado):</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto"><code>{code1}</code></pre>
        </div>

        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Response (no encontrado):</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto"><code>{code2}</code></pre>
        </div>

        <details class="text-sm font-sans">
          <summary class="cursor-pointer text-vzla-blue font-medium">TypeScript: interfaz de respuesta</summary>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto mt-2"><code>{code3}</code></pre>
        </details>
      </div>

      <!-- 4.2 Contador -->
      <div id="ep-search-count" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-4">
        <div class="flex items-center gap-3 flex-wrap">
          <span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">GET</span>
          <code class="font-mono text-sm bg-bg-light px-3 py-1.5 rounded-lg">/api/search/count</code>
        </div>
        <h3 class="font-display font-bold text-lg text-text-dark">Contador de pacientes registrados</h3>
        <p class="font-sans text-sm text-text-dark/70">Obtiene el número total de pacientes registrados en el sistema.</p>
        
        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Response:</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto"><code>{code4}</code></pre>
        </div>
      </div>

      <!-- 4.3 Listado público de pacientes -->
      <div id="ep-public-patients" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-4">
        <div class="flex items-center gap-3 flex-wrap">
          <span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">GET</span>
          <code class="font-mono text-sm bg-bg-light px-3 py-1.5 rounded-lg">/api/public/patients</code>
        </div>
        <h3 class="font-display font-bold text-lg text-text-dark">Listado paginado de pacientes</h3>
        <p class="font-sans text-sm text-text-dark/70">
          Lista todos los pacientes del sistema con paginación. 
          <strong>No expone el estatus de salud</strong> por privacidad, pero sí la ubicación y fecha de última actualización.
          Ideal para alimentar sistemas de búsqueda de desaparecidos, mapas, cruce de datos, etc.
        </p>

        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Parámetros query:</p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm font-sans border-collapse">
              <thead><tr class="bg-bg-light border-b border-border-subtle"><th class="text-left py-2 px-3 font-semibold">Nombre</th><th class="text-left py-2 px-3 font-semibold">Tipo</th><th class="text-left py-2 px-3 font-semibold">Default</th><th class="text-left py-2 px-3 font-semibold">Descripción</th></tr></thead>
              <tbody class="divide-y divide-border-subtle">
                <tr><td class="py-2 px-3 font-mono text-xs">page</td><td class="py-2 px-3">number</td><td class="py-2 px-3">1</td><td class="py-2 px-3">Número de página</td></tr>
                <tr><td class="py-2 px-3 font-mono text-xs">rows</td><td class="py-2 px-3">number</td><td class="py-2 px-3">50</td><td class="py-2 px-3">Registros por página (máx. 100)</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Ejemplo request:</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto"><code>GET /api/public/patients?page=1&rows=20</code></pre>
        </div>

        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Response:</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto"><code>{code5}</code></pre>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm font-sans">
          <p class="font-semibold text-amber-700 mb-1">⚠️ Privacidad</p>
          <p class="text-amber-600">Este endpoint no incluye el estatus de salud del paciente. Solo expone nombre, ubicación del centro, fecha de última actualización y fuente del registro.</p>
        </div>
      </div>

      <!-- 4.4 Centros médicos (lista) -->
      <div id="ep-public-medical-centers" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-4">
        <div class="flex items-center gap-3 flex-wrap">
          <span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">GET</span>
          <code class="font-mono text-sm bg-bg-light px-3 py-1.5 rounded-lg">/api/public/medical-centers</code>
        </div>
        <h3 class="font-display font-bold text-lg text-text-dark">Catálogo de centros médicos activos</h3>
        <p class="font-sans text-sm text-text-dark/70">Lista todos los centros médicos activos en el sistema. Ideal para poblar dropdowns, mapas o cruzar datos con otros sistemas.</p>
        
        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Response:</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto"><code>{code6}</code></pre>
        </div>
      </div>

      <!-- 4.5 Centro médico por ID -->
      <div id="ep-public-medical-center" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-4">
        <div class="flex items-center gap-3 flex-wrap">
          <span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">GET</span>
          <code class="font-mono text-sm bg-bg-light px-3 py-1.5 rounded-lg">/api/public/medical-centers/:id</code>
        </div>
        <h3 class="font-display font-bold text-lg text-text-dark">Detalle de centro médico</h3>
        <p class="font-sans text-sm text-text-dark/70">Obtiene la información detallada de un centro médico específico.</p>

        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Ejemplo request:</p>
          <pre class="bg-bg-light rounded-lg p-3 font-mono text-xs overflow-x-auto"><code>GET /api/public/medical-centers/1</code></pre>
        </div>

        <div>
          <p class="font-sans text-sm font-semibold text-text-dark mb-1">Response:</p>
