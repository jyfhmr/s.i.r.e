---
import Layout from '../layouts/Layout.astro';
import SearchForm from '../components/SearchForm.astro';
---

<Layout title="S.I.R.E. - Sistema de Información y Registro de Emergencias">
  <div class="space-y-10">
    <!-- Hero Section -->
    <section class="text-center max-w-3xl mx-auto space-y-5">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-vzla-blue/10 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-vzla-blue">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
        </svg>
      </div>
      
      <h1 class="font-display font-bold text-3xl md:text-5xl text-text-dark tracking-tight leading-tight">
        Sistema de Información y Registro de Emergencias
      </h1>
      
      <p class="font-sans text-base md:text-lg text-text-dark/70 leading-relaxed max-w-2xl mx-auto">
        Tras los <strong class="text-text-dark">terremotos del 24 de junio de 2026</strong> en Venezuela, S.I.R.E. recopila 
        las listas de pacientes publicadas por los hospitales y las centraliza en un solo sitio. 
        <strong class="text-text-dark"> valorBusca por cédula</strong> a tu allegado y entérate de su paradero.
      </p>

      <!-- Formulario de Búsqueda - visible de inmediato -->
      <div class="w-full max-w-2xl mx-auto">
        <SearchForm />
      </div>

      <!-- Calla-to-action en fila: Alerta + Registro Médico -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-2">
        <a 
          href="/register" 
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-xl transition-all shadow-xs no-underline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3zm-8.27 4a2 2 0 0 1-3.46 0"></path>
          </svg>
          Crear Alerta de Seguimiento
        </a>
        <a 
          href="/personal-salud" 
          class="inline-flex items-center justify-center gap-2 px-6 py-3 border-2 border-vzla-blue text-vzla-blue hover:bg-vzla-blue/5 font-display font-bold text-sm rounded-xl transition-all shadow-xs no-underline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <polyline points="16 11 18 13 22 9"></polyline>
          </svg>
          Registrarme como Médico
        </a>
      </div>
      <p class="font-sans text-xs text-text-dark/50">
        Para la alerta crea una cuenta ciudadana · Para registrarte como médico llena el formulario y el equipo de S.I.R.E. habilita tu acceso
      </p>

      <!-- Contador de personas registradas -->
      <div id="patient-counter" class="w-full max-w-xs mx-auto bg-white/70 backdrop-blur-sm border border-vzla-blue/20 rounded-xl px-5 py-3 shadow-sm">
        <p class="font-sans text-sm text-text-dark/60 text-center flex items-center justify-center gap-2">
          <span id="counter-number" class="font-display font-bold text-vzla-blue text-lg">—</span>
          <span>afectados registrados</span>
        </p>
      </div>


      <!-- Contenedor dinámico de resultados (Justo debajo del buscador) -->
      <section id="results-section" class="w-full max-w-2xl mx-auto text-left hidden" aria-live="polite">
        <!-- Loading -->
        <div id="results-loading" class="text-center py-12 hidden">
          <div class="inline-flex items-center gap-3 text-vzla-blue justify-center w-full">
            <svg class="animate-spin h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="font-display font-semibold text-lg">Buscando en la base de datos...</span>
          </div>
        </div>

        <!-- Tarjeta de paciente (inyectada dinámicamente) -->
        <div id="patient-card-holder" class="animate-fade-in"></div>

        <!-- No encontrado -->
        <div id="results-not-found" class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm text-center space-y-5 hidden">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-vzla-blue/10 text-vzla-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-text-dark">Sin resultados en este momento</h3>
          <p id="not-found-message" class="font-sans text-base text-text-dark/70 max-w-lg mx-auto leading-relaxed">
            No se encontraron registros de esta persona en el sistema. El equipo de S.I.R.E. revisa e inserta diariamente las listas publicadas por los hospitales, por lo que los datos se actualizan de forma constante. Si creas una cuenta gratuita y configuras una alerta, te notificaremos automáticamente por correo electrónico en cuanto esta persona sea registrada en el sistema.
          </p>
          
          <!-- CTA: Configurar alerta -->
          <div class="bg-bg-light border border-border-subtle rounded-xl p-5 max-w-md mx-auto">
            <p class="font-display font-semibold text-base text-text-dark mb-3">
              ¿Quieres enterarte inmediatamente si esta persona ingresa a algún hospital?
            </p>
            <a 
              href="/register" 
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-xl transition-all shadow-xs no-underline"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3zm-8.27 4a2 2 0 0 1-3.46 0"></path>
              </svg>
              Configurar Alerta por Correo
            </a>
            <p class="text-xs text-text-dark/50 mt-3">
              Recibirás un email automático cuando el personal médico registre a esta persona
            </p>
          </div>
        </div>

        <!-- Error -->
        <div id="results-error" class="bg-error-light border border-error-border rounded-2xl p-6 md:p-8 text-center space-y-4 hidden">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-error-text/10 text-error-text">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-error-text">Error de conexión</h3>
          <p id="error-message" class="font-sans text-base text-text-dark/70 max-w-lg mx-auto"></p>
        </div>
      </section>

      <div class="bg-white border border-border-subtle rounded-2xl p-6 shadow-sm text-left max-w-2xl mx-auto">
        <h2 class="font-display font-bold text-lg text-text-dark mb-3 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-vzla-blue"></span>
          Dos Frentes de Acción
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm md:text-base font-sans">
          <div class="space-y-2">
            <h3 class="font-display font-bold text-base text-vzla-blue">Frente Ciudadano (Público)</h3>
            <p class="text-text-dark/70 leading-relaxed">
     
Busca el paradero de un ser querido por su cédula o crea una Alerta de Seguimiento: recibirás un email automático apenas el personal médico registre información sobre esa persona. También puedes crear una alerta de seguimiento si quieres enterarte inmediatamente si aparece en alguna lista publicada por hospitales
            </p>
          </div>
          <div class="space-y-2">
            <h3 class="font-display font-bold text-base text-text-dark">Frente Médico (Privado)</h3>
            <p class="text-text-dark/70 leading-relaxed">
              Para que el personal de salud ingrese y actualice el estado de los pacientes en segundos, 
              reemplazando las listas de papel por un <strong>directorio digital centralizado</strong>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección: Listas de Hospitales Incorporadas (CU 0 - Transparencia) -->
    <section class="max-w-3xl mx-auto">
      <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm">
        <h2 class="font-display font-bold text-lg text-text-dark mb-4 flex items-center gap-2">
          <span class="text-vzla-blue text-xl">📋</span>
          Listas de Hospitales Incorporadas
        </h2>

        <p class="font-sans text-sm md:text-base text-text-dark/70 leading-relaxed mb-5">
          Hemos recopilado manualmente las listas de pacientes de los siguientes centros de salud.
          <strong class="text-text-dark">No tenemos alianzas oficiales</strong> con estos centros;
          la información puede estar desactualizada.
        </p>

        <ul class="space-y-3 mb-6">
          <li class="flex items-start gap-3 bg-bg-light rounded-xl p-4">
            <span class="text-vzla-blue mt-0.5 shrink-0">•</span>
            <div>
              <p class="font-display font-bold text-base text-text-dark">Hospital Dr. Miguel Pérez Carreño (IVSS)</p>
              <p class="font-sans text-sm text-text-dark/60">📍 Bella Vista — Distrito Capital</p>
            </div>
          </li>
          <li class="flex items-start gap-3 bg-bg-light rounded-xl p-4">
            <span class="text-vzla-blue mt-0.5 shrink-0">•</span>
            <div>
              <p class="font-display font-bold text-base text-text-dark">Hospital Dr. Domingo Luciani</p>
              <p class="font-sans text-sm text-text-dark/60">📍 El Llanito — Miranda</p>
            </div>
          </li>
        </ul>

        <div class="border-t border-border-subtle/50 pt-5 text-center">
          <p class="font-sans text-sm md:text-base text-text-dark/70 leading-relaxed mb-4">
            ⚠️ ¿Tienes acceso a una lista de algún hospital que aún no esté aquí?
          </p>
          <a 
            href="/contact" 
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-xl transition-all shadow-xs no-underline"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            Colabora — envíanos la información
          </a>
        </div>
      </div>
    </section>

    <!-- Botones de Enrutamiento - CU 0 -->
    <section class="max-w-3xl mx-auto pt-6 border-t border-border-subtle/50">
      <h2 class="font-display font-bold text-xl text-text-dark mb-5 text-center">
        ¿Cómo puedo usar S.I.R.E.?
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- CU 6: Recibir alertas -->
        <a 
          href="/register" 
          class="group bg-white hover:bg-vzla-blue-light border border-border-subtle hover:border-vzla-blue-border rounded-2xl p-6 transition-all shadow-xs hover:shadow text-left no-underline"
        >
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-vzla-blue/10 group-hover:bg-vzla-blue/20 text-vzla-blue mb-4 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3zm-8.27 4a2 2 0 0 1-3.46 0"></path>
            </svg>
          </div>
          <h3 class="font-display font-bold text-base text-text-dark mb-2">Recibir Alertas por Correo</h3>
          <p class="text-sm text-text-dark/60 font-sans leading-relaxed">
            Configura alertas para enterarte inmediatamente si alguien aparece en algún hospital
          </p>
        </a>

        <!-- CU 4: Personal de salud -->
        <a 
          href="/personal-salud" 
          class="group bg-white hover:bg-vzla-blue-light border border-border-subtle hover:border-vzla-blue-border rounded-2xl p-6 transition-all shadow-xs hover:shadow text-left no-underline"
        >
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-vzla-blue/10 group-hover:bg-vzla-blue/20 text-vzla-blue mb-4 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <polyline points="16 11 18 13 22 9"></polyline>
            </svg>
          </div>
          <h3 class="font-display font-bold text-base text-text-dark mb-2">Soy Personal de Salud</h3>
          <p class="text-sm text-text-dark/60 font-sans leading-relaxed">
            Solicita acceso oficial como médico, enfermero o paramédico para registrar pacientes
          </p>
        </a>

        <!-- CU 9: Iniciar sesión -->
        <a 
          href="/login" 
          class="group bg-white hover:bg-vzla-blue-light border border-border-subtle hover:border-vzla-blue-border rounded-2xl p-6 transition-all shadow-xs hover:shadow text-left no-underline"
        >
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-vzla-blue/10 group-hover:bg-vzla-blue/20 text-vzla-blue mb-4 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
              <polyline points="10 17 15 12 10 7"></polyline>
              <line x1="15" y1="12" x2="3" y2="12"></line>
            </svg>
          </div>
          <h3 class="font-display font-bold text-base text-text-dark mb-2">Iniciar Sesión</h3>
          <p class="text-sm text-text-dark/60 font-sans leading-relaxed">
            Si ya tienes una cuenta, ingresa para acceder al sistema
          </p>
        </a>
      </div>
    </section>
  </div>
</Layout>

<!-- Script de Búsqueda Real conectado al API -->
<script>
  import { searchPatientByDni, getPatientCount, type ApiError } from '../lib/api';
  import { getStatusConfig, getRegistrationSourceInfo } from '../lib/patient-status';
  import { PatientStatus, RegistrationSource } from '@shared/common';

  // Formatear fecha a texto relativo en español
  function formatRelativeTime(date: Date): string {
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return 'Hace menos de un minuto';
    if (diffMins === 1) return 'Hace 1 minuto';
    if (diffMins < 60) return `Hace ${diffMins} minutos`;
    if (diffHours === 1) return 'Hace 1 hora';
    if (diffHours < 24) return `Hace ${diffHours} horas`;
    if (diffDays === 1) return 'Hace 1 día';
    if (diffDays < 7) return `Hace ${diffDays} días`;
    
    return date.toLocaleDateString('es-VE', { 
      year: 'numeric', 
      month: 'long', 
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  }

  async function executeSearch(searchVal?: string) {
    // Si no se pasa un valor, leer de la URL
    if (!searchVal) {
      const params = new URLSearchParams(window.location.search);
      searchVal = params.get('search') || '';
    }
    
    // Sanitizar de entrada (eliminar letras de nacionalidad, puntos y espacios)
    if (searchVal) {
      searchVal = searchVal.replace(/[vVeE\.\-\s]/g, '').trim();
    }
    
    const resultsSection = document.getElementById('results-section');
    const loadingDiv = document.getElementById('results-loading');
    const cardHolder = document.getElementById('patient-card-holder');
    const notFoundDiv = document.getElementById('results-not-found');
    const errorDiv = document.getElementById('results-error');
    const searchInput = document.getElementById('search') as HTMLInputElement;

    if (!resultsSection || !loadingDiv || !cardHolder || !notFoundDiv || !errorDiv) return;

    // Si no hay búsqueda, ocultar todo
    if (!searchVal || !searchVal.trim()) {
      resultsSection.classList.add('hidden');
      return;
    }

    // Colocar el valor en el input
    if (searchInput) {
      searchInput.value = searchVal;
    }

    // Mostrar sección de resultados y loading
    resultsSection.classList.remove('hidden');
    loadingDiv.classList.remove('hidden');
    cardHolder.innerHTML = '';
    notFoundDiv.classList.add('hidden');
    errorDiv.classList.add('hidden');

    try {
      // Llamada real al API
      const response = await searchPatientByDni(searchVal);

      // Ocultar loading
      loadingDiv.classList.add('hidden');

      if (!response.found) {
        // No encontrado
        const messageEl = document.getElementById('not-found-message');
        if (messageEl) messageEl.textContent = response.message;
        notFoundDiv.classList.remove('hidden');
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      }

      // Paciente encontrado - renderizar tarjeta (solo localización, sin estatus médico)
      if (response.data) {
        const { fullName, status, location, lastUpdated, registrationSource } = response.data;
        const config = getStatusConfig(status as PatientStatus);
        const sourceInfo = getRegistrationSourceInfo(registrationSource as RegistrationSource);
        const formattedDate = formatRelativeTime(new Date(lastUpdated));

        cardHolder.innerHTML = `
          <div class="w-full bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm flex flex-col gap-5 font-sans animate-fade-in">
            <!-- Cabecera -->
            <div class="border-b border-border-subtle/50 pb-4">
              <span class="text-xs font-semibold text-text-dark/45 tracking-wider uppercase font-sans">Reporte de Localización</span>
              <h2 class="font-display font-bold text-2xl md:text-3xl text-text-dark mt-0.5">${fullName}</h2>
            </div>

            <!-- Estado: Localizado (badge simple sin detalle médico) -->
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full ${config.badgeClass} block shrink-0"></span>
              <span class="font-display font-bold text-lg md:text-xl tracking-tight text-text-dark">${config.label}</span>
            </div>

            <!-- Fuente del registro -->
            <div class="flex items-center gap-2 text-sm text-text-dark/60">
              <span>${sourceInfo.icon}</span>
              <span>${sourceInfo.label}</span>
            </div>

            <!-- Ubicación -->
            <div class="space-y-1">
              <h3 class="text-xs font-semibold text-text-dark/45 tracking-wider uppercase">Centro de Salud / Ubicación</h3>
              <p class="font-display font-bold text-lg text-vzla-blue">${location}</p>
            </div>

            <!-- Footer: solo última actualización -->
            <div class="border-t border-border-subtle/50 pt-4 flex items-center gap-1.5 text-xs md:text-sm text-text-dark/50">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              <span>Última actualización: <strong>${formattedDate}</strong></span>
            </div>
          </div>
        `;
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    } catch (error) {
      // Manejar errores
      loadingDiv.classList.add('hidden');
      const apiError = error as ApiError;
      const errorMessageEl = document.getElementById('error-message');
      if (errorMessageEl) {
        errorMessageEl.textContent = apiError.message || 'Ocurrió un error inesperado';
      }
      errorDiv.classList.remove('hidden');
    } finally {
      // Restablecer el estado del botón de búsqueda
      const searchBtn = document.getElementById('search-btn') as HTMLButtonElement;
      const spinner = document.getElementById('search-spinner');
      const btnText = document.getElementById('search-btn-text');
      
      if (searchBtn) searchBtn.disabled = false;
      if (spinner) spinner.classList.add('hidden');
      if (btnText) btnText.textContent = 'Buscar Familiar';
    }
  }

  // Ejecutar al cargar la página
  if (typeof window !== 'undefined') {
    // Cargar contador de personas registradas
    getPatientCount().then(data => {
      const el = document.getElementById('counter-number');
      if (el && data?.total !== undefined) {
        el.textContent = data.total.toLocaleString('es-VE');
      }
    }).catch(() => {
      // Silencio — el contador no es crítico
    });

    // Interceptar el submit del formulario para evitar scroll al tope
    const searchForm = document.querySelector('form[method="GET"]') as HTMLFormElement;
    if (searchForm) {
      searchForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const searchInput = document.getElementById('search') as HTMLInputElement;
        const rawValue = searchInput?.value || '';
        const searchValue = rawValue.replace(/[vVeE\.\-\s]/g, '').trim();
        
        if (searchInput && rawValue !== searchValue) {
          searchInput.value = searchValue;
        }
        
        if (searchValue) {
          // Actualizar URL sin recargar la página
          const newUrl = new URL(window.location.href);
          newUrl.searchParams.set('search', searchValue);
          window.history.pushState({}, '', newUrl);
          
          // Ejecutar búsqueda sin scroll
          executeSearch(searchValue);
        }
      });
    }

    // Ejecutar búsqueda inicial si hay parámetro en la URL
    executeSearch();
  }
</script>

<style>
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .animate-spin {
    animation: spin 1s linear infinite;
  }
</style>
