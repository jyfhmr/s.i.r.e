---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Iniciar Sesión - S.I.R.E.">
  <div class="max-w-md mx-auto my-8 md:my-16 space-y-6 animate-fade-in font-sans">
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
      
      <!-- Título -->
      <div class="text-center space-y-1">
        <h1 class="font-display font-bold text-2xl md:text-3xl text-text-dark">Iniciar Sesión</h1>
        <p class="text-xs md:text-sm text-text-dark/60">
          Ingresa tus credenciales para acceder a la plataforma.
        </p>
      </div>

      <!-- Formulario de Acceso Unificado -->
      <form id="form-user-login" class="space-y-4">
        <div class="space-y-1.5">
          <label for="login-email" class="block text-sm font-semibold text-text-dark/70">Correo electrónico</label>
          <input 
            type="email" 
            id="login-email" 
            required 
            class="w-full h-14 px-4 bg-white border border-border-subtle rounded-xl text-base focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
            placeholder="correo@ejemplo.com"
          />
        </div>

        <div class="space-y-1.5">
          <label for="login-password" class="block text-sm font-semibold text-text-dark/70">Contraseña</label>
          <div class="relative">
            <input 
              type="password" 
              id="login-password" 
              required 
              class="w-full h-14 pl-4 pr-12 bg-white border border-border-subtle rounded-xl text-base focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
              placeholder="••••••••"
            />
            <button type="button" id="toggle-password" class="absolute inset-y-0 right-0 px-4 flex items-center text-text-dark/50 hover:text-vzla-blue focus:outline-none" aria-label="Mostrar contraseña">
              <svg id="eye-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </div>

        <!-- Alerta de Error -->
        <div id="login-error" class="hidden bg-error-light border border-error-border text-error-text text-xs font-semibold rounded-lg p-3" role="alert">
          ⚠️ Credenciales incorrectas o usuario no registrado.
        </div>

        <button 
          type="submit" 
          class="w-full h-14 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-base rounded-xl cursor-pointer transition-all shadow-xs flex items-center justify-center gap-2"
        >
          <svg id="login-spinner" class="animate-spin h-5 w-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span id="login-btn-text">Ingresar al Sistema</span>
        </button>
      </form>

      <!-- Enlace recuperar contraseña -->
      <div class="text-center">
        <a href="/forgot-password" class="text-xs text-vzla-blue hover:underline font-semibold">¿Olvidaste tu contraseña?</a>
      </div>
    </div>

    <!-- Enlace de registro rápido -->
    <div class="text-center text-xs md:text-sm text-text-dark/60">
      ¿No tienes una cuenta de alertas? 
      <a href="/register" class="text-vzla-blue hover:underline font-semibold ml-1">Regístrate aquí</a>
    </div>
  </div>
</Layout>

<script>
  import { login } from '../lib/auth';

  if (typeof window !== 'undefined') {
    const loginForm = document.getElementById('form-user-login') as HTMLFormElement;
    const loginError = document.getElementById('login-error') as HTMLElement;
    const submitBtn = loginForm?.querySelector('button[type="submit"]') as HTMLButtonElement;
    const btnText = document.getElementById('login-btn-text') as HTMLElement;
    const spinner = document.getElementById('login-spinner') as HTMLElement;

    // Toggle password
    const toggleBtn = document.getElementById('toggle-password');
    const pwdInput = document.getElementById('login-password') as HTMLInputElement;
    const eyeIcon = document.getElementById('eye-icon');
    
    if (toggleBtn && pwdInput && eyeIcon) {
      toggleBtn.addEventListener('click', () => {
        const type = pwdInput.getAttribute('type') === 'password' ? 'text' : 'password';
        pwdInput.setAttribute('type', type);
        
        if (type === 'text') {
          eyeIcon.innerHTML = `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>`;
        } else {
          eyeIcon.innerHTML = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>`;
        }
      });
    }

    // Mostrar mensaje si viene de sesión expirada
    const params = new URLSearchParams(window.location.search);
    if (params.get('error') === 'session_expired') {
      if (loginError) {
        loginError.textContent = '⚠️ ' + (params.get('message') || 'Tu sesión ha expirado. Por favor inicia sesión nuevamente.');
        loginError.classList.remove('hidden');
      }
    } else if (params.get('error') === 'auth_required') {
      if (loginError) {
        loginError.textContent = '⚠️ Debes iniciar sesión para acceder a esa página.';
        loginError.classList.remove('hidden');
      }
    }

    if (loginForm && loginError && submitBtn) {
      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const email = (document.getElementById('login-email') as HTMLInputElement).value.trim();
        const password = (document.getElementById('login-password') as HTMLInputElement).value;

        // Deshabilitar botón
        submitBtn.disabled = true;
        if (btnText) btnText.textContent = 'Iniciando sesión...';
        if (spinner) spinner.classList.remove('hidden');
        loginError.classList.add('hidden');

        try {
          // Login real con JWT
          await login(email, password);
          
          // Redirigir al dashboard (el layout se encarga de redirigir a la ruta correcta)
          window.location.href = '/dashboard';
        } catch (error: any) {
          // Mostrar error
          loginError.textContent = '⚠️ ' + (error.message || 'Credenciales incorrectas o usuario no registrado.');
          loginError.classList.remove('hidden');
          
          // Re-habilitar botón
          submitBtn.disabled = false;
          if (btnText) btnText.textContent = 'Ingresar al Sistema';
          if (spinner) spinner.classList.add('hidden');
        }
      });
    }
  }
</script>


