---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Restablecer Contraseña - S.I.R.E." noindex={true}>
  <div class="max-w-md mx-auto my-8 md:my-16 space-y-6 animate-fade-in font-sans">
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
      
      <!-- Título -->
      <div class="text-center space-y-1">
        <h1 class="font-display font-bold text-2xl md:text-3xl text-text-dark">Restablecer Contraseña</h1>
        <p class="text-xs md:text-sm text-text-dark/60">
          Ingresa tu nueva contraseña para recuperar el acceso a tu cuenta.
        </p>
      </div>

      <!-- Formulario -->
      <form id="reset-password-form" class="space-y-4">
        <div class="space-y-1.5">
          <label for="password" class="block text-sm font-semibold text-text-dark/70">Nueva Contraseña</label>
          <input 
            type="password" 
            id="password" 
            required 
            minlength="6"
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="Mínimo 6 caracteres"
          />
        </div>

        <div class="space-y-1.5">
          <label for="confirm-password" class="block text-sm font-semibold text-text-dark/70">Confirmar Contraseña</label>
          <input 
            type="password" 
            id="confirm-password" 
            required 
            minlength="6"
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="Repite tu contraseña"
          />
        </div>

        <!-- Mensajes -->
        <div id="form-error" class="hidden bg-error-light border border-error-border text-error-text text-xs font-semibold rounded-lg p-3" role="alert"></div>
        <div id="form-success" class="hidden bg-success-light border border-success-border text-success-text text-xs font-semibold rounded-lg p-3" role="alert"></div>

        <button 
          type="submit" 
          id="submit-btn"
          class="w-full h-11 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg cursor-pointer transition-colors shadow-xs"
        >
          Restablecer Contraseña
        </button>
      </form>
    </div>

    <!-- Enlaces -->
    <div class="text-center space-y-2">
      <p class="text-xs md:text-sm text-text-dark/60">
        <a href="/login" class="text-vzla-blue hover:underline font-semibold">Volver al inicio de sesión</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { resetPassword } from '../lib/api';

  if (typeof window !== 'undefined') {
    const form = document.getElementById('reset-password-form') as HTMLFormElement;
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const confirmPasswordInput = document.getElementById('confirm-password') as HTMLInputElement;
    const formError = document.getElementById('form-error') as HTMLElement;
    const formSuccess = document.getElementById('form-success') as HTMLElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    // Obtener userId y token del query string
    const urlParams = new URLSearchParams(window.location.search);
    const userId = urlParams.get('userId');
    const token = urlParams.get('token');

    // Validar que existan los parámetros
    if (!userId || !token) {
      if (formError) {
        formError.textContent = '⚠️ Enlace de recuperación inválido o expirado. Por favor solicita un nuevo enlace.';
        formError.classList.remove('hidden');
      }
      if (submitBtn) submitBtn.disabled = true;
    }
    
    if (form && passwordInput && confirmPasswordInput && formError && formSuccess && submitBtn && userId && token) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const password = passwordInput.value;
        const confirmPassword = confirmPasswordInput.value;

        // Limpiar mensajes
        formError.classList.add('hidden');
        formSuccess.classList.add('hidden');

        // Validar que las contraseñas coincidan
        if (password !== confirmPassword) {
          formError.textContent = '⚠️ Las contraseñas no coinciden. Por favor verifica.';
          formError.classList.remove('hidden');
          return;
        }

        // Deshabilitar botón
        submitBtn.disabled = true;
        submitBtn.textContent = 'Restableciendo...';

        try {
          const response = await resetPassword(parseInt(userId), token, password);

          // Mostrar mensaje de éxito
          formSuccess.textContent = response.message || '✓ Contraseña restablecida exitosamente. Redirigiendo al inicio de sesión...';
          formSuccess.classList.remove('hidden');
          form.reset();
          
          // Deshabilitar formulario
          passwordInput.disabled = true;
          confirmPasswordInput.disabled = true;
          
          // Redirigir a login después de 2 segundos
          setTimeout(() => {
            window.location.href = '/login';
          }, 2000);
        } catch (error: any) {
          // Mostrar error
          formError.textContent = '⚠️ ' + (error.message || 'Error al restablecer la contraseña. El enlace puede estar expirado.');
          formError.classList.remove('hidden');
          
          // Re-habilitar botón
          submitBtn.disabled = false;
          submitBtn.textContent = 'Restablecer Contraseña';
        }
      });
    }
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
