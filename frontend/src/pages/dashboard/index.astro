---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Dashboard - S.I.R.E.">
	<!-- El DashboardLayout ya maneja la redirección automática a la primera ruta válida -->
	<div class="flex items-center justify-center py-20">
		<div class="text-center space-y-4">
			<div class="animate-spin h-12 w-12 border-4 border-vzla-blue border-t-transparent rounded-full mx-auto"></div>
			<p class="font-display font-semibold text-lg text-text-dark">Cargando...</p>
		</div>
	</div>
</DashboardLayout>
