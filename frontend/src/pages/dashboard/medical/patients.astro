---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Gestión de Pacientes - S.I.R.E.">
	<div class="space-y-6">
		<!-- Header -->
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
			<div>
				<h2 class="font-display font-bold text-2xl md:text-3xl text-text-dark">Mis Pacientes</h2>
				<p class="text-sm text-text-dark/60 mt-1">Administra los pacientes que has registrado o actualizado</p>
			</div>
			<button 
				id="btn-new-patient"
				class="h-11 px-6 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-xl transition-all shadow-xs"
			>
				+ Registrar Paciente
			</button>
		</div>

		<!-- Buscador Global (por cédula) -->
		<div class="bg-white border border-border-subtle rounded-xl p-4 shadow-sm">
			<form id="search-form" class="flex gap-3">
				<div class="flex-1">
					<input 
						type="text"
						id="search-dni"
						placeholder="Buscar paciente por cédula (cualquier centro médico)..."
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
					/>
				</div>
				<button 
					type="submit"
					class="h-11 px-6 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg transition-all"
				>
					Buscar
				</button>
			</form>
			<div id="search-result" class="hidden mt-4"></div>
		</div>

		<!-- Tabla de Pacientes -->
		<div class="bg-white border border-border-subtle rounded-xl shadow-sm overflow-hidden">
			<div class="p-4 border-b border-border-subtle">
				<h3 class="font-display font-bold text-lg text-text-dark">Lista de Pacientes</h3>
			</div>

			<!-- Loading -->
			<div id="patients-loading" class="p-8 text-center">
				<div class="animate-spin h-8 w-8 border-2 border-vzla-blue border-t-transparent rounded-full mx-auto"></div>
				<p class="text-sm text-text-dark/60 mt-3">Cargando pacientes...</p>
			</div>

			<!-- Tabla -->
			<div id="patients-table-container" class="hidden overflow-x-auto">
				<table class="w-full">
					<thead class="bg-bg-light border-b border-border-subtle">
						<tr class="text-left text-xs font-display font-bold text-text-dark/70 uppercase tracking-wider">
							<th class="px-4 py-3">Cédula</th>
							<th class="px-4 py-3">Nombre Completo</th>
							<th class="px-4 py-3">Estado</th>
							<th class="px-4 py-3">Centro / Ubicación</th>
							<th class="px-4 py-3">Última Act.</th>
							<th class="px-4 py-3 text-right">Acciones</th>
						</tr>
					</thead>
					<tbody id="patients-tbody" class="divide-y divide-border-subtle"></tbody>
				</table>
			</div>

			<!-- Empty State -->
			<div id="patients-empty" class="hidden p-12 text-center space-y-3">
				<div class="w-16 h-16 mx-auto rounded-full bg-bg-light flex items-center justify-center text-text-dark/40">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
						<circle cx="9" cy="7" r="4"></circle>
						<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
						<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
					</svg>
				</div>
				<p class="font-display font-semibold text-text-dark">No has registrado pacientes aún</p>
				<p class="text-sm text-text-dark/60">Haz clic en "Registrar Paciente" para comenzar</p>
			</div>

			<!-- Paginación -->
			<div id="patients-pagination" class="hidden border-t border-border-subtle p-4 flex items-center justify-between">
				<span id="pagination-info" class="text-sm text-text-dark/60"></span>
				<div class="flex gap-2">
					<button id="btn-prev" class="h-9 px-4 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
						Anterior
					</button>
					<button id="btn-next" class="h-9 px-4 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
						Siguiente
					</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Modal Upsert Paciente -->
	<div id="patient-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
			<div class="sticky top-0 bg-white border-b border-border-subtle p-6 flex items-center justify-between">
				<h3 id="modal-title" class="font-display font-bold text-xl text-text-dark">Registrar Nuevo Paciente</h3>
				<button id="modal-close" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-bg-light transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
			</div>

			<form id="patient-form" class="p-6 space-y-5">
				<!-- Cédula -->
				<div class="space-y-2">
					<label for="patient-dni" class="block text-sm font-display font-bold text-text-dark">
						Cédula de Identidad <span class="text-error-text">*</span>
					</label>
					<div class="flex gap-2">
						<input 
							type="text"
							id="patient-dni"
							required
							class="flex-1 h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
							placeholder="Ej: 12345678"
						/>
						<button 
							type="button"
							id="btn-lookup-dni"
							class="h-11 px-4 border border-vzla-blue/30 text-vzla-blue bg-vzla-blue/5 hover:bg-vzla-blue/10 rounded-lg font-display font-semibold text-sm transition-colors whitespace-nowrap"
						>
							Buscar
						</button>
					</div>
					<p id="dni-lookup-hint" class="text-xs text-text-dark/50">Ingresa la cédula y pulsa "Buscar" para autocompletar los datos si ya existe.</p>
				</div>


				<!-- Nombre Completo -->
				<div class="space-y-2">
					<label for="patient-name" class="block text-sm font-display font-bold text-text-dark">
						Nombre Completo <span class="text-error-text">*</span>
					</label>
					<input 
						type="text"
						id="patient-name"
						required
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
						placeholder="Ej: Juan Alberto Pérez"
					/>
				</div>

				<!-- Estado -->
				<div class="space-y-2">
					<label for="patient-status" class="block text-sm font-display font-bold text-text-dark">
						Estado del Paciente <span class="text-error-text">*</span>
					</label>
					<select 
						id="patient-status"
						required
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
					>
						<option value="">Seleccionar estado...</option>
						<option value="ESTABLE">Estable</option>
						<option value="CRÍTICO">Crítico</option>
						<option value="CONTACTAR_INMEDIATO">Contactar Inmediato</option>
						<option value="DESAPARECIDO">Desaparecido</option>
					</select>
				</div>

				<!-- Centro de Salud: combobox con búsqueda (ILike) o escritura manual -->
				<div class="space-y-2">
					<label for="medical-center-search" class="block text-sm font-display font-bold text-text-dark">
						Centro de Salud
					</label>

					<!-- Combobox: input de búsqueda + dropdown de resultados -->
					<div id="medical-center-combobox" class="relative">
						<input 
							type="text"
							id="medical-center-search"
							autocomplete="off"
							class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
							placeholder="Escribe el nombre del centro de salud..."
						/>
						<ul 
							id="medical-center-dropdown"
							class="hidden absolute z-20 mt-1 w-full max-h-60 overflow-y-auto bg-white border border-border-subtle rounded-lg shadow-lg text-sm"
						></ul>
					</div>

					<!-- Centro seleccionado del catálogo -->
					<div id="medical-center-selected" class="hidden items-center justify-between gap-2 bg-vzla-blue/5 border border-vzla-blue/20 rounded-lg px-3 py-2.5">
						<span id="medical-center-selected-name" class="text-sm font-display font-semibold text-text-dark"></span>
						<button type="button" id="medical-center-clear" class="text-xs text-vzla-blue hover:underline font-display font-semibold whitespace-nowrap">
							Cambiar
						</button>
					</div>

					<!-- Input de escritura manual -->
					<input 
						type="text"
						id="medical-center-manual"
						autocomplete="off"
						class="hidden w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
						placeholder="Escribe el nombre del centro o ubicación..."
					/>
					<p class="text-xs text-text-dark/50">Escribe para buscar en el catálogo o elige "Escribir manualmente".</p>
				</div>

				<!-- ID del centro seleccionado (oculto) -->
				<input type="hidden" id="selected-center-id" value="" />



				<!-- Mensajes -->
				<div id="form-error" class="hidden bg-error-light border border-error-border text-error-text text-sm rounded-lg p-3"></div>
				<div id="form-success" class="hidden bg-success-light border border-success-border text-success-text text-sm rounded-lg p-3"></div>

				<!-- Botones -->
				<div class="flex gap-3 pt-2">
					<button 
						type="button"
						id="modal-cancel"
						class="flex-1 h-11 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors"
					>
						Cancelar
					</button>
					<button 
						type="submit"
						id="modal-submit"
						class="flex-1 h-11 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg transition-all"
					>
						Guardar Paciente
					</button>
				</div>
			</form>
		</div>
	</div>
</DashboardLayout>

<script>
	import { findAllPatients, searchPatientByDniMedical, upsertPatient, searchMedicalCenters } from '../../../lib/api';


	import { getStatusConfig } from '../../../lib/patient-status';
	import type { IPatient, IUpsertPatientDto } from '@shared/core/medical/patients/interfaces';
	import type { PatientStatus } from '@shared/common';
	import type { IMedicalCenter } from '@shared/core/config/medical-centers/interfaces';

	// ==================== STATE ====================
	let currentPage = 1;
	const rowsPerPage = 10;
	let totalPatients = 0;
	let patients: IPatient[] = [];
	let searchTimeout: number;

	// ==================== ELEMENTOS ====================
	const loadingEl = document.getElementById('patients-loading') as HTMLElement;
	const tableContainer = document.getElementById('patients-table-container') as HTMLElement;
	const emptyEl = document.getElementById('patients-empty') as HTMLElement;
	const tbody = document.getElementById('patients-tbody') as HTMLTableSectionElement;
	const paginationEl = document.getElementById('patients-pagination') as HTMLElement;
	const paginationInfo = document.getElementById('pagination-info') as HTMLElement;
	const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
	const btnNext = document.getElementById('btn-next') as HTMLButtonElement;

	const modal = document.getElementById('patient-modal') as HTMLElement;
	const modalTitle = document.getElementById('modal-title') as HTMLElement;
	const modalClose = document.getElementById('modal-close') as HTMLElement;
	const modalCancel = document.getElementById('modal-cancel') as HTMLElement;
	const patientForm = document.getElementById('patient-form') as HTMLFormElement;

	const btnNewPatient = document.getElementById('btn-new-patient') as HTMLButtonElement;
	const searchForm = document.getElementById('search-form') as HTMLFormElement;
	const searchResult = document.getElementById('search-result') as HTMLElement;

	// ==================== CARGAR LISTA DE PACIENTES ====================
	async function loadPatients() {
		try {
			loadingEl.classList.remove('hidden');
			tableContainer.classList.add('hidden');
			emptyEl.classList.add('hidden');

			const response = await findAllPatients({ page: currentPage, rows: rowsPerPage });
			patients = response.data;
			totalPatients = response.total;

			if (patients.length === 0 && currentPage === 1) {
				// Sin pacientes
				loadingEl.classList.add('hidden');
				emptyEl.classList.remove('hidden');
			} else {
				// Renderizar tabla
				renderTable();
				updatePagination();
				loadingEl.classList.add('hidden');
				tableContainer.classList.remove('hidden');
				paginationEl.classList.remove('hidden');
			}
		} catch (error) {
			console.error('Error al cargar pacientes:', error);
			loadingEl.classList.add('hidden');
			emptyEl.classList.remove('hidden');
		}
	}

	function renderTable() {
		tbody.innerHTML = '';

		patients.forEach(patient => {
			const config = getStatusConfig(patient.currentStatus as PatientStatus);
			const location = patient.currentMedicalCenter?.name || patient.manualLocation || 'No especificado';
			const lastUpdated = new Date(patient.lastUpdatedAt || patient.createdAt || '').toLocaleDateString('es-VE', {
				year: 'numeric',
				month: 'short',
				day: 'numeric',
				hour: '2-digit',
				minute: '2-digit'
			});

			const tr = document.createElement('tr');
			tr.className = 'hover:bg-bg-light transition-colors';
			tr.innerHTML = `
				<td class="px-4 py-3 font-mono text-sm text-text-dark">${patient.dni}</td>
				<td class="px-4 py-3 font-display font-semibold text-sm text-text-dark">${patient.fullName}</td>
				<td class="px-4 py-3">
					<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold ${config.bgClass}">
						<span class="w-1.5 h-1.5 rounded-full ${config.badgeClass}"></span>
						${config.label}
					</span>
				</td>
				<td class="px-4 py-3 text-sm text-text-dark/80">${location}</td>
				<td class="px-4 py-3 text-xs text-text-dark/60">${lastUpdated}</td>
				<td class="px-4 py-3 text-right">
					<button 
						class="btn-edit-patient text-sm text-vzla-blue hover:underline font-display font-semibold"
						data-patient='${JSON.stringify(patient)}'
					>
						Actualizar
					</button>
				</td>
			`;
			tbody.appendChild(tr);
		});

		// Event listeners para editar
		document.querySelectorAll('.btn-edit-patient').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const data = (e.currentTarget as HTMLElement).getAttribute('data-patient');
				if (data) {
					const patient = JSON.parse(data) as IPatient;
					openModal(patient);
				}
			});
		});
	}

	function updatePagination() {
		const start = (currentPage - 1) * rowsPerPage + 1;
		const end = Math.min(currentPage * rowsPerPage, totalPatients);
		paginationInfo.textContent = `Mostrando ${start}-${end} de ${totalPatients}`;

		btnPrev.disabled = currentPage === 1;
		btnNext.disabled = currentPage * rowsPerPage >= totalPatients;
	}

	btnPrev.addEventListener('click', () => {
		if (currentPage > 1) {
			currentPage--;
			loadPatients();
		}
	});

	btnNext.addEventListener('click', () => {
		if (currentPage * rowsPerPage < totalPatients) {
			currentPage++;
			loadPatients();
		}
	});

	// ==================== BUSCAR PACIENTE GLOBAL ====================
	searchForm.addEventListener('submit', async (e) => {
		e.preventDefault();
		const dni = (document.getElementById('search-dni') as HTMLInputElement).value.trim();
		if (!dni) return;

		searchResult.innerHTML = '<p class="text-sm text-text-dark/60">Buscando...</p>';
		searchResult.classList.remove('hidden');

		try {
			const patient = await searchPatientByDniMedical(dni);
			if (patient) {
				const config = getStatusConfig(patient.currentStatus as PatientStatus);
				const location = patient.currentMedicalCenter?.name || patient.manualLocation || 'No especificado';
				
				searchResult.innerHTML = `
					<div class="bg-bg-light border border-border-subtle rounded-lg p-4 space-y-3">
						<div class="flex items-start justify-between gap-4">
							<div class="flex-1">
								<p class="font-display font-bold text-lg text-text-dark">${patient.fullName}</p>
								<p class="text-sm text-text-dark/60 font-mono">CI: ${patient.dni}</p>
							</div>
							<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold ${config.bgClass}">
								<span class="w-1.5 h-1.5 rounded-full ${config.badgeClass}"></span>
								${config.label}
							</span>
						</div>
						<p class="text-sm text-text-dark/80"><strong>Ubicación:</strong> ${location}</p>
						<button class="btn-update-found h-9 px-4 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-xs rounded-lg transition-all" data-patient='${JSON.stringify(patient)}'>
							Actualizar Este Paciente
						</button>
					</div>
				`;

				const btnUpdate = searchResult.querySelector('.btn-update-found') as HTMLElement;
				btnUpdate?.addEventListener('click', () => {
					const data = btnUpdate.getAttribute('data-patient');
					if (data) openModal(JSON.parse(data));
				});
			} else {
				searchResult.innerHTML = '<p class="text-sm text-error-text">No se encontró ningún paciente con esa cédula.</p>';
			}
		} catch (error: any) {
			searchResult.innerHTML = `<p class="text-sm text-error-text">${error.message || 'Error al buscar'}</p>`;
		}
	});

	// ==================== MODAL ====================
	function openModal(patient?: IPatient) {
		if (patient) {
			modalTitle.textContent = 'Actualizar Paciente';
			(document.getElementById('patient-dni') as HTMLInputElement).value = patient.dni;
			(document.getElementById('patient-dni') as HTMLInputElement).readOnly = true;
			(document.getElementById('patient-name') as HTMLInputElement).value = patient.fullName;
			(document.getElementById('patient-status') as HTMLSelectElement).value = patient.currentStatus;
			
			setCenterValue(
				patient.currentMedicalCenter?.id,
				patient.currentMedicalCenter?.name,
				patient.manualLocation,
			);
			setDniHint('Editando un paciente existente.', 'muted');
		} else {
			modalTitle.textContent = 'Registrar Nuevo Paciente';
			patientForm.reset();
			(document.getElementById('patient-dni') as HTMLInputElement).readOnly = false;
			(document.getElementById('selected-center-id') as HTMLInputElement).value = '';
			setCenterValue();
			setDniHint('Ingresa la cédula y pulsa "Buscar" para autocompletar los datos si ya existe.', 'muted');
		}

		// Asegurar que el botón de guardar siempre arranque en su estado por defecto
		const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;
		submitBtn.disabled = false;
		submitBtn.textContent = 'Guardar Paciente';
		(document.getElementById('form-error') as HTMLElement).classList.add('hidden');
		(document.getElementById('form-success') as HTMLElement).classList.add('hidden');

		modal.classList.remove('hidden');
	}


	function closeModal() {
		modal.classList.add('hidden');
		patientForm.reset();
		(document.getElementById('form-error') as HTMLElement).classList.add('hidden');
		(document.getElementById('form-success') as HTMLElement).classList.add('hidden');
	}

	btnNewPatient.addEventListener('click', () => openModal());
	modalClose.addEventListener('click', closeModal);
	modalCancel.addEventListener('click', closeModal);

	// ==================== CENTRO DE SALUD (combobox con búsqueda ILike o manual) ====================
	const centerSearch = document.getElementById('medical-center-search') as HTMLInputElement;
	const centerDropdown = document.getElementById('medical-center-dropdown') as HTMLUListElement;
	const centerCombobox = document.getElementById('medical-center-combobox') as HTMLElement;
	const centerSelected = document.getElementById('medical-center-selected') as HTMLElement;
	const centerSelectedName = document.getElementById('medical-center-selected-name') as HTMLElement;
	const centerClearBtn = document.getElementById('medical-center-clear') as HTMLButtonElement;
	const centerManual = document.getElementById('medical-center-manual') as HTMLInputElement;
	const selectedCenterId = document.getElementById('selected-center-id') as HTMLInputElement;
	const MANUAL_OPTION = '__manual__';

	let centerSearchTimeout: number;

	// Escapa texto para inyectarlo de forma segura en HTML/atributos
	function escapeHtml(value: string): string {
		return (value || '')
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;')
			.replace(/'/g, '&#39;');
	}

	// Renderiza el dropdown: "Escribir manualmente" como PRIMERA opción + resultados
	function renderCenterDropdown(centers: IMedicalCenter[]) {
		const manualItem = `
			<li>
				<button type="button" data-center-id="${MANUAL_OPTION}" class="center-option w-full text-left px-4 py-2.5 hover:bg-bg-light transition-colors font-display font-semibold text-vzla-blue border-b border-border-subtle">
					✏️ Escribir manualmente...
				</button>
			</li>
		`;

		const items = centers
			.map((c) => {
				const sub = [c.state, c.municipality].filter(Boolean).join(', ');
				return `
				<li>
					<button type="button" data-center-id="${c.id}" data-center-name="${escapeHtml(c.name)}" class="center-option w-full text-left px-4 py-2.5 hover:bg-bg-light transition-colors">
						<span class="block font-display font-semibold text-text-dark">${escapeHtml(c.name)}</span>
						${sub ? `<span class="block text-xs text-text-dark/50">${escapeHtml(sub)}</span>` : ''}
					</button>
				</li>
			`;
			})
			.join('');

		const emptyMsg =
			centers.length === 0
				? '<li class="px-4 py-2.5 text-text-dark/50">Sin coincidencias en el catálogo.</li>'
				: '';

		centerDropdown.innerHTML = manualItem + items + emptyMsg;
		centerDropdown.classList.remove('hidden');

		centerDropdown.querySelectorAll('.center-option').forEach((btn) => {
			btn.addEventListener('click', (e) => {
				const el = e.currentTarget as HTMLElement;
				const id = el.getAttribute('data-center-id');
				if (id === MANUAL_OPTION) {
					selectManualEntry();
				} else if (id) {
					selectCenter(parseInt(id), el.getAttribute('data-center-name') || '');
				}
			});
		});
	}

	// Busca centros (con término, o los últimos 10 si está vacío) y abre el dropdown
	async function fetchCenters(query: string) {
		try {
			const centers = await searchMedicalCenters(query);
			renderCenterDropdown(centers);
		} catch (error) {
			console.error('Error al buscar centros:', error);
			renderCenterDropdown([]);
		}
	}

	// Selecciona un centro del catálogo
	function selectCenter(id: number, name: string) {
		selectedCenterId.value = String(id);
		centerSelectedName.textContent = name || 'Centro seleccionado';
		centerSelected.classList.remove('hidden');
		centerSelected.classList.add('flex');
		centerDropdown.classList.add('hidden');
		centerSearch.classList.add('hidden');
		centerSearch.value = '';
		centerManual.classList.add('hidden');
		centerManual.value = '';
	}

	// Activa la escritura manual del centro/ubicación
	function selectManualEntry() {
		selectedCenterId.value = '';
		centerDropdown.classList.add('hidden');
		centerSearch.classList.add('hidden');
		centerSelected.classList.add('hidden');
		centerSelected.classList.remove('flex');
		centerManual.classList.remove('hidden');
		centerManual.value = centerSearch.value.trim();
		centerManual.focus();
	}

	// Resetea el combobox para volver a buscar/elegir
	function resetCenterPicker() {
		selectedCenterId.value = '';
		centerSelected.classList.add('hidden');
		centerSelected.classList.remove('flex');
		centerManual.classList.add('hidden');
		centerManual.value = '';
		centerSearch.classList.remove('hidden');
		centerSearch.value = '';
		centerDropdown.classList.add('hidden');
		centerDropdown.innerHTML = '';
	}

	// Búsqueda con debouncing (evita saturar el backend)
	centerSearch.addEventListener('input', () => {
		clearTimeout(centerSearchTimeout);
		const value = centerSearch.value.trim();
		centerSearchTimeout = window.setTimeout(() => {
			fetchCenters(value);
		}, 300);
	});

	// Al enfocar, mostrar de entrada los últimos 10 centros (o la búsqueda actual)
	centerSearch.addEventListener('focus', () => {
		fetchCenters(centerSearch.value.trim());
	});

	// Botón "Cambiar" del centro seleccionado
	centerClearBtn.addEventListener('click', () => {
		resetCenterPicker();
		centerSearch.focus();
		fetchCenters('');
	});

	// Cerrar el dropdown al hacer click fuera del combobox
	document.addEventListener('click', (e) => {
		if (centerCombobox && !centerCombobox.contains(e.target as Node)) {
			centerDropdown.classList.add('hidden');
		}
	});

	// Establecer el valor del centro al abrir el modal (catálogo o manual)
	function setCenterValue(centerId?: number, centerName?: string, manualLocation?: string) {
		if (centerId) {
			selectCenter(centerId, centerName || 'Centro seleccionado');
		} else if (manualLocation) {
			selectedCenterId.value = '';
			centerSelected.classList.add('hidden');
			centerSelected.classList.remove('flex');
			centerSearch.classList.add('hidden');
			centerDropdown.classList.add('hidden');
			centerManual.classList.remove('hidden');
			centerManual.value = manualLocation;
		} else {
			resetCenterPicker();
		}
	}

	// Construye la parte del DTO correspondiente al centro de salud
	function getCenterDto(): { medicalCenterId?: number; manualLocation?: string } {
		if (selectedCenterId.value) {
			return { medicalCenterId: parseInt(selectedCenterId.value) };
		}
		// Modo manual: el input manual está visible y con texto
		if (!centerManual.classList.contains('hidden') && centerManual.value.trim()) {
			return { manualLocation: centerManual.value.trim() };
		}
		return {};
	}


	// ==================== AUTOCOMPLETAR POR CÉDULA ====================
	const dniInput = document.getElementById('patient-dni') as HTMLInputElement;
	const btnLookupDni = document.getElementById('btn-lookup-dni') as HTMLButtonElement;
	const dniHint = document.getElementById('dni-lookup-hint') as HTMLElement;

	function setDniHint(message: string, type: 'muted' | 'success' | 'error') {
		if (!dniHint) return;
		dniHint.textContent = message;
		dniHint.className =
			'text-xs ' +
			(type === 'success'
				? 'text-success-text'
				: type === 'error'
					? 'text-error-text'
					: 'text-text-dark/50');
	}

	async function lookupDni() {
		const dni = dniInput.value.trim();
		if (!dni) {
			setDniHint('Ingresa una cédula para buscar.', 'error');
			return;
		}
		setDniHint('Buscando cédula...', 'muted');
		try {
			const patient = await searchPatientByDniMedical(dni);
			if (patient) {
				// Ya existe: autocompletar nombres y datos
				(document.getElementById('patient-name') as HTMLInputElement).value = patient.fullName;
				(document.getElementById('patient-status') as HTMLSelectElement).value = patient.currentStatus;
				setCenterValue(
					patient.currentMedicalCenter?.id,
					patient.currentMedicalCenter?.name,
					patient.manualLocation,
				);
				modalTitle.textContent = 'Actualizar Paciente';
				setDniHint('Paciente encontrado: datos autocompletados. Puedes actualizarlos.', 'success');
			} else {
				// No existe: el médico debe escribir el nombre manualmente
				setDniHint('Sin registro previo. Escribe el nombre completo manualmente.', 'muted');
				(document.getElementById('patient-name') as HTMLInputElement).focus();
			}
		} catch (error: any) {
			setDniHint(error?.message || 'No se pudo buscar la cédula.', 'error');
		}
	}

	btnLookupDni.addEventListener('click', lookupDni);
	dniInput.addEventListener('blur', () => {
		if (dniInput.value.trim() && !dniInput.readOnly) lookupDni();
	});

	// Submit del formulario

	patientForm.addEventListener('submit', async (e) => {
		e.preventDefault();

		const formError = document.getElementById('form-error') as HTMLElement;
		const formSuccess = document.getElementById('form-success') as HTMLElement;
		const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;

		formError.classList.add('hidden');
		formSuccess.classList.add('hidden');

		const dni = (document.getElementById('patient-dni') as HTMLInputElement).value.trim();
		const fullName = (document.getElementById('patient-name') as HTMLInputElement).value.trim();
		const status = (document.getElementById('patient-status') as HTMLSelectElement).value as PatientStatus;
		const dto: IUpsertPatientDto = {
			dni,
			fullName,
			status,
			...getCenterDto(),
		};


		try {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Guardando...';

			await upsertPatient(dto);

			formSuccess.textContent = 'Paciente guardado exitosamente';
			formSuccess.classList.remove('hidden');

			setTimeout(() => {
				// Restaurar el botón a su estado por defecto tras el guardado exitoso
				submitBtn.disabled = false;
				submitBtn.textContent = 'Guardar Paciente';
				closeModal();
				loadPatients(); // Recargar lista
				searchResult.classList.add('hidden'); // Ocultar resultado de búsqueda
			}, 1500);

		} catch (error: any) {
			formError.textContent = error.message || 'Error al guardar el paciente';
			formError.classList.remove('hidden');
			submitBtn.disabled = false;
			submitBtn.textContent = 'Guardar Paciente';
		}
	});

	// ==================== INICIALIZACIÓN ====================
	loadPatients();
</script>
