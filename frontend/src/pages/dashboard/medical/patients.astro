	function updatePagination() {
		const start = (currentPage - 1) * rowsPerPage + 1;
		const end = Math.min(currentPage * rowsPerPage, totalPatients);
		paginationInfo.textContent = `Mostrando ${start}-${end} de ${totalPatients}`;

		btnPrev.disabled = currentPage === 1;
		btnNext.disabled = currentPage * rowsPerPage >= totalPatients;
	}

	btnPrev.addEventListener('click', () => {
		if (currentPage > 1) {
			currentPage--;
			loadPatients();
		}
	});

	btnNext.addEventListener('click', () => {
		if (currentPage * rowsPerPage < totalPatients) {
			currentPage++;
			loadPatients();
		}
	});

	// ==================== BUSCAR PACIENTE GLOBAL ====================
	searchForm.addEventListener('submit', async (e) => {
		e.preventDefault();
		const dni = (document.getElementById('search-dni') as HTMLInputElement).value.trim();
		if (!dni) return;

		searchResult.innerHTML = '<p class="text-sm text-text-dark/60">Buscando...</p>';
		searchResult.classList.remove('hidden');

		try {
			const patient = await searchPatientByDniMedical(dni);
			if (patient) {
				const config = getStatusConfig(patient.currentStatus as PatientStatus);
				const location = patient.currentMedicalCenter?.name || patient.manualLocation || 'No especificado';
				
				searchResult.innerHTML = `
					<div class="bg-bg-light border border-border-subtle rounded-lg p-4 space-y-3">
						<div class="flex items-start justify-between gap-4">
							<div class="flex-1">
								<p class="font-display font-bold text-lg text-text-dark">${patient.fullName}</p>
								<p class="text-sm text-text-dark/60 font-mono">CI: ${patient.dni}</p>
							</div>
							<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold ${config.bgClass}">
								<span class="w-1.5 h-1.5 rounded-full ${config.badgeClass}"></span>
								${config.label}
							</span>
						</div>
						<p class="text-sm text-text-dark/80"><strong>Ubicación:</strong> ${location}</p>
						<button class="btn-update-found h-9 px-4 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-xs rounded-lg transition-all" data-patient="${encodePatientData(patient)}">
							Actualizar Este Paciente
						</button>
					</div>
				`;

				const btnUpdate = searchResult.querySelector('.btn-update-found') as HTMLElement;
				btnUpdate?.addEventListener('click', () => {
					const data = btnUpdate.getAttribute('data-patient');
					if (data) {
						const patientObj = decodePatientData(data);
						if (patientObj) openModal(patientObj);
					}
				});
			} else {
				searchResult.innerHTML = '<p class="text-sm text-error-text">No se encontró ningún paciente con esa cédula.</p>';
			}
		} catch (error: any) {
			searchResult.innerHTML = `<p class="text-sm text-error-text">${error.message || 'Error al buscar'}</p>`;
		}
	});

	// ==================== MODAL ====================
	function openModal(patient?: IPatient) {
		const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;
		const modalSpinner = document.getElementById('modal-spinner');
		const modalBtnText = document.getElementById('modal-btn-text');

		if (patient) {
			modalTitle.textContent = 'Actualizar Paciente';
			(document.getElementById('patient-dni') as HTMLInputElement).value = patient.dni;
			(document.getElementById('patient-dni') as HTMLInputElement).readOnly = true;
			(document.getElementById('patient-name') as HTMLInputElement).value = patient.fullName;
			(document.getElementById('patient-status') as HTMLSelectElement).value = patient.currentStatus;
			
			setCenterValue(
				patient.currentMedicalCenter?.id,
				patient.currentMedicalCenter?.name,
				patient.manualLocation,
			);
			setDniHint('Editando un paciente existente.', 'success');
			if (btnSubmitAnother) btnSubmitAnother.classList.add('hidden');
		} else {
			modalTitle.textContent = 'Registrar Nuevo Paciente';
			patientForm.reset();
			(document.getElementById('patient-dni') as HTMLInputElement).readOnly = false;
			
			// Cargar el último centro de salud utilizado si existe en localStorage
			const lastCenterId = localStorage.getItem('sire_last_center_id');
			const lastCenterName = localStorage.getItem('sire_last_center_name');
			const lastCenterManual = localStorage.getItem('sire_last_center_manual');

			if (lastCenterId) {
				setCenterValue(parseInt(lastCenterId), lastCenterName || 'Centro seleccionado');
			} else if (lastCenterManual) {
				setCenterValue(undefined, undefined, lastCenterManual);
			} else {
				setCenterValue();
			}

			setDniHint('Ingresa la cédula y pulsa "Buscar Datos" para autocompletar si ya existe.', 'muted');
			if (btnSubmitAnother) btnSubmitAnother.classList.remove('hidden');
		}

		// Asegurar que los botones de guardar siempre arranquen en su estado por defecto
		submitBtn.disabled = false;
		if (modalSpinner) modalSpinner.classList.add('hidden');
		if (modalBtnText) modalBtnText.textContent = 'Guardar Paciente';

		if (btnSubmitAnother) {
			btnSubmitAnother.disabled = false;
			if (modalSpinnerAnother) modalSpinnerAnother.classList.add('hidden');
			if (modalBtnTextAnother) modalBtnTextAnother.textContent = 'Guardar y Registrar Otro';
		}
		
		(document.getElementById('form-error') as HTMLElement).classList.add('hidden');
		(document.getElementById('form-success') as HTMLElement).classList.add('hidden');

		modal.classList.remove('hidden');
	}


	function closeModal() {
		modal.classList.add('hidden');
		patientForm.reset();
		(document.getElementById('form-error') as HTMLElement).classList.add('hidden');
		(document.getElementById('form-success') as HTMLElement).classList.add('hidden');
	}

	btnNewPatient.addEventListener('click', () => openModal());
	modalClose.addEventListener('click', closeModal);
	modalCancel.addEventListener('click', closeModal);

	// Controlar qué botón originó el submit
	const submitBtnElement = document.getElementById('modal-submit') as HTMLButtonElement;
	if (submitBtnElement) {
		submitBtnElement.addEventListener('click', () => {
			registerAnother = false;
		});
	}
	if (btnSubmitAnother) {
		btnSubmitAnother.addEventListener('click', () => {
			registerAnother = true;
		});
	}

	// Cerrar modal al pulsar Escape o hacer click fuera del contenedor
	window.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
			closeModal();
		}
	});

	modal.addEventListener('click', (e) => {
		if (e.target === modal) {
			closeModal();
		}
	});

	// ==================== CENTRO DE SALUD (combobox con búsqueda ILike o manual) ====================
	const centerSearch = document.getElementById('medical-center-search') as HTMLInputElement;
	const centerDropdown = document.getElementById('medical-center-dropdown') as HTMLUListElement;
	const centerCombobox = document.getElementById('medical-center-combobox') as HTMLElement;
	const centerSelected = document.getElementById('medical-center-selected') as HTMLElement;
	const centerSelectedName = document.getElementById('medical-center-selected-name') as HTMLElement;
	const centerClearBtn = document.getElementById('medical-center-clear') as HTMLButtonElement;
	const centerManual = document.getElementById('medical-center-manual') as HTMLInputElement;
	const selectedCenterId = document.getElementById('selected-center-id') as HTMLInputElement;
	const MANUAL_OPTION = '__manual__';

	let centerSearchTimeout: number;
	let optionButtons: HTMLButtonElement[] = [];
	let activeOptionIndex = -1;

	// Escapa texto para inyectarlo de forma segura en HTML/atributos
	function escapeHtml(value: string): string {
		return (value || '')
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;')
			.replace(/'/g, '&#39;');
	}

	function highlightOption(index: number) {
		// Quitar destaque anterior
		optionButtons.forEach(btn => {
			btn.classList.remove('bg-slate-150', 'bg-slate-100');
			btn.removeAttribute('aria-selected');
		});

		activeOptionIndex = index;
		if (activeOptionIndex >= 0 && activeOptionIndex < optionButtons.length) {
			const btn = optionButtons[activeOptionIndex];
			btn.classList.add('bg-slate-100');
			btn.setAttribute('aria-selected', 'true');
			btn.scrollIntoView({ block: 'nearest' });
			centerSearch.setAttribute('aria-activedescendant', btn.id);
		} else {
			centerSearch.removeAttribute('aria-activedescendant');
		}
	}

	// Renderiza el dropdown: "Escribir manualmente" como PRIMERA opción + resultados
	function renderCenterDropdown(centers: IMedicalCenter[]) {
		const manualItem = `
			<li>
				<button type="button" id="center-option-manual" role="option" data-center-id="${MANUAL_OPTION}" class="center-option w-full text-left px-4 py-3 hover:bg-slate-50 transition-colors font-bold text-vzla-blue border-b border-slate-100">
					✏️ Escribir manualmente...
				</button>
			</li>
		`;

		const items = centers
			.map((c, idx) => {
				const sub = [c.state, c.municipality].filter(Boolean).join(', ');
				return `
				<li>
					<button type="button" id="center-option-${idx}" role="option" data-center-id="${c.id}" data-center-name="${escapeHtml(c.name)}" class="center-option w-full text-left px-4 py-3 hover:bg-slate-50 transition-colors border-b border-slate-50 last:border-0">
						<span class="block font-bold text-slate-900">${escapeHtml(c.name)}</span>
						${sub ? `<span class="block text-xs font-medium text-slate-500 mt-0.5">${escapeHtml(sub)}</span>` : ''}
					</button>
				</li>
			`;
			})
			.join('');

		const emptyMsg =
			centers.length === 0
				? '<li class="px-4 py-3 text-slate-500 text-sm">Sin coincidencias en el catálogo.</li>'
				: '';

		centerDropdown.innerHTML = manualItem + items + emptyMsg;
		centerDropdown.classList.remove('hidden');
		centerSearch.setAttribute('aria-expanded', 'true');

		optionButtons = Array.from(centerDropdown.querySelectorAll('.center-option'));
		activeOptionIndex = -1;

		optionButtons.forEach((btn, index) => {
			btn.addEventListener('click', (e) => {
				const el = e.currentTarget as HTMLElement;
				const id = el.getAttribute('data-center-id');
				if (id === MANUAL_OPTION) {
					selectManualEntry();
				} else if (id) {
					selectCenter(parseInt(id), el.getAttribute('data-center-name') || '');
				}
			});

			btn.addEventListener('mouseenter', () => {
				highlightOption(index);
			});
		});
	}

	// Busca centros (con término, o los últimos 10 si está vacío) y abre el dropdown
	async function fetchCenters(query: string) {
		try {
			const centers = await searchMedicalCenters(query);
			renderCenterDropdown(centers);
		} catch (error) {
			console.error('Error al buscar centros:', error);
			renderCenterDropdown([]);
		}
	}

	// Selecciona un centro del catálogo
	function selectCenter(id: number, name: string) {
		selectedCenterId.value = String(id);
		centerSelectedName.textContent = name || 'Centro seleccionado';
		centerSelected.classList.remove('hidden');
		centerSelected.classList.add('flex');
		centerDropdown.classList.add('hidden');
		centerSearch.setAttribute('aria-expanded', 'false');
		centerSearch.removeAttribute('aria-activedescendant');
		centerSearch.classList.add('hidden');
		centerSearch.value = '';
		centerManual.classList.add('hidden');
		centerManual.value = '';
	}

	// Activa la escritura manual del centro/ubicación
	function selectManualEntry() {
		selectedCenterId.value = '';
		centerDropdown.classList.add('hidden');
		centerSearch.setAttribute('aria-expanded', 'false');
		centerSearch.removeAttribute('aria-activedescendant');
		centerSearch.classList.add('hidden');
		centerSelected.classList.add('hidden');
		centerSelected.classList.remove('flex');
		centerManual.classList.remove('hidden');
		centerManual.value = centerSearch.value.trim();
		centerManual.focus();
	}

	// Resetea el combobox para volver a buscar/elegir
	function resetCenterPicker() {
		selectedCenterId.value = '';
		centerSelected.classList.add('hidden');
		centerSelected.classList.remove('flex');
		centerManual.classList.add('hidden');
		centerManual.value = '';
		centerSearch.classList.remove('hidden');
		centerSearch.value = '';
		centerDropdown.classList.add('hidden');
		centerSearch.setAttribute('aria-expanded', 'false');
		centerSearch.removeAttribute('aria-activedescendant');
		centerDropdown.innerHTML = '';
	}

	// Soporte de navegación por teclado para el combobox
	centerSearch.addEventListener('keydown', (e) => {
		const isOpen = !centerDropdown.classList.contains('hidden');
		
		if (e.key === 'ArrowDown') {
			if (!isOpen) {
				e.preventDefault();
				fetchCenters(centerSearch.value.trim());
			} else if (optionButtons.length > 0) {
				e.preventDefault();
				let nextIndex = activeOptionIndex + 1;
				if (nextIndex >= optionButtons.length) nextIndex = 0; // Rotación circular
				highlightOption(nextIndex);
			}
		} else if (e.key === 'ArrowUp') {
			if (isOpen && optionButtons.length > 0) {
				e.preventDefault();
				let prevIndex = activeOptionIndex - 1;
				if (prevIndex < 0) prevIndex = optionButtons.length - 1; // Rotación circular
				highlightOption(prevIndex);
			}
		} else if (e.key === 'Enter') {
			if (isOpen && activeOptionIndex >= 0 && activeOptionIndex < optionButtons.length) {
				e.preventDefault();
				e.stopPropagation();
				optionButtons[activeOptionIndex].click();
			}
		} else if (e.key === 'Escape') {
			if (isOpen) {
				e.preventDefault();
				e.stopPropagation();
				centerDropdown.classList.add('hidden');
				centerSearch.setAttribute('aria-expanded', 'false');
				centerSearch.removeAttribute('aria-activedescendant');
			}
		}
	});

	// Búsqueda con debouncing (evita saturar el backend)
	centerSearch.addEventListener('input', () => {
		clearTimeout(centerSearchTimeout);
		const value = centerSearch.value.trim();
		centerSearchTimeout = window.setTimeout(() => {
			fetchCenters(value);
		}, 300);
	});

	// Al enfocar, mostrar de entrada los últimos 10 centros (o la búsqueda actual)
	centerSearch.addEventListener('focus', () => {
		fetchCenters(centerSearch.value.trim());
	});

	// Botón "Cambiar" del centro seleccionado
	centerClearBtn.addEventListener('click', () => {
		resetCenterPicker();
		centerSearch.focus();
		fetchCenters('');
	});

	// Si el usuario borra todo lo escrito en modo manual, regresa al buscador del catálogo
	centerManual.addEventListener('input', () => {
		if (centerManual.value.trim() === '') {
			resetCenterPicker();
			centerSearch.focus();
			fetchCenters('');
		}
	});

	// Cerrar el dropdown al hacer click fuera del combobox
	document.addEventListener('click', (e) => {
		if (centerCombobox && !centerCombobox.contains(e.target as Node)) {
			centerDropdown.classList.add('hidden');
			centerSearch.setAttribute('aria-expanded', 'false');
			centerSearch.removeAttribute('aria-activedescendant');
		}
	});

	// Establecer el valor del centro al abrir el modal (catálogo o manual)
	function setCenterValue(centerId?: number, centerName?: string, manualLocation?: string) {
		if (centerId) {
			selectCenter(centerId, centerName || 'Centro seleccionado');
		} else if (manualLocation) {
			selectedCenterId.value = '';
			centerSelected.classList.add('hidden');
			centerSelected.classList.remove('flex');
			centerSearch.classList.add('hidden');
			centerDropdown.classList.add('hidden');
			centerManual.classList.remove('hidden');
			centerManual.value = manualLocation;
		} else {
			resetCenterPicker();
		}
	}

	// Construye la parte del DTO correspondiente al centro de salud
	function getCenterDto(): { medicalCenterId?: number; manualLocation?: string } {
		if (selectedCenterId.value) {
			return { medicalCenterId: parseInt(selectedCenterId.value) };
		}
		// Modo manual: el input manual está visible y con texto
		if (!centerManual.classList.contains('hidden') && centerManual.value.trim()) {
			return { manualLocation: centerManual.value.trim() };
		}
		return {};
	}


	// ==================== AUTOCOMPLETAR POR CÉDULA ====================
	const dniInput = document.getElementById('patient-dni') as HTMLInputElement;
	const btnLookupDni = document.getElementById('btn-lookup-dni') as HTMLButtonElement;
	const dniHint = document.getElementById('dni-lookup-hint') as HTMLElement;

	function setDniHint(message: string, type: 'muted' | 'success' | 'error') {
		if (!dniHint) return;
		dniHint.textContent = message;
		dniHint.className =
			'text-xs ' +
			(type === 'success'
				? 'text-success-text'
				: type === 'error'
					? 'text-error-text'
					: 'text-text-dark/50');
	}

	async function lookupDni() {
		const dni = dniInput.value.trim();
		if (!dni) {
			setDniHint('Ingresa una cédula para buscar.', 'error');
			return;
		}
		setDniHint('Buscando cédula...', 'muted');
		try {
			const patient = await searchPatientByDniMedical(dni);
			if (patient) {
				// Ya existe: autocompletar nombres y datos
				(document.getElementById('patient-name') as HTMLInputElement).value = patient.fullName;
				(document.getElementById('patient-status') as HTMLSelectElement).value = patient.currentStatus;
				setCenterValue(
					patient.currentMedicalCenter?.id,
					patient.currentMedicalCenter?.name,
					patient.manualLocation,
				);
				modalTitle.textContent = 'Actualizar Paciente';
				setDniHint('Paciente encontrado: datos autocompletados. Puedes actualizarlos.', 'success');
			} else {
				// No existe: el médico debe escribir el nombre manualmente
				setDniHint('Sin registro previo. Escribe el nombre completo manualmente.', 'muted');
				(document.getElementById('patient-name') as HTMLInputElement).focus();
			}
		} catch (error: any) {
			setDniHint(error?.message || 'No se pudo buscar la cédula.', 'error');
		}
	}

	btnLookupDni.addEventListener('click', lookupDni);
	dniInput.addEventListener('blur', () => {
		if (dniInput.value.trim() && !dniInput.readOnly) lookupDni();
	});

	// Submit del formulario
	patientForm.addEventListener('submit', async (e) => {
		e.preventDefault();

		const formError = document.getElementById('form-error') as HTMLElement;
		const formErrorMsg = document.getElementById('form-error-msg') as HTMLElement;
		const formSuccess = document.getElementById('form-success') as HTMLElement;
		const formSuccessMsg = document.getElementById('form-success-msg') as HTMLElement;
		
		const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;
		const modalSpinner = document.getElementById('modal-spinner');
		const modalBtnText = document.getElementById('modal-btn-text');

		formError.classList.add('hidden');
		formSuccess.classList.add('hidden');

		const dni = (document.getElementById('patient-dni') as HTMLInputElement).value.trim();
		const fullName = (document.getElementById('patient-name') as HTMLInputElement).value.trim();
		const status = (document.getElementById('patient-status') as HTMLSelectElement).value as PatientStatus;
		
		const dto: IUpsertPatientDto = {
			dni,
			fullName,
			status,
		};

		const centerId = (document.getElementById('selected-center-id') as HTMLInputElement).value;
		const centerManual = (document.getElementById('medical-center-manual') as HTMLInputElement).value.trim();

		if (centerId && centerId !== MANUAL_OPTION) {
			dto.medicalCenterId = parseInt(centerId);
		} else if (centerManual) {
			dto.manualLocation = centerManual;
		}

		// Determinar qué botón usar para spinner/deshabilitar
		const activeSubmitBtn = registerAnother ? btnSubmitAnother : submitBtn;
		const activeSpinner = registerAnother ? modalSpinnerAnother : modalSpinner;
		const activeBtnText = registerAnother ? modalBtnTextAnother : modalBtnText;
		const originalText = registerAnother ? 'Guardar y Registrar Otro' : 'Guardar Paciente';

		try {
			if (submitBtn) submitBtn.disabled = true;
			if (btnSubmitAnother) btnSubmitAnother.disabled = true;
			if (activeSpinner) activeSpinner.classList.remove('hidden');
			if (activeBtnText) activeBtnText.textContent = 'Guardando...';

			await upsertPatient(dto);

			// Persistir el último centro utilizado en localStorage
			if (centerId && centerId !== MANUAL_OPTION) {
				const centerName = document.getElementById('medical-center-selected-name')?.textContent || '';
				localStorage.setItem('sire_last_center_id', centerId);
				localStorage.setItem('sire_last_center_name', centerName);
				localStorage.removeItem('sire_last_center_manual');
			} else if (centerManual) {
				localStorage.setItem('sire_last_center_manual', centerManual);
				localStorage.removeItem('sire_last_center_id');
				localStorage.removeItem('sire_last_center_name');
			}

			// Éxito
			formSuccessMsg.textContent = 'Paciente registrado exitosamente.';
			formSuccess.classList.remove('hidden');

			if (registerAnother) {
				// Cargar pacientes en background
				loadPatients();
				
				// Limpiar campos de paciente pero mantener el centro de salud
				const dniInput = document.getElementById('patient-dni') as HTMLInputElement;
				const nameInput = document.getElementById('patient-name') as HTMLInputElement;
				const statusSelect = document.getElementById('patient-status') as HTMLSelectElement;
				if (dniInput) {
					dniInput.value = '';
					dniInput.focus();
				}
				if (nameInput) nameInput.value = '';
				if (statusSelect) statusSelect.value = '';
				setDniHint('Ingresa la cédula y pulsa "Buscar Datos" para autocompletar si ya existe.', 'muted');
				
				// Ocultar mensaje de éxito después de 1.5s
				setTimeout(() => {
					formSuccess.classList.add('hidden');
				}, 1500);
			} else {
				// Cierre rápido
				setTimeout(() => {
					closeModal();
					loadPatients();
					searchResult.classList.add('hidden');
				}, 600);
			}

		} catch (error: any) {
			console.error('Error al guardar paciente:', error);
			formErrorMsg.textContent = error.message || 'Error al guardar el paciente';
			formError.classList.remove('hidden');
		} finally {
			if (submitBtn) submitBtn.disabled = false;
			if (btnSubmitAnother) btnSubmitAnother.disabled = false;
			if (activeSpinner) activeSpinner.classList.add('hidden');
			if (activeBtnText) activeBtnText.textContent = originalText;
		}
	});

	// ==================== FILTROS DE TRIAJE ====================
	const filterButtons = document.querySelectorAll('.triage-filter-btn');
	filterButtons.forEach(btn => {
		btn.addEventListener('click', (e) => {
			const el = e.currentTarget as HTMLButtonElement;
			const filterValue = el.getAttribute('data-filter');
			
			selectedStatusFilter = filterValue === 'ALL' ? null : filterValue;
			currentPage = 1; // Reiniciar paginación al cambiar de filtro
			
			// Actualizar estilos activos de los botones
			filterButtons.forEach(b => {
				const bf = b.getAttribute('data-filter');
				b.className = 'triage-filter-btn px-3 py-1.5 rounded-full font-bold transition-all cursor-pointer ';
				if (bf === filterValue) {
					// Botón Activo
					b.classList.add('bg-vzla-blue', 'text-white');
				} else {
					// Botón Inactivo
					b.classList.add('bg-bg-light', 'text-text-dark/70', 'hover:bg-slate-200');
				}
			});

			loadPatients();
		});
	});

	// Botón Reintentar carga
	const btnRetryPatients = document.getElementById('btn-retry-patients');
	if (btnRetryPatients) {
		btnRetryPatients.addEventListener('click', () => {
			loadPatients();
		});
	}

	// ==================== INICIALIZACIÓN ====================
	loadPatients();
</script>
