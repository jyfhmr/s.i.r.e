---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Gestión de Pacientes - S.I.R.E.">
	<div class="space-y-6">
		<!-- Header -->
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
			<div>
				<h2 class="font-display font-bold text-2xl md:text-3xl text-text-dark">Mis Pacientes</h2>
				<p class="text-sm text-text-dark/60 mt-1">Administra los pacientes que has registrado o actualizado</p>
			</div>
			<button 
				id="btn-new-patient"
				class="h-11 px-6 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-xl transition-all shadow-xs"
			>
				+ Registrar Paciente
			</button>
		</div>

		<!-- Buscador Global (por cédula) -->
		<div class="bg-white border border-border-subtle rounded-xl p-4 shadow-sm">
			<form id="search-form" class="flex gap-3">
				<div class="flex-1">
					<input 
						type="text"
						id="search-dni"
						placeholder="Buscar paciente por cédula (cualquier centro médico)..."
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
					/>
				</div>
				<button 
					type="submit"
					class="h-11 px-6 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg transition-all"
				>
					Buscar
				</button>
			</form>
			<div id="search-result" class="hidden mt-4"></div>
		</div>

		<!-- Tabla de Pacientes -->
		<div class="bg-white border border-border-subtle rounded-xl shadow-sm overflow-hidden">
			<div class="p-4 border-b border-border-subtle flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<h3 id="patients-list-title" class="font-display font-bold text-lg text-text-dark">Lista de Pacientes</h3>
				
				<!-- Filtro por Estado (Triage Chips) -->
				<div class="flex flex-wrap gap-2 text-xs" id="triage-filter-container">
					<button type="button" data-filter="ALL" class="triage-filter-btn px-3 py-1.5 rounded-full font-bold bg-vzla-blue text-white transition-all cursor-pointer">
						Todos
					</button>
					<button type="button" data-filter="ESTABLE" class="triage-filter-btn px-3 py-1.5 rounded-full font-bold bg-bg-light text-text-dark/70 hover:bg-slate-200 transition-all cursor-pointer">
						Estable
					</button>
					<button type="button" data-filter="CRÍTICO" class="triage-filter-btn px-3 py-1.5 rounded-full font-bold bg-bg-light text-text-dark/70 hover:bg-slate-200 transition-all cursor-pointer">
						Crítico
					</button>
					<button type="button" data-filter="CONTACTAR_INMEDIATO" class="triage-filter-btn px-3 py-1.5 rounded-full font-bold bg-bg-light text-text-dark/70 hover:bg-slate-200 transition-all cursor-pointer">
						Contactar
					</button>
					<button type="button" data-filter="DESAPARECIDO" class="triage-filter-btn px-3 py-1.5 rounded-full font-bold bg-bg-light text-text-dark/70 hover:bg-slate-200 transition-all cursor-pointer">
						Desaparecido
					</button>
				</div>
			</div>

			<!-- Loading -->
			<div id="patients-loading" class="p-8 text-center">
				<div class="animate-spin h-8 w-8 border-2 border-vzla-blue border-t-transparent rounded-full mx-auto"></div>
				<p class="text-sm text-text-dark/60 mt-3">Cargando pacientes...</p>
			</div>

			<!-- Tabla / Tarjetas Container -->
			<div id="patients-table-container" class="hidden">
				<!-- Tabla (Desktop) -->
				<div class="hidden md:block overflow-x-auto">
					<table class="w-full">
						<thead class="bg-bg-light border-b border-border-subtle">
							<tr class="text-left text-xs font-display font-bold text-text-dark/70 uppercase tracking-wider">
								<th class="px-4 py-3">Cédula</th>
								<th class="px-4 py-3">Nombre Completo</th>
								<th class="px-4 py-3">Estado</th>
								<th class="px-4 py-3">Centro / Ubicación</th>
								<th class="px-4 py-3">Última Act.</th>
								<th class="px-4 py-3 text-right">Acciones</th>
							</tr>
						</thead>
						<tbody id="patients-tbody" class="divide-y divide-border-subtle"></tbody>
					</table>
				</div>

				<!-- Vista Tarjetas / Widgets (Móvil) -->
				<div id="patients-cards-container" class="md:hidden p-4 space-y-4"></div>
			</div>

			<!-- Empty State -->
			<div id="patients-empty" class="hidden p-12 text-center space-y-3">
				<div class="w-16 h-16 mx-auto rounded-full bg-bg-light flex items-center justify-center text-text-dark/40">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
						<circle cx="9" cy="7" r="4"></circle>
						<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
						<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
					</svg>
				</div>
				<p class="font-display font-semibold text-text-dark">No has registrado pacientes aún</p>
				<p class="text-sm text-text-dark/60">Haz clic en "Registrar Paciente" para comenzar</p>
			</div>

			<!-- Error State -->
			<div id="patients-error" class="hidden p-12 text-center space-y-4">
				<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-error-light text-error-text border border-error-border">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"></circle>
						<line x1="12" y1="8" x2="12" y2="12"></line>
						<line x1="12" y1="16" x2="12.01" y2="16"></line>
					</svg>
				</div>
				<p class="font-display font-semibold text-text-dark">Error al cargar pacientes</p>
				<p class="text-sm text-text-dark/60 max-w-md mx-auto">No pudimos conectar con el servidor. Por favor verifica tu conexión a internet.</p>
				<button 
					type="button" 
					id="btn-retry-patients" 
					class="h-10 px-6 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-xl transition-all cursor-pointer inline-flex items-center gap-2"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path>
					</svg>
					Reintentar
				</button>
			</div>

			<!-- Paginación -->
			<div id="patients-pagination" class="hidden border-t border-border-subtle p-4 flex items-center justify-between">
				<span id="pagination-info" class="text-sm text-text-dark/60"></span>
				<div class="flex gap-2">
					<button id="btn-prev" class="h-9 px-4 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
						Anterior
					</button>
					<button id="btn-next" class="h-9 px-4 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
						Siguiente
					</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Modal Upsert Paciente -->
	<div id="patient-modal" class="hidden fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 transition-all">
		<div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl max-h-[90vh] flex flex-col overflow-hidden animate-in fade-in zoom-in-95 duration-200">
			<div class="bg-white border-b border-slate-100 p-5 sm:p-6 flex items-center justify-between z-10 shrink-0">
				<h3 id="modal-title" class="font-display font-bold text-xl text-slate-900">Registrar Nuevo Paciente</h3>
				<button type="button" id="modal-close" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-100 text-slate-500 transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
			</div>

			<form id="patient-form" class="flex flex-col flex-1 overflow-hidden">
				<div class="p-5 sm:p-8 space-y-6 overflow-y-auto flex-1">
					<!-- Cédula -->
				<div class="space-y-2">
					<label for="patient-dni" class="block text-sm font-semibold text-slate-900">
						Cédula de Identidad <span class="text-red-500" aria-hidden="true">*</span>
					</label>
					<div class="flex flex-col sm:flex-row gap-3">
						<input 
							type="text"
							inputmode="numeric"
							id="patient-dni"
							required
							class="w-full sm:flex-1 h-14 px-4 bg-white border-2 border-slate-200 hover:border-slate-300 rounded-xl text-base text-slate-900 placeholder:text-slate-400 focus:border-vzla-blue focus:ring-4 focus:ring-vzla-blue/15 outline-none transition-all shrink-0"
							placeholder="Ej: 12345678"
						/>
						<button 
							type="button"
							id="btn-lookup-dni"
							class="w-full sm:w-auto h-14 px-6 bg-slate-100 hover:bg-slate-200 text-slate-700 border-2 border-transparent rounded-xl font-semibold text-sm transition-all whitespace-nowrap flex items-center justify-center gap-2 focus:border-slate-300 focus:ring-4 focus:ring-slate-200 outline-none shrink-0"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
							Buscar Datos
						</button>
					</div>
					<p id="dni-lookup-hint" class="text-xs font-medium text-slate-500 pt-1">Pulsa "Buscar Datos" para autocompletar si ya existe.</p>
				</div>

				<!-- Nombre Completo -->
				<div class="space-y-2">
					<label for="patient-name" class="block text-sm font-semibold text-slate-900">
						Nombre Completo <span class="text-red-500" aria-hidden="true">*</span>
					</label>
					<input 
						type="text"
						id="patient-name"
						required
						class="w-full h-14 px-4 bg-white border-2 border-slate-200 hover:border-slate-300 rounded-xl text-base text-slate-900 placeholder:text-slate-400 focus:border-vzla-blue focus:ring-4 focus:ring-vzla-blue/15 outline-none transition-all shrink-0"
						placeholder="Ej: Juan Alberto Pérez"
					/>
				</div>

				<!-- Estado -->
				<div class="space-y-2">
					<label for="patient-status" class="block text-sm font-semibold text-slate-900">
						Estado del Paciente <span class="text-red-500" aria-hidden="true">*</span>
					</label>
					<div class="relative">
						<select 
							id="patient-status"
							required
							class="w-full h-14 px-4 pr-10 bg-white border-2 border-slate-200 hover:border-slate-300 rounded-xl text-base text-slate-900 focus:border-vzla-blue focus:ring-4 focus:ring-vzla-blue/15 outline-none transition-all appearance-none cursor-pointer shrink-0"
						>
							<option value="">Seleccionar estado...</option>
							<option value="ESTABLE">Estable</option>
							<option value="CRÍTICO">Crítico</option>
							<option value="CONTACTAR_INMEDIATO">Contactar Inmediato</option>
							<option value="DESAPARECIDO">Desaparecido</option>
						</select>
						<div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-500">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
						</div>
					</div>
				</div>

				<!-- Centro de Salud -->
				<div class="space-y-2">
					<label for="medical-center-search" class="block text-sm font-semibold text-slate-900">
						Centro de Salud / Ubicación
					</label>

					<!-- Combobox -->
					<div id="medical-center-combobox" class="relative">
						<input 
							type="text"
							id="medical-center-search"
							autocomplete="off"
							role="combobox"
							aria-autocomplete="list"
							aria-expanded="false"
							aria-controls="medical-center-dropdown"
							class="w-full h-14 px-4 bg-white border-2 border-slate-200 hover:border-slate-300 rounded-xl text-base text-slate-900 placeholder:text-slate-400 focus:border-vzla-blue focus:ring-4 focus:ring-vzla-blue/15 outline-none transition-all shrink-0"
							placeholder="Buscar catálogo o escribir centro..."
						/>
						<ul 
							id="medical-center-dropdown"
							role="listbox"
							aria-label="Centros de salud sugeridos"
							class="hidden absolute z-20 mt-2 w-full max-h-60 overflow-y-auto bg-white border-2 border-slate-100 rounded-xl shadow-lg shadow-slate-200/50 text-sm"
						></ul>
					</div>

					<!-- Centro seleccionado -->
					<div id="medical-center-selected" class="hidden items-center justify-between gap-3 bg-slate-50 border-2 border-slate-200 rounded-xl px-4 py-3 shrink-0">
						<span id="medical-center-selected-name" class="text-sm font-semibold text-slate-900"></span>
						<button type="button" id="medical-center-clear" class="text-sm text-slate-500 hover:text-slate-800 font-semibold whitespace-nowrap bg-white border border-slate-200 rounded-lg px-3 py-1.5 transition-colors focus:ring-2 focus:ring-slate-200 outline-none">
							Cambiar
						</button>
					</div>

					<!-- Input manual -->
					<input 
						type="text"
						id="medical-center-manual"
						autocomplete="off"
						class="hidden w-full h-14 px-4 bg-white border-2 border-slate-200 hover:border-slate-300 rounded-xl text-base text-slate-900 placeholder:text-slate-400 focus:border-vzla-blue focus:ring-4 focus:ring-vzla-blue/15 outline-none transition-all shrink-0"
						placeholder="Escribe el nombre o ubicación exacta..."
					/>
				</div>

				<input type="hidden" id="selected-center-id" value="" />

				<!-- Mensajes -->
				<div id="form-error" class="hidden bg-red-50 border-2 border-red-200 text-red-700 font-semibold text-sm rounded-xl p-4 flex gap-2 items-start shrink-0" role="alert">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
					<span id="form-error-msg"></span>
				</div>
				<div id="form-success" class="hidden bg-green-50 border-2 border-green-200 text-green-700 font-semibold text-sm rounded-xl p-4 flex gap-2 items-start shrink-0" role="alert">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
					<span id="form-success-msg"></span>
				</div>

				</div>

				<!-- Botones (Sticky / Fixed at bottom of modal) -->
				<div class="p-4 sm:p-6 border-t border-slate-100 bg-slate-50 flex flex-col-reverse sm:flex-row gap-3 shrink-0">
					<button 
						type="button"
						id="modal-cancel"
						class="w-full sm:flex-1 h-14 bg-white border-2 border-slate-200 hover:border-slate-300 hover:bg-slate-50 text-slate-700 rounded-xl text-base font-semibold transition-all focus:border-slate-400 focus:ring-4 focus:ring-slate-100 outline-none shrink-0 cursor-pointer"
					>
						Cancelar
					</button>
					<button 
						type="submit"
						id="modal-submit-another"
						class="w-full sm:flex-[1.5] h-14 bg-white hover:bg-slate-50 text-vzla-blue border-2 border-vzla-blue hover:border-vzla-blue-hover rounded-xl text-base font-semibold transition-all flex items-center justify-center gap-2 focus:ring-4 focus:ring-vzla-blue/20 outline-none shrink-0 cursor-pointer"
					>
						<svg id="modal-spinner-another" class="animate-spin h-5 w-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
						</svg>
						<span id="modal-btn-text-another">Guardar y Registrar Otro</span>
					</button>
					<button 
						type="submit"
						id="modal-submit"
						class="w-full sm:flex-[1.5] h-14 bg-vzla-blue hover:bg-vzla-blue-hover text-white rounded-xl text-base font-semibold transition-all flex items-center justify-center gap-2 focus:ring-4 focus:ring-vzla-blue/30 outline-none shrink-0 cursor-pointer"
					>
						<svg id="modal-spinner" class="animate-spin h-5 w-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
						</svg>
						<span id="modal-btn-text">Guardar Paciente</span>
					</button>
				</div>
			</form>
		</div>
	</div>
</DashboardLayout>

<script>
	import { findAllPatients, searchPatientByDniMedical, upsertPatient, searchMedicalCenters } from '../../../lib/api';


	import { getStatusConfig } from '../../../lib/patient-status';
	import type { IPatient, IUpsertPatientDto } from '@shared/core/medical/patients/interfaces';
	import type { PatientStatus } from '@shared/common';
	import type { IMedicalCenter } from '@shared/core/config/medical-centers/interfaces';

	// Safe Base64 encoding/decoding helper functions to prevent quotes/special chars breaking HTML attributes (XSS-safe)
	function encodePatientData(patient: IPatient): string {
		try {
			return btoa(encodeURIComponent(JSON.stringify(patient)));
		} catch (e) {
			console.error('Error encoding patient data:', e);
			return '';
		}
	}

	function decodePatientData(data: string): IPatient | null {
		try {
			return JSON.parse(decodeURIComponent(atob(data)));
		} catch (e) {
			console.error('Error decoding patient data:', e);
		}
	}
	// ==================== STATE ====================
	let currentPage = 1;
	const rowsPerPage = 15;
	let totalPatients = 0;
	let patients: IPatient[] = [];
	let searchTimeout: number;
	let registerAnother = false;
	let selectedStatusFilter: string | null = null;

	// ==================== ELEMENTOS ====================
	const listTitleEl = document.getElementById('patients-list-title') as HTMLElement;
	const loadingEl = document.getElementById('patients-loading') as HTMLElement;
	const tableContainer = document.getElementById('patients-table-container') as HTMLElement;
	const emptyEl = document.getElementById('patients-empty') as HTMLElement;
	const tbody = document.getElementById('patients-tbody') as HTMLTableSectionElement;
	const cardsContainer = document.getElementById('patients-cards-container') as HTMLElement;
	const paginationEl = document.getElementById('patients-pagination') as HTMLElement;
	const paginationInfo = document.getElementById('pagination-info') as HTMLElement;
	const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
	const btnNext = document.getElementById('btn-next') as HTMLButtonElement;

	const modal = document.getElementById('patient-modal') as HTMLElement;
	const modalTitle = document.getElementById('modal-title') as HTMLElement;
	const modalClose = document.getElementById('modal-close') as HTMLElement;
	const modalCancel = document.getElementById('modal-cancel') as HTMLElement;
	const patientForm = document.getElementById('patient-form') as HTMLFormElement;

	const btnSubmitAnother = document.getElementById('modal-submit-another') as HTMLButtonElement;
	const modalSpinnerAnother = document.getElementById('modal-spinner-another');
	const modalBtnTextAnother = document.getElementById('modal-btn-text-another');

	const btnNewPatient = document.getElementById('btn-new-patient') as HTMLButtonElement;
	const searchForm = document.getElementById('search-form') as HTMLFormElement;
	const searchResult = document.getElementById('search-result') as HTMLElement;

	// ==================== CARGAR LISTA DE PACIENTES ====================
	async function loadPatients() {
		try {
			loadingEl.classList.remove('hidden');
			tableContainer.classList.add('hidden');
			emptyEl.classList.add('hidden');
			paginationEl.classList.add('hidden');
			
			const errorEl = document.getElementById('patients-error') as HTMLElement;
			if (errorEl) errorEl.classList.add('hidden');

			const queryParams: any = { page: currentPage, rows: rowsPerPage };
			if (selectedStatusFilter) {
				queryParams.status = selectedStatusFilter;
			}

			const response = await findAllPatients(queryParams);
			patients = response.data;
			totalPatients = response.total;

			if (listTitleEl) {
				listTitleEl.textContent = selectedStatusFilter 
					? `Lista de Pacientes (${totalPatients} filtrados)` 
					: `Lista de Pacientes (${totalPatients})`;
			}

			if (patients.length === 0 && currentPage === 1) {
				// Sin pacientes
				loadingEl.classList.add('hidden');
				
				// Personalizar el Empty State según si hay filtro activo
				const emptyTitle = emptyEl.querySelector('p.font-display') as HTMLElement;
				const emptySub = emptyEl.querySelector('p.text-sm') as HTMLElement;
				if (emptyTitle && emptySub) {
					if (selectedStatusFilter) {
						emptyTitle.textContent = 'No hay pacientes con este estado';
						emptySub.textContent = 'No tienes pacientes registrados con el estado de triaje seleccionado.';
					} else {
						emptyTitle.textContent = 'No has registrado pacientes aún';
						emptySub.textContent = 'Haz clic en "Registrar Paciente" para comenzar';
					}
				}
				
				emptyEl.classList.remove('hidden');
			} else {
				// Renderizar tabla
				renderTable();
				updatePagination();
				loadingEl.classList.add('hidden');
				tableContainer.classList.remove('hidden');
				paginationEl.classList.remove('hidden');
			}
		} catch (error) {
			console.error('Error al cargar pacientes:', error);
			loadingEl.classList.add('hidden');
			tableContainer.classList.add('hidden');
			emptyEl.classList.add('hidden');
			paginationEl.classList.add('hidden');
			
			const errorEl = document.getElementById('patients-error') as HTMLElement;
			if (errorEl) errorEl.classList.remove('hidden');
		}
	}

	function renderTable() {
		tbody.innerHTML = '';
		cardsContainer.innerHTML = '';

		patients.forEach(patient => {
			const config = getStatusConfig(patient.currentStatus as PatientStatus);
			const location = patient.currentMedicalCenter?.name || patient.manualLocation || 'No especificado';
			const lastUpdated = new Date(patient.lastUpdatedAt || patient.createdAt || '').toLocaleDateString('es-VE', {
				year: 'numeric',
				month: 'short',
				day: 'numeric',
				hour: '2-digit',
				minute: '2-digit'
			});

			// 1. Desktop: Fila de tabla
			const tr = document.createElement('tr');
			tr.className = 'hover:bg-bg-light transition-colors';
			tr.innerHTML = `
				<td class="px-4 py-3 font-mono text-sm text-text-dark">${patient.dni}</td>
				<td class="px-4 py-3 font-display font-semibold text-sm text-text-dark">${patient.fullName}</td>
				<td class="px-4 py-3">
					<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold ${config.bgClass}">
						<span class="w-1.5 h-1.5 rounded-full ${config.badgeClass}"></span>
						${config.label}
					</span>
				</td>
				<td class="px-4 py-3 text-sm text-text-dark/80">${location}</td>
				<td class="px-4 py-3 text-xs text-text-dark/60">${lastUpdated}</td>
				<td class="px-4 py-3 text-right">
					<button 
						class="btn-edit-patient text-sm text-vzla-blue hover:underline font-display font-semibold"
						data-patient="${encodePatientData(patient)}"
					>
						Actualizar
					</button>
				</td>
			`;
			tbody.appendChild(tr);

			// 2. Móvil: Tarjeta / Widget
			const card = document.createElement('div');
			let borderLClass = 'border-l-4 border-l-slate-300';
			if (patient.currentStatus === 'ESTABLE') borderLClass = 'border-l-4 border-l-emerald-500';
			else if (patient.currentStatus === 'CRÍTICO' || patient.currentStatus === 'CRITICO') borderLClass = 'border-l-4 border-l-rose-500';
			else if (patient.currentStatus === 'CONTACTAR_INMEDIATO') borderLClass = 'border-l-4 border-l-amber-500';
			else if (patient.currentStatus === 'DESAPARECIDO') borderLClass = 'border-l-4 border-l-sky-500';

			card.className = `bg-white border border-border-subtle rounded-xl p-4 space-y-3 shadow-sm hover:border-slate-300 transition-colors ${borderLClass}`;
			card.innerHTML = `
				<div class="space-y-2">
					<div class="flex justify-between items-center gap-2">
						<h4 class="font-display font-bold text-base text-text-dark leading-tight">${patient.fullName}</h4>
						<span class="text-xs text-text-dark/50 font-mono shrink-0">C.I. ${patient.dni}</span>
					</div>
					<div class="flex">
						<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold ${config.bgClass}">
							<span class="w-1.5 h-1.5 rounded-full ${config.badgeClass}"></span>
							${config.label}
						</span>
					</div>
				</div>
				<div class="text-xs text-text-dark/80 space-y-1.5 pt-1">
					<p><span class="font-semibold text-text-dark/60">Ubicación:</span> ${location}</p>
					<p><span class="font-semibold text-text-dark/60">Última act.:</span> ${lastUpdated}</p>
				</div>
				<div class="pt-3 border-t border-slate-100 flex justify-end">
					<button 
						class="btn-edit-patient text-sm text-vzla-blue hover:underline font-display font-semibold flex items-center gap-1"
						data-patient="${encodePatientData(patient)}"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"></path></svg>
						Actualizar Paciente
					</button>
				</div>
			`;
			cardsContainer.appendChild(card);
		});

		// Event listeners (para ambos layouts)
		document.querySelectorAll('.btn-edit-patient').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const data = (e.currentTarget as HTMLElement).getAttribute('data-patient');
				if (data) {
					const patient = decodePatientData(data);
					if (patient) openModal(patient);
				}
			});
