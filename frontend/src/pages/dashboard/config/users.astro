---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Gestión de Usuarios - S.I.R.E.">
	<div class="space-y-6">
		<!-- Header -->
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
			<div>
				<h2 class="font-display font-bold text-2xl md:text-3xl text-text-dark">Usuarios del Sistema</h2>
				<p class="text-sm text-text-dark/60 mt-1">Administra cuentas de usuarios y permisos</p>
			</div>
			<button 
				id="btn-new-user"
				class="h-11 px-6 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-xl transition-all shadow-xs"
			>
				+ Nuevo Usuario
			</button>
		</div>

		<!-- Tabla de usuarios -->
		<div class="bg-white border border-border-subtle rounded-xl shadow-sm overflow-hidden">
			<div class="p-4 border-b border-border-subtle">
				<h3 class="font-display font-bold text-lg text-text-dark">Lista de Usuarios</h3>
			</div>

			<!-- Loading -->
			<div id="users-loading" class="p-8 text-center">
				<div class="animate-spin h-8 w-8 border-2 border-vzla-blue border-t-transparent rounded-full mx-auto"></div>
				<p class="text-sm text-text-dark/60 mt-3">Cargando usuarios...</p>
			</div>

			<!-- Tabla -->
			<div id="users-table-container" class="hidden overflow-x-auto">
				<table class="w-full">
					<thead class="bg-bg-light border-b border-border-subtle">
						<tr class="text-left text-xs font-display font-bold text-text-dark/70 uppercase tracking-wider">
							<th class="px-4 py-3">Nombre</th>
							<th class="px-4 py-3">Email</th>
							<th class="px-4 py-3">Cédula</th>
							<th class="px-4 py-3">Estado</th>
							<th class="px-4 py-3">Fecha Creación</th>
							<th class="px-4 py-3 text-right">Acciones</th>
						</tr>
					</thead>
					<tbody id="users-tbody" class="divide-y divide-border-subtle"></tbody>
				</table>
			</div>

			<!-- Paginación -->
			<div id="users-pagination" class="hidden border-t border-border-subtle p-4 flex items-center justify-between">
				<span id="pagination-info" class="text-sm text-text-dark/60"></span>
				<div class="flex gap-2">
					<button id="btn-prev" class="h-9 px-4 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
						Anterior
					</button>
					<button id="btn-next" class="h-9 px-4 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
						Siguiente
					</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Modal Crear Usuario -->
	<div id="user-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
			<div class="sticky top-0 bg-white border-b border-border-subtle p-6 flex items-center justify-between">
				<h3 id="modal-title" class="font-display font-bold text-xl text-text-dark">Nuevo Usuario</h3>
				<button id="modal-close" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-bg-light transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
			</div>

			<form id="user-form" class="p-6 space-y-5">
				<div class="bg-info-light border border-info-border rounded-lg p-3 text-xs text-info-text">
					<strong>Nota:</strong> Solo puedes crear usuarios tipo DIOS. Los médicos se crean a través de solicitudes de acceso.
				</div>

				<div class="space-y-2">
					<label for="user-name" class="block text-sm font-display font-bold text-text-dark">
						Nombre de Usuario <span class="text-error-text">*</span>
					</label>
					<input 
						type="text"
						id="user-name"
						required
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
						placeholder="usuario.admin"
					/>
				</div>

				<div class="space-y-2">
					<label for="user-fullname" class="block text-sm font-display font-bold text-text-dark">
						Nombre Completo <span class="text-error-text">*</span>
					</label>
					<input 
						type="text"
						id="user-fullname"
						required
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
						placeholder="Juan Pérez"
					/>
				</div>

				<div class="space-y-2">
					<label for="user-email" class="block text-sm font-display font-bold text-text-dark">
						Email <span class="text-error-text">*</span>
					</label>
					<input 
						type="email"
						id="user-email"
						required
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
						placeholder="admin@sire.ve"
					/>
				</div>

				<div class="space-y-2">
					<label for="user-dni" class="block text-sm font-display font-bold text-text-dark">
						Cédula <span class="text-error-text">*</span>
					</label>
					<input 
						type="text"
						id="user-dni"
						required
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
						placeholder="12345678"
					/>
				</div>

				<div class="space-y-2">
					<label for="user-password" class="block text-sm font-display font-bold text-text-dark">
						Contraseña <span class="text-error-text">*</span>
					</label>
					<input 
						type="password"
						id="user-password"
						required
						minlength="6"
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
						placeholder="Mínimo 6 caracteres"
					/>
				</div>

				<input type="hidden" id="user-profile" value="1" />

				<div id="form-error" class="hidden bg-error-light border border-error-border text-error-text text-sm rounded-lg p-3"></div>
				<div id="form-success" class="hidden bg-success-light border border-success-border text-success-text text-sm rounded-lg p-3"></div>

				<div class="flex gap-3 pt-2">
					<button 
						type="button"
						id="modal-cancel"
						class="flex-1 h-11 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors"
					>
						Cancelar
					</button>
					<button 
						type="submit"
						id="modal-submit"
						class="flex-1 h-11 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg transition-all"
					>
						Crear Usuario
					</button>
				</div>
			</form>
		</div>
	</div>
</DashboardLayout>

<script>
	import { findAllUsers, createUser, changeUserStatus } from '../../../lib/api';
	import type { IUser, ICreateUserDto } from '@shared/core/config/user/interfaces';

	// ==================== STATE ====================
	let currentPage = 1;
	const rowsPerPage = 10;
	let totalUsers = 0;
	let users: IUser[] = [];

	// ==================== ELEMENTOS ====================
	const loadingEl = document.getElementById('users-loading') as HTMLElement;
	const tableContainer = document.getElementById('users-table-container') as HTMLElement;
	const tbody = document.getElementById('users-tbody') as HTMLTableSectionElement;
	const paginationEl = document.getElementById('users-pagination') as HTMLElement;
	const paginationInfo = document.getElementById('pagination-info') as HTMLElement;
	const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
	const btnNext = document.getElementById('btn-next') as HTMLButtonElement;

	const modal = document.getElementById('user-modal') as HTMLElement;
	const modalClose = document.getElementById('modal-close') as HTMLElement;
	const modalCancel = document.getElementById('modal-cancel') as HTMLElement;
	const userForm = document.getElementById('user-form') as HTMLFormElement;
	const btnNewUser = document.getElementById('btn-new-user') as HTMLButtonElement;

	// ==================== CARGAR USUARIOS ====================
	async function loadUsers() {
		try {
			loadingEl.classList.remove('hidden');
			tableContainer.classList.add('hidden');

			const response = await findAllUsers({ page: currentPage, rows: rowsPerPage });
			users = response.data;
			totalUsers = response.total;

			renderTable();
			updatePagination();
			loadingEl.classList.add('hidden');
			tableContainer.classList.remove('hidden');
			paginationEl.classList.remove('hidden');
		} catch (error) {
			console.error('Error al cargar usuarios:', error);
			loadingEl.classList.add('hidden');
		}
	}

	function renderTable() {
		tbody.innerHTML = '';

		users.forEach(user => {
			const createdDate = new Date(user.createdAt || '').toLocaleDateString('es-VE', {
				year: 'numeric',
				month: 'short',
				day: 'numeric'
			});

			const tr = document.createElement('tr');
			tr.className = 'hover:bg-bg-light transition-colors';
			tr.innerHTML = `
				<td class="px-4 py-3 font-display font-semibold text-sm text-text-dark">${user.fullName}</td>
				<td class="px-4 py-3 text-sm text-text-dark/80">${user.email}</td>
				<td class="px-4 py-3 text-sm font-mono text-text-dark/80">${user.dni}</td>
				<td class="px-4 py-3">
					<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold ${user.isActive ? 'bg-success-light text-success-text' : 'bg-error-light text-error-text'}">
						${user.isActive ? 'Activo' : 'Inactivo'}
					</span>
				</td>
				<td class="px-4 py-3 text-xs text-text-dark/60">${createdDate}</td>
				<td class="px-4 py-3 text-right">
					<button class="btn-toggle-status text-sm ${user.isActive ? 'text-error-text' : 'text-success-text'} hover:underline font-display font-semibold" data-id="${user.id}" data-active="${user.isActive}">
						${user.isActive ? 'Desactivar' : 'Activar'}
					</button>
				</td>
			`;
			tbody.appendChild(tr);
		});

		document.querySelectorAll('.btn-toggle-status').forEach(btn => {
			btn.addEventListener('click', async (e) => {
				const id = parseInt((e.currentTarget as HTMLElement).getAttribute('data-id') || '0');
				const isActive = (e.currentTarget as HTMLElement).getAttribute('data-active') === 'true';
				
				if (confirm(`¿Estás seguro de ${isActive ? 'desactivar' : 'activar'} este usuario?`)) {
					try {
						await changeUserStatus(id);
						loadUsers();
					} catch (error: any) {
						alert('Error: ' + (error.message || 'Error al cambiar estado'));
					}
				}
			});
		});
	}

	function updatePagination() {
		const start = (currentPage - 1) * rowsPerPage + 1;
		const end = Math.min(currentPage * rowsPerPage, totalUsers);
		paginationInfo.textContent = `Mostrando ${start}-${end} de ${totalUsers}`;

		btnPrev.disabled = currentPage === 1;
		btnNext.disabled = currentPage * rowsPerPage >= totalUsers;
	}

	btnPrev.addEventListener('click', () => {
		if (currentPage > 1) {
			currentPage--;
			loadUsers();
		}
	});

	btnNext.addEventListener('click', () => {
		if (currentPage * rowsPerPage < totalUsers) {
			currentPage++;
			loadUsers();
		}
	});

	// ==================== MODAL ====================
	function openModal() {
		modal.classList.remove('hidden');
	}

	function closeModal() {
		modal.classList.add('hidden');
		userForm.reset();
		(document.getElementById('form-error') as HTMLElement).classList.add('hidden');
		(document.getElementById('form-success') as HTMLElement).classList.add('hidden');
	}

	btnNewUser.addEventListener('click', openModal);
	modalClose.addEventListener('click', closeModal);
	modalCancel.addEventListener('click', closeModal);

	userForm.addEventListener('submit', async (e) => {
		e.preventDefault();

		const formError = document.getElementById('form-error') as HTMLElement;
		const formSuccess = document.getElementById('form-success') as HTMLElement;
		const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;

		formError.classList.add('hidden');
		formSuccess.classList.add('hidden');

		const dto: ICreateUserDto = {
			name: (document.getElementById('user-name') as HTMLInputElement).value.trim(),
			fullName: (document.getElementById('user-fullname') as HTMLInputElement).value.trim(),
			email: (document.getElementById('user-email') as HTMLInputElement).value.trim(),
			dni: (document.getElementById('user-dni') as HTMLInputElement).value.trim(),
			password: (document.getElementById('user-password') as HTMLInputElement).value,
			profile: 1 // DIOS
		};

		try {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Creando...';

			await createUser(dto);

			formSuccess.textContent = 'Usuario creado exitosamente';
			formSuccess.classList.remove('hidden');

			setTimeout(() => {
				closeModal();
				loadUsers();
			}, 1500);
		} catch (error: any) {
			formError.textContent = error.message || 'Error al crear usuario';
			formError.classList.remove('hidden');
			submitBtn.disabled = false;
			submitBtn.textContent = 'Crear Usuario';
		}
	});

	// ==================== INICIALIZACIÓN ====================
	loadUsers();
</script>
