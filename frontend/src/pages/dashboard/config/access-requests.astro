---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Solicitudes de Acceso - S.I.R.E.">
	<div class="space-y-6">
		<!-- Header -->
		<div>
			<h2 class="font-display font-bold text-2xl md:text-3xl text-text-dark">Solicitudes de Acceso Médico</h2>
			<p class="text-sm text-text-dark/60 mt-1">Gestiona las solicitudes de personal de salud para acceso al sistema</p>
		</div>

		<!-- Filtros -->
		<div class="bg-white border border-border-subtle rounded-xl p-4 shadow-sm">
			<div class="flex gap-3">
				<select id="filter-status" class="h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors">
					<option value="">Todos los estados</option>
					<option value="PENDING">Pendientes</option>
					<option value="APPROVED">Aprobadas</option>
					<option value="REJECTED">Rechazadas</option>
				</select>
			</div>
		</div>

		<!-- Lista de solicitudes -->
		<div class="bg-white border border-border-subtle rounded-xl shadow-sm">
			<div class="p-4 border-b border-border-subtle">
				<h3 class="font-display font-bold text-lg text-text-dark">Lista de Solicitudes</h3>
			</div>

			<!-- Loading -->
			<div id="requests-loading" class="p-8 text-center">
				<div class="animate-spin h-8 w-8 border-2 border-vzla-blue border-t-transparent rounded-full mx-auto"></div>
				<p class="text-sm text-text-dark/60 mt-3">Cargando solicitudes...</p>
			</div>

			<!-- Lista -->
			<div id="requests-list" class="hidden divide-y divide-border-subtle"></div>

			<!-- Empty -->
			<div id="requests-empty" class="hidden p-12 text-center space-y-3">
				<div class="w-16 h-16 mx-auto rounded-full bg-bg-light flex items-center justify-center text-text-dark/40">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
						<polyline points="14 2 14 8 20 8"></polyline>
						<line x1="16" y1="13" x2="8" y2="13"></line>
						<line x1="16" y1="17" x2="8" y2="17"></line>
						<polyline points="10 9 9 9 8 9"></polyline>
					</svg>
				</div>
				<p class="font-display font-semibold text-text-dark">No hay solicitudes</p>
				<p class="text-sm text-text-dark/60">Las nuevas solicitudes aparecerán aquí</p>
			</div>

			<!-- Paginación -->
			<div id="requests-pagination" class="hidden border-t border-border-subtle p-4 flex items-center justify-between">
				<span id="pagination-info" class="text-sm text-text-dark/60"></span>
				<div class="flex gap-2">
					<button id="btn-prev" class="h-9 px-4 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
						Anterior
					</button>
					<button id="btn-next" class="h-9 px-4 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
						Siguiente
					</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Modal Aprobar -->
	<div id="approve-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-2xl shadow-xl max-w-md w-full">
			<div class="p-6 border-b border-border-subtle">
				<h3 class="font-display font-bold text-xl text-text-dark">Aprobar Solicitud</h3>
			</div>

			<form id="approve-form" class="p-6 space-y-5">
				<input type="hidden" id="approve-request-id" value="" />

				<div id="approve-request-info" class="bg-bg-light border border-border-subtle rounded-lg p-4 text-sm space-y-1"></div>

				<div class="space-y-2">
					<label for="initial-password" class="block text-sm font-display font-bold text-text-dark">
						Contraseña Inicial <span class="text-error-text">*</span>
					</label>
					<input 
						type="password"
						id="initial-password"
						required
						minlength="6"
						class="w-full h-11 px-4 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
						placeholder="Mínimo 6 caracteres"
					/>
					<p class="text-xs text-text-dark/50">Esta contraseña será enviada al solicitante por correo</p>
				</div>

				<div id="approve-error" class="hidden bg-error-light border border-error-border text-error-text text-sm rounded-lg p-3"></div>
				<div id="approve-success" class="hidden bg-success-light border border-success-border text-success-text text-sm rounded-lg p-3"></div>

				<div class="flex gap-3">
					<button 
						type="button"
						id="approve-cancel"
						class="flex-1 h-11 border border-border-subtle rounded-lg text-sm font-display font-semibold hover:bg-bg-light transition-colors"
					>
						Cancelar
					</button>
					<button 
						type="submit"
						id="approve-submit"
						class="flex-1 h-11 bg-success-bg hover:bg-success-bg-hover text-white font-display font-bold text-sm rounded-lg transition-all"
					>
						Aprobar Acceso
					</button>

				</div>
			</form>
		</div>
	</div>
</DashboardLayout>

<script>
	import { findAllAccessRequests, approveAccessRequest, rejectAccessRequest } from '../../../lib/api';
	import { AccessRequestStatus } from '@shared/core/auth/access-requests/interfaces';
	import type { IMedicalAccessRequest, IAccessRequestFilter } from '@shared/core/auth/access-requests/interfaces';

	// ==================== STATE ====================
	let currentPage = 1;
	const rowsPerPage = 10;
	let totalRequests = 0;
	let requests: IMedicalAccessRequest[] = [];
	let currentFilter: IAccessRequestFilter = {};

	// ==================== ELEMENTOS ====================
	const loadingEl = document.getElementById('requests-loading') as HTMLElement;
	const listEl = document.getElementById('requests-list') as HTMLElement;
	const emptyEl = document.getElementById('requests-empty') as HTMLElement;
	const paginationEl = document.getElementById('requests-pagination') as HTMLElement;
	const paginationInfo = document.getElementById('pagination-info') as HTMLElement;
	const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
	const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
	const filterStatus = document.getElementById('filter-status') as HTMLSelectElement;

	const approveModal = document.getElementById('approve-modal') as HTMLElement;
	const approveForm = document.getElementById('approve-form') as HTMLFormElement;
	const approveCancel = document.getElementById('approve-cancel') as HTMLElement;

	// ==================== CARGAR SOLICITUDES ====================
	async function loadRequests() {
		try {
			loadingEl.classList.remove('hidden');
			listEl.classList.add('hidden');
			emptyEl.classList.add('hidden');

			const response = await findAllAccessRequests({ 
				page: currentPage, 
				rows: rowsPerPage,
				...currentFilter 
			});
			requests = response.data;
			totalRequests = response.total;

			if (requests.length === 0) {
				loadingEl.classList.add('hidden');
				emptyEl.classList.remove('hidden');
				paginationEl.classList.add('hidden');
			} else {
				renderList();
				updatePagination();
				loadingEl.classList.add('hidden');
				listEl.classList.remove('hidden');
				paginationEl.classList.remove('hidden');
			}
		} catch (error) {
			console.error('Error al cargar solicitudes:', error);
			loadingEl.classList.add('hidden');
			emptyEl.classList.remove('hidden');
		}
	}

	function renderList() {
		listEl.innerHTML = '';

		requests.forEach(request => {
			const createdDate = new Date(request.createdAt || '').toLocaleDateString('es-VE', {
				year: 'numeric',
				month: 'short',
				day: 'numeric'
			});

			const statusConfig = {
				PENDING: { label: 'Pendiente', class: 'bg-alert-light text-alert-text' },
				APPROVED: { label: 'Aprobada', class: 'bg-success-light text-success-text' },
				REJECTED: { label: 'Rechazada', class: 'bg-error-light text-error-text' }
			}[request.status];

			const div = document.createElement('div');
			div.className = 'p-5 hover:bg-bg-light/50 transition-colors';
			div.innerHTML = `
				<div class="flex items-start justify-between gap-4">
					<div class="flex-1 space-y-3">
						<div class="flex items-center gap-3">
							<h4 class="font-display font-bold text-lg text-text-dark">${request.fullName}</h4>
							<span class="px-2.5 py-0.5 rounded-full text-xs font-bold ${statusConfig.class}">
								${statusConfig.label}
							</span>
						</div>
						
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-text-dark/70">
							<div><strong>CI:</strong> ${request.dni}</div>
							<div><strong>Email:</strong> ${request.email}</div>
							<div><strong>Teléfono:</strong> ${request.phoneNumber}</div>
							<div><strong>Cargo:</strong> ${request.position}</div>
							<div class="sm:col-span-2"><strong>Centro:</strong> ${request.manualMedicalCenter || 'Centro médico del catálogo'}</div>
							<div class="text-xs text-text-dark/50"><strong>Solicitado:</strong> ${createdDate}</div>
						</div>

						${request.status === AccessRequestStatus.PENDING ? `
							<div class="flex gap-2 pt-2">
								<button 
									class="btn-approve h-9 px-4 bg-success-bg hover:bg-success-bg-hover text-white rounded-lg text-sm font-display font-semibold transition-colors"
									data-request='${JSON.stringify(request)}'
								>
									✓ Aprobar
								</button>

								<button 
									class="btn-reject h-9 px-4 border border-error-border text-error-text hover:bg-error-light rounded-lg text-sm font-display font-semibold transition-colors"
									data-id="${request.id}"
								>
									✗ Rechazar
								</button>
							</div>
						` : ''}
					</div>
				</div>
			`;
			listEl.appendChild(div);
		});

		// Event listeners
		document.querySelectorAll('.btn-approve').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const data = (e.currentTarget as HTMLElement).getAttribute('data-request');
				if (data) openApproveModal(JSON.parse(data));
			});
		});

		document.querySelectorAll('.btn-reject').forEach(btn => {
			btn.addEventListener('click', async (e) => {
				const id = parseInt((e.currentTarget as HTMLElement).getAttribute('data-id') || '0');
				
				if (confirm('¿Estás seguro de rechazar esta solicitud? Esta acción no se puede deshacer.')) {
					try {
						await rejectAccessRequest(id);
						loadRequests();
					} catch (error: any) {
						alert('Error: ' + (error.message || 'Error al rechazar'));
					}
				}
			});
		});
	}

	function updatePagination() {
		const start = (currentPage - 1) * rowsPerPage + 1;
		const end = Math.min(currentPage * rowsPerPage, totalRequests);
		paginationInfo.textContent = `Mostrando ${start}-${end} de ${totalRequests}`;

		btnPrev.disabled = currentPage === 1;
		btnNext.disabled = currentPage * rowsPerPage >= totalRequests;
	}

	btnPrev.addEventListener('click', () => {
		if (currentPage > 1) {
			currentPage--;
			loadRequests();
		}
	});

	btnNext.addEventListener('click', () => {
		if (currentPage * rowsPerPage < totalRequests) {
			currentPage++;
			loadRequests();
		}
	});

	// Filtro
	filterStatus.addEventListener('change', () => {
		const status = filterStatus.value;
		currentFilter = status ? { status: status as any } : {};
		currentPage = 1;
		loadRequests();
	});

	// ==================== MODAL APROBAR ====================
	function openApproveModal(request: IMedicalAccessRequest) {
		const infoEl = document.getElementById('approve-request-info') as HTMLElement;
		infoEl.innerHTML = `
			<p class="font-display font-bold text-text-dark">${request.fullName}</p>
			<p class="text-text-dark/70">${request.email}</p>
			<p class="text-text-dark/70">CI: ${request.dni} • ${request.position}</p>
		`;

		(document.getElementById('approve-request-id') as HTMLInputElement).value = String(request.id);
		approveModal.classList.remove('hidden');
	}

	function closeApproveModal() {
		approveModal.classList.add('hidden');
		approveForm.reset();
		(document.getElementById('approve-error') as HTMLElement).classList.add('hidden');
		(document.getElementById('approve-success') as HTMLElement).classList.add('hidden');

		// Restaurar el botón de submit a su estado original
		const submitBtn = document.getElementById('approve-submit') as HTMLButtonElement;
		if (submitBtn) {
			submitBtn.disabled = false;
			submitBtn.textContent = 'Aprobar Acceso';
		}
	}


	approveCancel.addEventListener('click', closeApproveModal);

	approveForm.addEventListener('submit', async (e) => {
		e.preventDefault();

		const approveError = document.getElementById('approve-error') as HTMLElement;
		const approveSuccess = document.getElementById('approve-success') as HTMLElement;
		const submitBtn = document.getElementById('approve-submit') as HTMLButtonElement;

		approveError.classList.add('hidden');
		approveSuccess.classList.add('hidden');

		const id = parseInt((document.getElementById('approve-request-id') as HTMLInputElement).value);
		const password = (document.getElementById('initial-password') as HTMLInputElement).value;

		try {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Aprobando...';

			await approveAccessRequest(id, { password });

			approveSuccess.textContent = '✓ Solicitud aprobada. Se ha enviado un correo al solicitante.';
			approveSuccess.classList.remove('hidden');

			setTimeout(() => {
				closeApproveModal();
				loadRequests();
			}, 2000);
		} catch (error: any) {
			approveError.textContent = error.message || 'Error al aprobar';
			approveError.classList.remove('hidden');
			submitBtn.disabled = false;
			submitBtn.textContent = 'Aprobar Acceso';
		}
	});

	// ==================== INICIALIZACIÓN ====================
	loadRequests();
</script>
