---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Recuperar Contraseña - S.I.R.E." noindex={true}>
  <div class="max-w-md mx-auto my-8 md:my-16 space-y-6 animate-fade-in font-sans">
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
      
      <!-- Título -->
      <div class="text-center space-y-1">
        <h1 class="font-display font-bold text-2xl md:text-3xl text-text-dark">¿Olvidaste tu Contraseña?</h1>
        <p class="text-xs md:text-sm text-text-dark/60">
          Ingresa tu correo electrónico y te enviaremos un enlace para restablecer tu contraseña.
        </p>
      </div>

      <!-- Formulario -->
      <form id="forgot-password-form" class="space-y-4">
        <div class="space-y-1.5">
          <label for="email" class="block text-sm font-semibold text-text-dark/70">Correo electrónico</label>
          <input 
            type="email" 
            id="email" 
            required 
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="correo@ejemplo.com"
          />
        </div>

        <!-- Mensajes -->
        <div id="form-error" class="hidden bg-error-light border border-error-border text-error-text text-xs font-semibold rounded-lg p-3" role="alert"></div>
        <div id="form-success" class="hidden bg-success-light border border-success-border text-success-text text-xs font-semibold rounded-lg p-3" role="alert"></div>

        <button 
          type="submit" 
          id="submit-btn"
          class="w-full h-11 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg cursor-pointer transition-colors shadow-xs"
        >
          Enviar Enlace de Recuperación
        </button>
      </form>
    </div>

    <!-- Enlaces -->
    <div class="text-center space-y-2">
      <p class="text-xs md:text-sm text-text-dark/60">
        ¿Recordaste tu contraseña? 
        <a href="/login" class="text-vzla-blue hover:underline font-semibold ml-1">Inicia sesión aquí</a>
      </p>
      <p class="text-xs md:text-sm text-text-dark/60">
        <a href="/" class="text-vzla-blue hover:underline font-semibold">Volver a la página principal</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { requestPasswordReset } from '../lib/api';

  if (typeof window !== 'undefined') {
    const form = document.getElementById('forgot-password-form') as HTMLFormElement;
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const formError = document.getElementById('form-error') as HTMLElement;
    const formSuccess = document.getElementById('form-success') as HTMLElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    
    if (form && emailInput && formError && formSuccess && submitBtn) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const email = emailInput.value.trim();

        // Limpiar mensajes
        formError.classList.add('hidden');
        formSuccess.classList.add('hidden');

        // Deshabilitar botón
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando...';

        try {
          const response = await requestPasswordReset(email);

          // Mostrar mensaje de éxito
          formSuccess.textContent = response.message || '✓ Se ha enviado un correo con instrucciones para recuperar tu contraseña. Por favor revisa tu bandeja de entrada.';
          formSuccess.classList.remove('hidden');
          form.reset();
          
          // Deshabilitar formulario
          emailInput.disabled = true;
          submitBtn.textContent = 'Enlace Enviado';
        } catch (error: any) {
          // Mostrar error
          formError.textContent = '⚠️ ' + (error.message || 'Error al enviar el correo. Por favor intenta nuevamente.');
          formError.classList.remove('hidden');
          
          // Re-habilitar botón
          submitBtn.disabled = false;
          submitBtn.textContent = 'Enviar Enlace de Recuperación';
        }
      });
    }
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
