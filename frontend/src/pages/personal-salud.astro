---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Solicitud de Acceso para Personal de Salud - S.I.R.E."
  description="Si eres médico, enfermero o personal de salud en Venezuela, solicita tu acceso autorizado para colaborar registrando pacientes hospitalizados."
>
  <div class="max-w-2xl mx-auto space-y-8">
    <!-- Header -->
    <section class="text-center space-y-4">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-vzla-blue/10 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-vzla-blue">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <polyline points="16 11 18 13 22 9"></polyline>
        </svg>
      </div>
      
      <h1 class="font-display font-bold text-3xl md:text-4xl text-text-dark tracking-tight leading-tight">
        Solicitud de Acceso para Personal de Salud
      </h1>
      
      <p class="font-sans text-base md:text-lg text-text-dark/70 leading-relaxed max-w-xl mx-auto">
        Como médico puedes crear una cuenta y registrar los pacientes que ves en tus guardias para colaborar 
        con la base de datos centralizada. Llena el formulario y el equipo de S.I.R.E. revisará y habilitará tu acceso.
      </p>

    </section>

    <!-- Formulario -->
    <section class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm">
      <form id="access-request-form" class="space-y-6">
        <!-- Nombre Completo -->
        <div class="space-y-2">
          <label for="fullName" class="block font-display font-bold text-base text-text-dark">
            Nombre Completo <span class="text-error-text">*</span>
          </label>
          <input
            type="text"
            id="fullName"
            name="fullName"
            required
            class="w-full h-12 px-4 bg-white border border-border-subtle rounded-xl text-base text-text-dark placeholder-text-dark/40 focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
            placeholder="Ej: Dr. Juan Alberto Pérez"
          />
        </div>

        <!-- Cédula -->
        <div class="space-y-2">
          <label for="dni" class="block font-display font-bold text-base text-text-dark">
            Cédula de Identidad <span class="text-error-text">*</span>
          </label>
          <input
            type="text"
            id="dni"
            name="dni"
            required
            class="w-full h-12 px-4 bg-white border border-border-subtle rounded-xl text-base text-text-dark placeholder-text-dark/40 focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
            placeholder="Ej: 12345678"
          />
          <p class="text-xs text-text-dark/50 font-sans">Solo números, sin puntos ni guiones</p>
        </div>

        <!-- Email -->
        <div class="space-y-2">
          <label for="email" class="block font-display font-bold text-base text-text-dark">
            Correo Electrónico <span class="text-error-text">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full h-12 px-4 bg-white border border-border-subtle rounded-xl text-base text-text-dark placeholder-text-dark/40 focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
            placeholder="tu.email@hospital.gob.ve"
          />
        </div>

        <!-- Teléfono -->
        <div class="space-y-2">
          <label for="phoneNumber" class="block font-display font-bold text-base text-text-dark">
            Número de Teléfono <span class="text-error-text">*</span>
          </label>
          <input
            type="tel"
            id="phoneNumber"
            name="phoneNumber"
            required
            class="w-full h-12 px-4 bg-white border border-border-subtle rounded-xl text-base text-text-dark placeholder-text-dark/40 focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
            placeholder="Ej: 04241234567"
          />
        </div>

        <!-- Cargo/Posición -->
        <div class="space-y-2">
          <label for="position" class="block font-display font-bold text-base text-text-dark">
            Cargo en el Centro de Salud <span class="text-error-text">*</span>
          </label>
          <select
            id="position"
            name="position"
            required
            class="w-full h-12 px-4 bg-white border border-border-subtle rounded-xl text-base text-text-dark focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
          >
            <option value="">Selecciona tu cargo...</option>
            <option value="Médico">Médico</option>
            <option value="Enfermero">Enfermero</option>
            <option value="Paramédico">Paramédico</option>
            <option value="Interno">Interno</option>
            <option value="Residente">Residente</option>
            <option value="Otro">Otro</option>
          </select>
        </div>

        <!-- Centro de Salud Autocomplete Combobox -->
        <div class="space-y-2">
          <label for="medical-center-search" class="block font-display font-bold text-base text-text-dark">
            Centro de Salud donde Laboras <span class="text-error-text">*</span>
          </label>
          
          <div id="medical-center-combobox" class="relative">
            <!-- Input de búsqueda -->
            <input 
              type="text"
              id="medical-center-search"
              class="w-full h-12 px-4 bg-white border border-border-subtle rounded-xl text-base text-text-dark placeholder-text-dark/40 focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
              placeholder="🔍 Busca tu centro de salud..."
              autocomplete="off"
            />
            <!-- Dropdown de resultados -->
            <ul 
              id="medical-center-dropdown"
              class="hidden absolute z-30 w-full mt-1 bg-white border border-border-subtle rounded-xl shadow-lg max-h-60 overflow-y-auto divide-y divide-slate-50 outline-none"
            >
            </ul>
          </div>

          <!-- Caja de centro seleccionado -->
          <div id="medical-center-selected" class="hidden items-center justify-between gap-3 bg-slate-50 border border-border-subtle rounded-xl px-4 py-3 shrink-0">
            <span id="medical-center-selected-name" class="text-sm font-semibold text-text-dark"></span>
            <button type="button" id="medical-center-clear" class="text-sm text-slate-500 hover:text-slate-800 font-semibold whitespace-nowrap bg-white border border-border-subtle rounded-lg px-3 py-1.5 transition-colors focus:ring-2 focus:ring-slate-200 outline-none cursor-pointer">
              Cambiar
            </button>
          </div>

          <!-- Input manual (aparece si eligen "Escribir manualmente") -->
          <input 
            type="text"
            id="medical-center-manual"
            class="hidden w-full h-12 px-4 bg-white border border-border-subtle rounded-xl text-base text-text-dark placeholder-text-dark/40 focus:border-vzla-blue focus:ring-1 focus:ring-vzla-blue/20 focus:outline-none transition-all"
            placeholder="Ej: Hospital Domingo Luciani"
          />
          
          <!-- ID del centro seleccionado (oculto) -->
          <input type="hidden" id="selected-center-id" />

          <p class="text-xs text-text-dark/50 font-sans">Escribe para buscar en el catálogo o selecciona la opción de escritura manual.</p>
        </div>

        <!-- Aviso de Verificación -->
        <div class="bg-bg-light border border-border-subtle rounded-xl p-5">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-5 h-5 rounded-full bg-vzla-blue/10 flex items-center justify-center text-vzla-blue text-xs font-bold mt-0.5">
              i
            </div>
            <div class="flex-1 space-y-1">
              <p class="text-sm font-display font-semibold text-text-dark">Proceso de Revisión</p>
              <p class="text-xs text-text-dark/60 font-sans leading-relaxed">
                Tu solicitud será <strong>revisada manualmente</strong> por el equipo de administración. 
                Tu cuenta quedará <strong>en estado inactivo</strong> hasta que sea aprobada. 
                Recibirás un correo cuando tu acceso sea autorizado.
              </p>
            </div>
          </div>
        </div>

        <!-- Botón de envío -->
        <button
          type="submit"
          id="submit-btn"
          class="w-full h-14 px-8 bg-vzla-blue hover:bg-vzla-blue-hover active:bg-vzla-blue text-white font-display font-bold text-lg rounded-xl flex items-center justify-center gap-2 cursor-pointer shadow-xs hover:shadow transition-all disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="submit-text">Enviar Solicitud</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </form>

      <!-- Mensaje de éxito -->
      <div id="success-message" class="hidden mt-6 bg-success-light border border-success-border rounded-xl p-6 text-center space-y-3">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-success-text/10 text-success-text">
          ✓
        </div>
        <h3 class="font-display font-bold text-xl text-success-text">¡Solicitud Enviada Exitosamente!</h3>
        <p class="font-sans text-sm text-text-dark/70 max-w-md mx-auto leading-relaxed">
          Tu solicitud ha sido recibida y está en <strong>revisión</strong>. 
          Recibirás un correo electrónico cuando tu acceso sea aprobado por el administrador del sistema.
        </p>
        <a href="/" class="inline-block mt-4 text-sm font-display font-semibold text-vzla-blue hover:underline">
          ← Volver al inicio
        </a>
      </div>

      <!-- Mensaje de error -->
      <div id="error-message" class="hidden mt-6 bg-error-light border border-error-border rounded-xl p-6 text-center space-y-3">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-error-text/10 text-error-text">
          ⚠️
        </div>
        <h3 class="font-display font-bold text-xl text-error-text">Error al Enviar Solicitud</h3>
        <p id="error-text" class="font-sans text-sm text-text-dark/70 max-w-md mx-auto"></p>
      </div>
    </section>

    <!-- Información adicional -->
    <section class="bg-white border border-border-subtle rounded-2xl p-6 shadow-xs">
      <h3 class="font-display font-bold text-base text-text-dark mb-3">
        ¿Qué sucede después de enviar mi solicitud?
      </h3>
      <ol class="space-y-3 text-sm text-text-dark/70 font-sans list-decimal list-inside">
        <li>Tu información será <strong>verificada manualmente</strong> por el equipo de administración</li>
        <li>Recibirás un <strong>correo electrónico</strong> cuando tu cuenta sea aprobada</li>
        <li>Podrás <strong>iniciar sesión</strong> y comenzar a registrar pacientes inmediatamente</li>
        <li>Tendrás acceso al <strong>Dashboard Médico</strong> para gestionar tu carga de pacientes</li>
      </ol>
    </section>
  </div>
</Layout>

<script>
  import { createMedicalAccessRequest, searchMedicalCenters, type ApiError } from '../lib/api';
  import type { ICreateAccessRequestDto } from '@shared/core/auth/access-requests/interfaces';
  import type { IMedicalCenter } from '@shared/core/config/medical-centers/interfaces';

  const form = document.getElementById('access-request-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text') as HTMLSpanElement;
  const successMessage = document.getElementById('success-message') as HTMLDivElement;
  const errorMessage = document.getElementById('error-message') as HTMLDivElement;
  const errorText = document.getElementById('error-text') as HTMLParagraphElement;

  // ==================== CENTRO DE SALUD COMBOBOX LÓGICA ====================
  const centerSearch = document.getElementById('medical-center-search') as HTMLInputElement;
  const centerDropdown = document.getElementById('medical-center-dropdown') as HTMLUListElement;
  const centerCombobox = document.getElementById('medical-center-combobox') as HTMLElement;
  const centerSelected = document.getElementById('medical-center-selected') as HTMLElement;
  const centerSelectedName = document.getElementById('medical-center-selected-name') as HTMLElement;
  const centerClearBtn = document.getElementById('medical-center-clear') as HTMLButtonElement;
  const centerManual = document.getElementById('medical-center-manual') as HTMLInputElement;
  const selectedCenterId = document.getElementById('selected-center-id') as HTMLInputElement;
  const MANUAL_OPTION = '__manual__';

  let centerSearchTimeout: number;

  function escapeHtml(value: string): string {
    return (value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function renderCenterDropdown(centers: IMedicalCenter[]) {
    const manualItem = `
      <li>
        <button type="button" data-center-id="${MANUAL_OPTION}" class="center-option w-full text-left px-4 py-3 hover:bg-slate-50 transition-colors font-bold text-vzla-blue border-b border-slate-100 cursor-pointer">
          ✏️ Escribir manualmente...
        </button>
      </li>
    `;

    const items = centers
      .map((c) => {
        const sub = [c.state, c.municipality].filter(Boolean).join(', ');
        return `
        <li>
          <button type="button" data-center-id="${c.id}" data-center-name="${escapeHtml(c.name)}" class="center-option w-full text-left px-4 py-3 hover:bg-slate-50 transition-colors border-b border-slate-50 last:border-0 cursor-pointer">
            <span class="block font-bold text-slate-900">${escapeHtml(c.name)}</span>
            ${sub ? `<span class="block text-xs font-medium text-slate-500 mt-0.5">${escapeHtml(sub)}</span>` : ''}
          </button>
        </li>
      `;
      })
      .join('');

    const emptyMsg =
      centers.length === 0
        ? '<li class="px-4 py-3 text-slate-500 text-sm">Sin coincidencias en el catálogo.</li>'
        : '';

    centerDropdown.innerHTML = manualItem + items + emptyMsg;
    centerDropdown.classList.remove('hidden');

    centerDropdown.querySelectorAll('.center-option').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const el = e.currentTarget as HTMLElement;
        const id = el.getAttribute('data-center-id');
        if (id === MANUAL_OPTION) {
          selectManualEntry();
        } else if (id) {
          selectCenter(parseInt(id), el.getAttribute('data-center-name') || '');
        }
      });
    });
  }

  async function fetchCenters(query: string) {
    try {
      // Pasamos true como segundo argumento para indicarle al API que no requiere autenticación
      const centers = await searchMedicalCenters(query, true);
      renderCenterDropdown(centers);
    } catch (error) {
      console.error('Error al buscar centros:', error);
      renderCenterDropdown([]);
    }
  }

  function selectCenter(id: number, name: string) {
    selectedCenterId.value = String(id);
    centerSelectedName.textContent = name || 'Centro seleccionado';
    centerSelected.classList.remove('hidden');
    centerSelected.classList.add('flex');
    centerDropdown.classList.add('hidden');
    centerSearch.classList.add('hidden');
    centerSearch.value = '';
    centerManual.classList.add('hidden');
    centerManual.value = '';
  }

  function selectManualEntry() {
    selectedCenterId.value = '';
    centerDropdown.classList.add('hidden');
    centerSearch.classList.add('hidden');
    centerSelected.classList.add('hidden');
    centerSelected.classList.remove('flex');
    centerManual.classList.remove('hidden');
    centerManual.value = centerSearch.value.trim();
    centerManual.focus();
  }

  function resetCenterPicker() {
    selectedCenterId.value = '';
    centerSelected.classList.add('hidden');
    centerSelected.classList.remove('flex');
    centerManual.classList.add('hidden');
    centerManual.value = '';
    centerSearch.classList.remove('hidden');
    centerSearch.value = '';
    centerDropdown.classList.add('hidden');
    centerDropdown.innerHTML = '';
  }

  if (centerSearch) {
    centerSearch.addEventListener('input', () => {
      clearTimeout(centerSearchTimeout);
      const value = centerSearch.value.trim();
      centerSearchTimeout = window.setTimeout(() => {
        fetchCenters(value);
      }, 300);
    });

    centerSearch.addEventListener('focus', () => {
      fetchCenters(centerSearch.value.trim());
    });
  }

  if (centerClearBtn) {
    centerClearBtn.addEventListener('click', () => {
      resetCenterPicker();
      centerSearch.focus();
      fetchCenters('');
    });
  }

  if (centerManual) {
    centerManual.addEventListener('input', () => {
      if (centerManual.value.trim() === '') {
        resetCenterPicker();
        centerSearch.focus();
        fetchCenters('');
      }
    });
  }

  document.addEventListener('click', (e) => {
    if (centerCombobox && !centerCombobox.contains(e.target as Node)) {
      centerDropdown.classList.add('hidden');
    }
  });

  // ==================== FORM SUBMIT HANDLER ====================
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Ocultar mensajes previos
      successMessage.classList.add('hidden');
      errorMessage.classList.add('hidden');

      const centerIdStr = selectedCenterId.value;
      const centerManualVal = centerManual.value.trim();
      const centerId = centerIdStr ? parseInt(centerIdStr) : undefined;

      // Validación del centro de salud
      if (!centerId && !centerManualVal) {
        errorText.textContent = 'Por favor selecciona un centro de salud del catálogo o escribe uno manualmente.';
        errorMessage.classList.remove('hidden');
        errorMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      // Deshabilitar botón
      submitBtn.disabled = true;
      submitText.textContent = 'Enviando...';

      try {
        // Obtener datos del formulario
        const formData = new FormData(form);
        const dto: ICreateAccessRequestDto = {
          fullName: formData.get('fullName') as string,
          dni: formData.get('dni') as string,
          email: formData.get('email') as string,
          phoneNumber: formData.get('phoneNumber') as string,
          position: formData.get('position') as string,
          ...(centerId ? { medicalCenterId: centerId } : { manualMedicalCenter: centerManualVal }),
        };

        // Enviar al API
        await createMedicalAccessRequest(dto);

        // Mostrar mensaje de éxito
        form.classList.add('hidden');
        successMessage.classList.remove('hidden');
        
        // Scroll al mensaje
        successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });

      } catch (error) {
        // Mostrar error
        const apiError = error as ApiError;
        errorText.textContent = apiError.message || 'Ocurrió un error inesperado. Por favor intenta nuevamente.';
        errorMessage.classList.remove('hidden');
        
        // Re-habilitar botón
        submitBtn.disabled = false;
        submitText.textContent = 'Enviar Solicitud';
        
        // Scroll al error
        errorMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  }
</script>
