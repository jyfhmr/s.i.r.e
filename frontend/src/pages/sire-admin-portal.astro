---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="SIRE - Portal Seguro de Administración">
  <!-- PANTALLA 1: FORMULARIO DE ACCESO (LOGIN) -->
  <div id="admin-login-screen" class="max-w-md mx-auto my-12 md:my-20 space-y-6 animate-fade-in font-sans">
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
      <div class="text-center space-y-1">
        <h2 class="font-display font-bold text-xl md:text-2xl text-text-dark">Ingreso Administrativo</h2>
        <p class="text-xs md:text-sm text-text-dark/60">
          Identifícate con tus credenciales de seguridad institucional.
        </p>
      </div>

      <form id="form-admin-login" class="space-y-4">
        <div class="space-y-1.5">
          <label for="admin-email" class="block text-sm font-semibold text-text-dark/70">Correo electrónico</label>
          <input 
            type="email" 
            id="admin-email" 
            required 
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="admin@sire.org"
          />
        </div>

        <div class="space-y-1.5">
          <label for="admin-password" class="block text-sm font-semibold text-text-dark/70">Contraseña de Control</label>
          <input 
            type="password" 
            id="admin-password" 
            required 
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="••••••••••••"
          />
        </div>

        <div id="admin-login-error" class="hidden bg-error-light border border-error-border text-error-text text-xs font-semibold rounded-lg p-3" role="alert">
          ⚠️ Acceso denegado: Credenciales incorrectas.
        </div>

        <button 
          type="submit" 
          class="w-full h-11 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg cursor-pointer transition-colors shadow-xs"
        >
          Iniciar Sesión
        </button>
      </form>
    </div>

    <!-- Ayuda de demostración para evaluación del evaluador -->
    <div class="bg-info-light/60 border border-info-border rounded-xl p-4 text-xs text-info-text leading-relaxed">
      <p class="font-semibold mb-1">Credenciales de prueba del administrador:</p>
      <p>Usuario: <strong class="select-all">admin@sire.org</strong></p>
      <p class="mt-0.5">Clave: <strong class="select-all">SireControl2026!</strong></p>
    </div>
  </div>

  <!-- PANTALLA 2: PANEL DE CONTROL DE ADMINISTRACIÓN (GATED) -->
  <div id="admin-dashboard-screen" class="hidden space-y-6">
    <!-- Pestañas (Tabs) -->
    <div class="flex border-b border-border-subtle gap-2">
      <button
        id="tab-medics"
        class="tab-btn px-5 py-3 border-b-2 border-vzla-blue font-display font-bold text-sm text-vzla-blue transition-colors cursor-pointer"
      >
        Personal Médico
      </button>
      <button
        id="tab-patients"
        class="tab-btn px-5 py-3 border-b-2 border-transparent font-display font-semibold text-sm text-text-dark/60 hover:text-text-dark hover:border-border-subtle transition-colors cursor-pointer"
      >
        Gestionar Pacientes
      </button>
    </div>

    <!-- PANEL 1: PERSONAL MÉDICO -->
    <div id="panel-medics" class="space-y-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Formulario Crear Médico -->
        <div class="bg-white border border-border-subtle rounded-2xl p-5 shadow-sm space-y-4 h-fit">
          <h2 class="font-display font-bold text-lg text-text-dark">Registrar Usuario Médico</h2>
          
          <form id="form-create-doctor" class="space-y-3.5">
            <div class="space-y-1">
              <label for="doc-name" class="block text-xs font-semibold text-text-dark/70">Nombre del Médico</label>
              <input 
                type="text" 
                id="doc-name" 
                required 
                class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: Dra. Gabriela Rivas"
              />
            </div>

            <div class="space-y-1">
              <label for="doc-email" class="block text-xs font-semibold text-text-dark/70">Correo Institucional</label>
              <input 
                type="email" 
                id="doc-email" 
                required 
                class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="gabriela.rivas@huc.org"
              />
            </div>

            <div class="space-y-1">
              <label for="doc-hospital" class="block text-xs font-semibold text-text-dark/70">Centro Hospitalario</label>
              <input 
                type="text" 
                id="doc-hospital" 
                required 
                class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: Hospital Univ. de Caracas"
              />
            </div>

            <div class="space-y-1">
              <label for="doc-credentials" class="block text-xs font-semibold text-text-dark/70">Matrícula MPPS / Cédula</label>
              <input 
                type="text" 
                id="doc-credentials" 
                required 
                class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: MPPS-94821"
              />
            </div>

            <button 
              type="submit" 
              class="w-full h-10 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg cursor-pointer transition-colors mt-2"
            >
              Crear Acceso Médico
            </button>
          </form>
        </div>

        <!-- Listado de Médicos -->
        <div class="lg:col-span-2 bg-white border border-border-subtle rounded-2xl p-5 shadow-sm space-y-4">
          <h2 class="font-display font-bold text-lg text-text-dark">Usuarios Médicos Creados</h2>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
              <thead>
                <tr class="border-b border-border-subtle text-text-dark/50">
                  <th class="pb-3 font-semibold">Médico</th>
                  <th class="pb-3 font-semibold">Centro</th>
                  <th class="pb-3 font-semibold">Credencial</th>
                  <th class="pb-3 font-semibold text-right">Acción</th>
                </tr>
              </thead>
              <tbody id="list-medics">
                <!-- Inyectado dinámicamente -->
              </tbody>
            </table>
            <div id="no-medics-msg" class="hidden text-center py-8 text-text-dark/45 font-sans">
              No hay usuarios médicos registrados aún.
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PANEL 2: GESTIONAR PACIENTES -->
    <div id="panel-patients" class="hidden space-y-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Formulario Crear/Editar Paciente -->
        <div class="bg-white border border-border-subtle rounded-2xl p-5 shadow-sm space-y-4 h-fit">
          <h2 id="patient-form-title" class="font-display font-bold text-lg text-text-dark">Registrar Paciente</h2>
          
          <form id="form-create-patient" class="space-y-3">
            <div class="space-y-1">
              <label for="pat-id" class="block text-xs font-semibold text-text-dark/70">Cédula de Identidad</label>
              <input 
                type="text" 
                id="pat-id" 
                required 
                class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: V-17234567"
              />
            </div>

            <div class="space-y-1">
              <label for="pat-name" class="block text-xs font-semibold text-text-dark/70">Nombre Completo</label>
              <input 
                type="text" 
                id="pat-name" 
                required 
                class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: Juan Pérez"
              />
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="space-y-1">
                <label for="pat-age" class="block text-xs font-semibold text-text-dark/70">Edad</label>
                <input 
                  type="number" 
                  id="pat-age" 
                  required 
                  class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                  placeholder="72"
                />
              </div>

              <div class="space-y-1">
                <label for="pat-status" class="block text-xs font-semibold text-text-dark/70">Estado Clínico</label>
                <select 
                  id="pat-status" 
                  required 
                  class="w-full h-10 px-2 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                >
                  <option value="ESTABLE">Estable</option>
                  <option value="OBSERVACION">Observación</option>
                  <option value="TRASLADADO">Trasladado</option>
                  <option value="CRITICO">Especial / Crítico</option>
                </select>
              </div>
            </div>

            <div class="space-y-1">
              <label for="pat-hospital" class="block text-xs font-semibold text-text-dark/70">Centro de Salud</label>
              <input 
                type="text" 
                id="pat-hospital" 
                required 
                class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: Hosp. Universitario"
              />
            </div>

            <div class="space-y-1">
              <label for="pat-location" class="block text-xs font-semibold text-text-dark/70">Ubicación Interna</label>
              <input 
                type="text" 
                id="pat-location" 
                required 
                class="w-full h-10 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: Sala Emergencias A, Cama 12"
              />
            </div>

            <div class="space-y-1">
              <label for="pat-notes" class="block text-xs font-semibold text-text-dark/70">Notas Clínicas</label>
              <textarea 
                id="pat-notes" 
                required 
                rows="2" 
                class="w-full p-2 bg-white border border-border-subtle rounded-lg text-xs focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Condición del paciente..."
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full h-10 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg cursor-pointer transition-colors mt-1"
            >
              Guardar Paciente
            </button>
          </form>
        </div>

        <!-- Listado de Pacientes -->
        <div class="lg:col-span-2 bg-white border border-border-subtle rounded-2xl p-5 shadow-sm space-y-4">
          <h2 class="font-display font-bold text-lg text-text-dark">Pacientes Registrados</h2>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
              <thead>
                <tr class="border-b border-border-subtle text-text-dark/50">
                  <th class="pb-3 font-semibold">Cédula / Paciente</th>
                  <th class="pb-3 font-semibold">Centro / Ubicación</th>
                  <th class="pb-3 font-semibold">Estado</th>
                  <th class="pb-3 font-semibold text-right">Acción</th>
                </tr>
              </thead>
              <tbody id="list-patients">
                <!-- Inyectado dinámicamente -->
              </tbody>
            </table>
            <div id="no-patients-msg" class="hidden text-center py-8 text-text-dark/45 font-sans">
              No hay pacientes cargados.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // --- SEGURIDAD: VERIFICACIÓN Y LOGIN ---
  const loginForm = document.getElementById('form-admin-login') as HTMLFormElement;
  const loginScreen = document.getElementById('admin-login-screen');
  const dashboardScreen = document.getElementById('admin-dashboard-screen');
  const loginError = document.getElementById('admin-login-error');

  // Inicializar verificación de sesión
  if (typeof window !== 'undefined' && loginScreen && dashboardScreen && loginError) {
    const isLogged = sessionStorage.getItem('sire_admin_logged_in') === 'true';
    
    if (isLogged) {
      dashboardScreen.classList.remove('hidden');
      loginScreen.classList.add('hidden');
      initDashboard();
    } else {
      loginScreen.classList.remove('hidden');
      dashboardScreen.classList.add('hidden');
    }

    if (loginForm) {
      loginForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const email = (document.getElementById('admin-email') as HTMLInputElement).value;
        const password = (document.getElementById('admin-password') as HTMLInputElement).value;

        // Validación rígida en el cliente (Prueba de maqueta segura)
        if (email.trim() === 'admin@sire.org' && password === 'SireControl2026!') {
          sessionStorage.setItem('sire_admin_logged_in', 'true');
          loginError.classList.add('hidden');
          window.location.reload(); // Recargar para activar e inyectar el dashboard
        } else {
          loginError.classList.remove('hidden');
        }
      });
    }
  }

  // --- CONTROLADOR DEL DASHBOARD (SOLO SE INICIA TRAS LOGIN) ---
  function initDashboard() {
    // --- Lógica de Pestañas ---
    const tabMedics = document.getElementById('tab-medics');
    const tabPatients = document.getElementById('tab-patients');
    const panelMedics = document.getElementById('panel-medics');
    const panelPatients = document.getElementById('panel-patients');

    if (tabMedics && tabPatients && panelMedics && panelPatients) {
      tabMedics.addEventListener('click', () => {
        tabMedics.classList.add('border-vzla-blue', 'text-vzla-blue');
        tabMedics.classList.remove('border-transparent', 'text-text-dark/60');
        tabPatients.classList.add('border-transparent', 'text-text-dark/60');
        tabPatients.classList.remove('border-vzla-blue', 'text-vzla-blue');
        panelMedics.classList.remove('hidden');
        panelPatients.classList.add('hidden');
      });

      tabPatients.addEventListener('click', () => {
        tabPatients.classList.add('border-vzla-blue', 'text-vzla-blue');
        tabPatients.classList.remove('border-transparent', 'text-text-dark/60');
        tabMedics.classList.add('border-transparent', 'text-text-dark/60');
        tabMedics.classList.remove('border-vzla-blue', 'text-vzla-blue');
        panelPatients.classList.remove('hidden');
        panelMedics.classList.add('hidden');
      });
    }

    // --- Persistencia Médicos ---
    const defaultMedics = [
      { name: 'Dr. Gabriela Rivas', email: 'gabriela.rivas@huc.org', hospital: 'Hospital Univ. de Caracas (HUC)', credentials: 'MPPS-94821' },
      { name: 'Dr. Alejandro Marín', email: 'a.marin@centralmaracay.gob.ve', hospital: 'Hospital Central de Maracay', credentials: 'MPPS-82910' }
    ];

    function renderMedics() {
      const list = document.getElementById('list-medics');
      const noMedics = document.getElementById('no-medics-msg');
      if (!list || !noMedics) return;

      const medics = JSON.parse(localStorage.getItem('sire_medical_users') || '[]');
      if (medics.length === 0) {
        localStorage.setItem('sire_medical_users', JSON.stringify(defaultMedics));
        renderMedics();
        return;
      }

      list.innerHTML = '';
      noMedics.classList.add('hidden');

      medics.forEach((doc: any, index: number) => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-border-subtle/50 hover:bg-bg-light/45 transition-colors';
        tr.innerHTML = `
          <td class="py-3.5">
            <span class="font-semibold block text-text-dark">${doc.name}</span>
            <span class="text-xs text-text-dark/50 block">${doc.email}</span>
          </td>
          <td class="py-3.5 text-text-dark/80 font-medium">${doc.hospital}</td>
          <td class="py-3.5 font-mono text-xs text-text-dark/60">${doc.credentials}</td>
          <td class="py-3.5 text-right">
            <button 
              class="text-xs text-rose-600 hover:underline cursor-pointer border-none bg-transparent btn-delete-doc font-semibold"
              data-index="${index}"
            >
              Revocar
            </button>
          </td>
        `;
        list.appendChild(tr);
      });

      document.querySelectorAll('.btn-delete-doc').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const indexStr = (e.currentTarget as HTMLButtonElement).getAttribute('data-index');
          if (indexStr !== null) {
            const index = parseInt(indexStr);
            const currentMedics = JSON.parse(localStorage.getItem('sire_medical_users') || '[]');
            currentMedics.splice(index, 1);
            localStorage.setItem('sire_medical_users', JSON.stringify(currentMedics));
            renderMedics();
          }
        });
      });
    }

    // --- Persistencia Pacientes ---
    function renderPatients() {
      const list = document.getElementById('list-patients');
      const noPatients = document.getElementById('no-patients-msg');
      if (!list || !noPatients) return;

      const patients = JSON.parse(localStorage.getItem('sire_dynamic_patients') || '[]');
      if (patients.length === 0) {
        list.innerHTML = '';
        noPatients.classList.remove('hidden');
        return;
      }

      list.innerHTML = '';
      noPatients.classList.add('hidden');

      const statusBadgeClass = (status: string) => {
        switch(status) {
          case 'ESTABLE': return 'bg-success-light text-success-text border-success-border';
          case 'OBSERVACION': return 'bg-alert-light text-alert-text border-alert-border';
          case 'TRASLADADO': return 'bg-info-light text-info-text border-info-border';
          case 'CRITICO': return 'bg-error-light text-error-text border-error-border';
          default: return 'bg-white border-border-subtle';
        }
      };

      patients.forEach((pat: any, index: number) => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-border-subtle/50 hover:bg-bg-light/45 transition-colors';
        tr.innerHTML = `
          <td class="py-3.5">
            <span class="font-semibold font-mono text-xs block text-text-dark">${pat.id}</span>
            <span class="font-medium text-sm block">${pat.name} (${pat.age} a)</span>
          </td>
          <td class="py-3.5 text-xs text-text-dark/85">
            <span class="font-semibold block">${pat.hospital}</span>
            <span class="block text-text-dark/50 mt-0.5">${pat.location}</span>
          </td>
          <td class="py-3.5">
            <span class="px-2 py-0.5 border text-xs rounded-full font-bold ${statusBadgeClass(pat.status)}">
              ${pat.status}
            </span>
          </td>
          <td class="py-3.5 text-right space-x-2">
            <button 
              class="text-xs text-vzla-blue hover:underline cursor-pointer border-none bg-transparent btn-edit-pat font-semibold"
              data-index="${index}"
            >
              Editar
            </button>
            <button 
              class="text-xs text-rose-600 hover:underline cursor-pointer border-none bg-transparent btn-delete-pat font-semibold"
              data-index="${index}"
            >
              Egreso
            </button>
          </td>
        `;
        list.appendChild(tr);
      });

      document.querySelectorAll('.btn-edit-pat').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const indexStr = (e.currentTarget as HTMLButtonElement).getAttribute('data-index');
          if (indexStr !== null) {
            const index = parseInt(indexStr);
            const currentPatients = JSON.parse(localStorage.getItem('sire_dynamic_patients') || '[]');
            const pat = currentPatients[index];
            
            (document.getElementById('pat-id') as HTMLInputElement).value = pat.id;
            (document.getElementById('pat-name') as HTMLInputElement).value = pat.name;
            (document.getElementById('pat-age') as HTMLInputElement).value = pat.age;
            (document.getElementById('pat-status') as HTMLSelectElement).value = pat.status;
            (document.getElementById('pat-hospital') as HTMLInputElement).value = pat.hospital;
            (document.getElementById('pat-location') as HTMLInputElement).value = pat.location;
            (document.getElementById('pat-notes') as HTMLTextAreaElement).value = pat.notes;

            const title = document.getElementById('patient-form-title');
            if (title) title.innerText = `Editar Paciente #${index + 1}`;
            
            formCreatePatient.setAttribute('data-edit-index', indexStr);
          }
        });
      });

      document.querySelectorAll('.btn-delete-pat').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const indexStr = (e.currentTarget as HTMLButtonElement).getAttribute('data-index');
          if (indexStr !== null) {
            const index = parseInt(indexStr);
            const currentPatients = JSON.parse(localStorage.getItem('sire_dynamic_patients') || '[]');
            currentPatients.splice(index, 1);
            localStorage.setItem('sire_dynamic_patients', JSON.stringify(currentPatients));
            renderPatients();
          }
        });
      });
    }

    // --- Envíos de Formulario ---
    const formCreateDoc = document.getElementById('form-create-doctor') as HTMLFormElement;
    if (formCreateDoc) {
      formCreateDoc.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = (document.getElementById('doc-name') as HTMLInputElement).value;
        const email = (document.getElementById('doc-email') as HTMLInputElement).value;
        const hospital = (document.getElementById('doc-hospital') as HTMLInputElement).value;
        const credentials = (document.getElementById('doc-credentials') as HTMLInputElement).value;

        const medics = JSON.parse(localStorage.getItem('sire_medical_users') || '[]');
        medics.push({ name, email, hospital, credentials });
        localStorage.setItem('sire_medical_users', JSON.stringify(medics));
        
        formCreateDoc.reset();
        renderMedics();
      });
    }

    const formCreatePatient = document.getElementById('form-create-patient') as HTMLFormElement;
    if (formCreatePatient) {
      formCreatePatient.addEventListener('submit', (e) => {
        e.preventDefault();
        const id = (document.getElementById('pat-id') as HTMLInputElement).value;
        const name = (document.getElementById('pat-name') as HTMLInputElement).value;
        const age = parseInt((document.getElementById('pat-age') as HTMLInputElement).value);
        const status = (document.getElementById('pat-status') as HTMLSelectElement).value;
        const hospital = (document.getElementById('pat-hospital') as HTMLInputElement).value;
        const location = (document.getElementById('pat-location') as HTMLInputElement).value;
        const notes = (document.getElementById('pat-notes') as HTMLTextAreaElement).value;
        
        const patients = JSON.parse(localStorage.getItem('sire_dynamic_patients') || '[]');
        const editIndexStr = formCreatePatient.getAttribute('data-edit-index');

        if (editIndexStr !== null) {
          const editIndex = parseInt(editIndexStr);
          patients[editIndex] = { id, name, age, status, hospital, location, notes, updatedAt: 'Hace un momento' };
          formCreatePatient.removeAttribute('data-edit-index');
          const title = document.getElementById('patient-form-title');
          if (title) title.innerText = "Registrar Paciente";
        } else {
          patients.push({ id, name, age, status, hospital, location, notes, updatedAt: 'Recién ingresado' });
        }

        localStorage.setItem('sire_dynamic_patients', JSON.stringify(patients));
        formCreatePatient.reset();
        renderPatients();
      });
    }

    // Correr renders iniciales
    renderMedics();
    renderPatients();
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
