---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registrarse para Alertas - S.I.R.E.">
  <div class="max-w-md mx-auto my-8 md:my-16 space-y-6 animate-fade-in font-sans">
    
    <!-- Aviso Crítico para Personal Médico (Color terracota desaturado / Amber) -->
    <div class="bg-alert-light border-l-4 border-l-amber-500 p-4 rounded-r-xl text-xs text-alert-text leading-relaxed">
      <h3 class="font-display font-bold text-sm text-alert-text flex items-center gap-1.5 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        ¿Eres personal de salud o médico?
      </h3>
      <p>
        Las cuentas médicas con permisos para registrar e ingresar pacientes **no pueden autoregistrarse públicamente**. Debes contactarnos a <a href="mailto:soporte@sirevenezuela.org" class="font-semibold underline hover:text-vzla-blue transition-colors">soporte@sirevenezuela.org</a> para habilitar tus credenciales.
      </p>
    </div>

    <!-- Bloque de contenido principal -->
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
      
      <!-- Título -->
      <div class="text-center space-y-1">
        <h1 class="font-display font-bold text-2xl md:text-3xl text-text-dark">Crear Cuenta</h1>
        <p class="text-xs md:text-sm text-text-dark/60">
          Crea una cuenta para recibir alertas por correo.
        </p>
      </div>

      <!-- Formulario para Usuarios Comunes (Alertas) -->
      <form id="signup-form" class="space-y-4">
        <div class="space-y-1.5">
          <label for="reg-name" class="block text-sm font-semibold text-text-dark/70">Nombre y Apellido</label>
          <input 
            type="text" 
            id="reg-name" 
            required 
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="Ej: Pedro Infante"
          />
        </div>

        <div class="space-y-1.5">
          <label for="reg-email" class="block text-sm font-semibold text-text-dark/70">Correo electrónico</label>
          <input 
            type="email" 
            id="reg-email" 
            required 
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="pedro@ejemplo.com"
          />
        </div>

        <div class="space-y-1.5">
          <label for="reg-password" class="block text-sm font-semibold text-text-dark/70">Contraseña</label>
          <input 
            type="password" 
            id="reg-password" 
            required 
            minlength="6"
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="Mínimo 6 caracteres"
          />
        </div>

        <div class="flex items-start gap-2.5 pt-1">
          <input 
            type="checkbox" 
            id="terms" 
            required 
            class="mt-1 w-4 h-4 rounded text-vzla-blue focus:ring-vzla-blue/20"
          />
          <label for="terms" class="text-xs text-text-dark/65 leading-relaxed">
            Acepto recibir alertas por correo electrónico sobre los pacientes de interés.
          </label>
        </div>

        <button 
          type="submit" 
          class="w-full h-11 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg cursor-pointer transition-colors shadow-xs"
        >
          Crear Cuenta
        </button>
      </form>

      <!-- Divisor visual -->
      <div class="flex items-center gap-3 text-xs text-text-dark/30 py-1">
        <span class="flex-grow border-t border-border-subtle"></span>
        <span class="shrink-0 font-semibold uppercase">O</span>
        <span class="flex-grow border-t border-border-subtle"></span>
      </div>

      <!-- Botón de Registro con Google (better-auth mockup) -->
      <button 
        id="btn-google-signup"
        type="button"
        class="w-full h-11 bg-white hover:bg-bg-light border border-border-subtle hover:border-text-dark/20 text-text-dark font-display font-semibold text-sm rounded-lg cursor-pointer transition-all flex items-center justify-center gap-2.5 shadow-3xs"
      >
        <!-- Icono oficial de Google -->
        <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.85z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.85c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span>Registrarse con Google</span>
      </button>

      <!-- Alerta informativa de better-auth -->
      <div id="google-signup-info" class="hidden bg-info-light border border-info-border text-info-text text-3xs rounded-xl p-3 leading-normal animate-fade-in" role="alert">
        💡 <strong>Demostración de better-auth:</strong> En producción, este botón registrará tu cuenta utilizando Google OAuth de forma instantánea.
      </div>

      <div id="signup-success" class="hidden bg-success-light border border-success-border text-success-text rounded-xl p-4 text-sm font-semibold animate-fade-in" role="alert">
        ✓ ¡Registro completado con éxito! Tu cuenta ha sido creada. Ahora puedes iniciar sesión para configurar tus alertas.
      </div>
    </div>

    <!-- Enlace de regreso -->
    <div class="text-center pt-2">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 text-vzla-blue hover:text-vzla-blue-hover font-display font-semibold text-base transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Volver a la página principal
      </a>
    </div>
  </div>
</Layout>

<script>
  if (typeof window !== 'undefined') {
    const form = document.getElementById('signup-form') as HTMLFormElement;
    const successAlert = document.getElementById('signup-success');
    const googleBtn = document.getElementById('btn-google-signup');
    const googleInfo = document.getElementById('google-signup-info');

    // Alerta de Google
    if (googleBtn && googleInfo) {
      googleBtn.addEventListener('click', () => {
        googleInfo.classList.remove('hidden');
        setTimeout(() => {
          googleInfo.classList.add('hidden');
        }, 6000);
      });
    }
    
    if (form && successAlert) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const name = (document.getElementById('reg-name') as HTMLInputElement).value;
        const email = (document.getElementById('reg-email') as HTMLInputElement).value;
        const password = (document.getElementById('reg-password') as HTMLInputElement).value;
        
        // Guardar el registro en localStorage para simular persistencia
        const users = JSON.parse(localStorage.getItem('sire_familiar_users') || '[]');
        users.push({ name, email, password, createdAt: new Date().toISOString() });
        localStorage.setItem('sire_familiar_users', JSON.stringify(users));

        // Mostrar alerta de éxito
        successAlert.classList.remove('hidden');
        form.reset();
        
        setTimeout(() => {
          successAlert.classList.add('hidden');
        }, 5000);
      });
    }
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
