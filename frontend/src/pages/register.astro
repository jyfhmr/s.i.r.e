---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registrarse para Alertas - S.I.R.E.">
  <div class="max-w-md mx-auto my-8 md:my-16 space-y-6 animate-fade-in font-sans">
    
    <!-- Aviso para Personal Médico -->
    <div class="bg-alert-light border-l-4 border-l-amber-500 p-4 rounded-r-xl text-xs text-alert-text leading-relaxed">
      <h3 class="font-display font-bold text-sm text-alert-text flex items-center gap-1.5 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        ¿Eres personal de salud o médico?
      </h3>
      <p>
        Las cuentas médicas tienen un proceso de registro diferente. 
        <a href="/personal-salud" class="font-semibold underline hover:text-vzla-blue transition-colors">Haz clic aquí para solicitar acceso como personal de salud</a>.
      </p>
    </div>

    <!-- Bloque de contenido principal -->
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
      
      <!-- Título -->
      <div class="text-center space-y-1">
        <h1 class="font-display font-bold text-2xl md:text-3xl text-text-dark">Crear Cuenta</h1>
        <p class="text-xs md:text-sm text-text-dark/60">
          Crea una cuenta para recibir alertas por correo.
        </p>
      </div>

      <!-- Formulario para Usuarios Comunes (Alertas) -->
      <form id="signup-form" class="space-y-4">
        <div class="space-y-1.5">
          <label for="reg-name" class="block text-sm font-semibold text-text-dark/70">Nombre y Apellido</label>
          <input 
            type="text" 
            id="reg-name" 
            required 
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="Ej: Pedro Infante"
          />
        </div>

        <div class="space-y-1.5">
          <label for="reg-email" class="block text-sm font-semibold text-text-dark/70">Correo electrónico</label>
          <input 
            type="email" 
            id="reg-email" 
            required 
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="pedro@ejemplo.com"
          />
        </div>

        <div class="space-y-1.5">
          <label for="reg-password" class="block text-sm font-semibold text-text-dark/70">Contraseña</label>
          <input 
            type="password" 
            id="reg-password" 
            required 
            minlength="6"
            class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
            placeholder="Mínimo 6 caracteres"
          />
        </div>

        <div class="flex items-start gap-2.5 pt-1">
          <input 
            type="checkbox" 
            id="terms" 
            required 
            class="mt-1 w-4 h-4 rounded text-vzla-blue focus:ring-vzla-blue/20"
          />
          <label for="terms" class="text-xs text-text-dark/65 leading-relaxed">
            Acepto recibir alertas por correo electrónico sobre los pacientes de interés.
          </label>
        </div>

        <button 
          type="submit" 
          class="w-full h-11 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-sm rounded-lg cursor-pointer transition-colors shadow-xs"
        >
          Crear Cuenta
        </button>
      </form>

      <div id="signup-success" class="hidden bg-success-light border border-success-border text-success-text rounded-xl p-4 text-sm font-semibold animate-fade-in" role="alert">
        ✓ ¡Registro completado con éxito! Tu cuenta ha sido creada. Ahora puedes iniciar sesión para configurar tus alertas.
      </div>
    </div>

    <!-- Enlace de regreso -->
    <div class="text-center pt-2">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 text-vzla-blue hover:text-vzla-blue-hover font-display font-semibold text-base transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Volver a la página principal
      </a>
    </div>
  </div>
</Layout>

<script>
  import { registerCitizen } from '../lib/api';

  if (typeof window !== 'undefined') {
    const form = document.getElementById('signup-form') as HTMLFormElement;
    const successAlert = document.getElementById('signup-success') as HTMLElement;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
    
    if (form && successAlert && submitBtn) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const fullName = (document.getElementById('reg-name') as HTMLInputElement).value.trim();
        const email = (document.getElementById('reg-email') as HTMLInputElement).value.trim();
        const password = (document.getElementById('reg-password') as HTMLInputElement).value;

        // Deshabilitar botón
        submitBtn.disabled = true;
        submitBtn.textContent = 'Creando cuenta...';
        successAlert.classList.add('hidden');

        try {
          // Registro real en el backend
          await registerCitizen({ fullName, email, password });

          // Mostrar alerta de éxito
          if (successAlert) {
            successAlert.textContent = '✓ ¡Registro completado con éxito! Redirigiendo al login...';
            successAlert.classList.remove('hidden');
          }
          form.reset();
          
          // Redirigir a /login después de 1.5 segundos
          setTimeout(() => {
            window.location.href = '/login';
          }, 1500);
        } catch (error: any) {
          // Mostrar error
          alert('Error al registrar: ' + (error.message || 'Error desconocido. Intenta nuevamente.'));
          
          // Re-habilitar botón
          submitBtn.disabled = false;
          submitBtn.textContent = 'Crear Cuenta';
        }
      });
    }
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
