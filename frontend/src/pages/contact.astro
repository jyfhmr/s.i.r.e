---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto y Soporte - S.I.R.E.">
  <div class="max-w-2xl mx-auto space-y-8 animate-fade-in">
    <!-- Título de la sección -->
    <div class="text-center space-y-2">
      <h1 class="font-display font-bold text-3xl md:text-4xl text-text-dark">Contacto y Soporte</h1>
      <p class="font-sans text-base md:text-lg text-text-dark/65">
        ¿Tienes dudas o deseas integrar tu hospital? Escríbenos.
      </p>
    </div>

    <!-- Bloque de contenido principal -->
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 font-sans text-sm text-text-dark">
        <div class="p-4 bg-bg-light rounded-xl border border-border-subtle">
          <span class="block text-xs font-semibold text-text-dark/45 uppercase tracking-wider">Correo Institucional</span>
          <a href="mailto:soporte@sirevenezuela.org" class="text-vzla-blue hover:underline font-semibold block mt-1 text-base">
            soporte@sirevenezuela.org
          </a>
        </div>
        <div class="p-4 bg-bg-light rounded-xl border border-border-subtle">
          <span class="block text-xs font-semibold text-text-dark/45 uppercase tracking-wider">Numero Telefónico</span>
          <span class="font-semibold block mt-1 text-base text-text-dark">
            555-5555555
          </span>
        </div>
      </div>

      <section class="space-y-4 pt-4 border-t border-border-subtle/50">
        <h2 class="font-display font-bold text-xl text-text-dark">Formulario de Contacto</h2>
        
        <form id="contact-form" class="space-y-4 font-sans">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="name" class="block text-sm font-semibold text-text-dark/70">Nombre completo</label>
              <input 
                type="text" 
                id="name" 
                required 
                class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: Pedro Infante"
              />
            </div>
            
            <div class="space-y-1.5">
              <label for="email" class="block text-sm font-semibold text-text-dark/70">Correo electrónico</label>
              <input 
                type="email" 
                id="email" 
                required 
                class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="pedro@ejemplo.com"
              />
            </div>
          </div>

          <div class="space-y-1.5">
            <label for="message" class="block text-sm font-semibold text-text-dark/70">Mensaje o Consulta</label>
            <textarea 
              id="message" 
              rows="4" 
              required 
              class="w-full p-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
              placeholder="Explica detalladamente tu solicitud..."
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full h-12 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-base rounded-xl cursor-pointer transition-all shadow-xs hover:shadow"
          >
            Enviar Solicitud
          </button>
        </form>

        <div id="success-alert" class="hidden bg-success-light border border-success-border text-success-text rounded-xl p-4 text-sm font-semibold animate-fade-in" role="alert">
          ✓ ¡Gracias! Tu mensaje ha sido enviado correctamente. Responderemos a la brevedad.
        </div>
      </section>
    </div>

    <!-- Botón de regreso -->
    <div class="text-center pt-2">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 text-vzla-blue hover:text-vzla-blue-hover font-display font-semibold text-base transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Volver a la página principal
      </a>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const alert = document.getElementById('success-alert');
  if (form && alert) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // Mostrar alerta de éxito
      alert.classList.remove('hidden');
      form.reset();
      
      // Ocultar la alerta tras unos segundos
      setTimeout(() => {
        alert.classList.add('hidden');
      }, 5000);
    });
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
