---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contacto, Soporte y Colaboración - S.I.R.E."
  description="Ponte en contacto con el equipo de soporte de S.I.R.E. para reportar información de nuevos hospitales, coordinar alianzas o resolver dudas de la plataforma."
>
  <div class="max-w-2xl mx-auto space-y-8 animate-fade-in">
    <!-- Título de la sección -->
    <div class="text-center space-y-2">
      <h1 class="font-display font-bold text-3xl md:text-4xl text-text-dark">Contacto y Soporte</h1>
      <p class="font-sans text-base md:text-lg text-text-dark/65">
        ¿Tienes información de hospitales, quieres colaborar o tienes dudas sobre S.I.R.E.? Escríbenos.
      </p>
    </div>


    <!-- Bloque de contenido principal -->
    <div class="bg-white border border-border-subtle rounded-2xl p-6 md:p-8 shadow-sm space-y-6">
    

      <section class="space-y-4 pt-4 border-t border-border-subtle/50">
        <h2 class="font-display font-bold text-xl text-text-dark">Formulario de Contacto</h2>
        
        <form id="contact-form" class="space-y-4 font-sans">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label for="name" class="block text-sm font-semibold text-text-dark/70">Nombre completo</label>
              <input 
                type="text" 
                id="name" 
                required 
                class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="Ej: Pedro Infante"
              />
            </div>
            
            <div class="space-y-1.5">
              <label for="email" class="block text-sm font-semibold text-text-dark/70">Correo electrónico</label>
              <input 
                type="email" 
                id="email" 
                required 
                class="w-full h-11 px-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
                placeholder="pedro@ejemplo.com"
              />
            </div>
          </div>

          <div class="space-y-1.5">
            <label for="message" class="block text-sm font-semibold text-text-dark/70">Mensaje o Consulta</label>
            <textarea 
              id="message" 
              rows="4" 
              required 
              class="w-full p-3 bg-white border border-border-subtle rounded-lg text-sm focus:border-vzla-blue focus:outline-none transition-colors"
              placeholder="Explica detalladamente tu solicitud..."
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full h-12 bg-vzla-blue hover:bg-vzla-blue-hover text-white font-display font-bold text-base rounded-xl cursor-pointer transition-all shadow-xs hover:shadow"
          >
            Enviar Solicitud
          </button>
        </form>

        <div id="success-alert" class="hidden bg-success-light border border-success-border text-success-text rounded-xl p-4 text-sm font-semibold animate-fade-in" role="alert">
          ✓ ¡Gracias! Tu mensaje ha sido enviado correctamente. Responderemos a la brevedad.
        </div>

        <div id="error-alert" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 text-sm font-semibold animate-fade-in" role="alert">
          <span id="error-message">Ocurrió un error al enviar tu mensaje. Inténtalo de nuevo.</span>
        </div>
      </section>
    </div>

    <!-- Botón de regreso -->
    <div class="text-center pt-2">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 text-vzla-blue hover:text-vzla-blue-hover font-display font-semibold text-base transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Volver a la página principal
      </a>
    </div>
  </div>
</Layout>

<script>
  import { sendContactMessage, type ApiError } from '../lib/api';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successAlert = document.getElementById('success-alert');
  const errorAlert = document.getElementById('error-alert');
  const errorMessage = document.getElementById('error-message');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  const nameInput = document.getElementById('name') as HTMLInputElement | null;
  const emailInput = document.getElementById('email') as HTMLInputElement | null;
  const messageInput = document.getElementById('message') as HTMLTextAreaElement | null;

  const DEFAULT_BTN_TEXT = submitBtn?.textContent ?? 'Enviar Solicitud';

  if (form && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Ocultar alertas previas
      successAlert?.classList.add('hidden');
      errorAlert?.classList.add('hidden');

      const payload = {
        name: nameInput?.value.trim() ?? '',
        email: emailInput?.value.trim() ?? '',
        message: messageInput?.value.trim() ?? '',
      };

      // Estado de carga
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
      submitBtn.textContent = 'Enviando…';

      try {
        await sendContactMessage(payload);

        successAlert?.classList.remove('hidden');
        form.reset();

        setTimeout(() => {
          successAlert?.classList.add('hidden');
        }, 6000);
      } catch (err) {
        const apiError = err as ApiError;
        if (errorMessage) {
          errorMessage.textContent =
            apiError?.message ||
            'Ocurrió un error al enviar tu mensaje. Inténtalo de nuevo.';
        }
        errorAlert?.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        submitBtn.textContent = DEFAULT_BTN_TEXT;
      }
    });
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
