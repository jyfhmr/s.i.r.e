# ==================================================
# CONFIGURACIÓN DE ENTORNO - S.I.R.E.
# Sistema de Información y Registro de Emergencias
# ==================================================

# Entorno de Ejecución
NODE_ENV=development
SERVER_PORT=3000

# Frontend
URL_FRONTEND=http://localhost:5173

# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=sire_db

# Servicio de Emails (Resend)
RESEND_API_KEY=re_TuClaveDeResend
# Remitente de los correos. Mientras no tengas un dominio verificado en Resend,
# usa la dirección de pruebas "onboarding@resend.dev".
RESEND_FROM_EMAIL=Acme <onboarding@resend.dev>
# Correo donde RECIBIRÁS los mensajes del formulario de contacto (/contact).
# Nota: con "onboarding@resend.dev" como remitente, Resend solo permite enviar
# al correo dueño de tu cuenta Resend hasta que verifiques un dominio propio.
CONTACT_EMAIL=tu-correo@ejemplo.com


# Autenticación JWT
JWT_SECRET=cambia_esto_por_un_secret_seguro_en_produccion