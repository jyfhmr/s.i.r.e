{
  "name": "codebase-backend",
  "version": "0.0.1",
  "description": "",
  "author": "José Hernández",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "db:setup": "ts-node -r dotenv/config -r tsconfig-paths/register src/scripts/db-setup.ts",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/backend/src/main TZ=America/Caracas",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "entity:create": "ts-node -r dotenv/config -r tsconfig-paths/register ./node_modules/typeorm/cli.js entity:create -n",
    "create:audits": "ts-node -r dotenv/config -r tsconfig-paths/register src/scripts/create-audits.ts",
    "create-empty-db": "node -r dotenv/config -r ts-node/register -r tsconfig-paths/register -e \"require('typeorm-extension/bin/cli.cjs')\" -- db:create -d ./src/database/data.source.ts -s no",
    "db:drop": "node -r dotenv/config -r ts-node/register -r tsconfig-paths/register -e \"require('typeorm-extension/bin/cli.cjs')\" -- db:drop -d ./src/database/data.source.ts",
    "schema:sync": "ts-node -r dotenv/config -r tsconfig-paths/register ./node_modules/typeorm/cli.js schema:sync -d ./src/database/data.source.ts",
    "schema:drop": "ts-node -r dotenv/config -r tsconfig-paths/register ./node_modules/typeorm/cli.js schema:drop -d ./src/database/data.source.ts",
    "migration:run": "node -r dotenv/config -r ts-node/register -r tsconfig-paths/register -e \"process.argv.splice(1, 0, 'typeorm'); require('typeorm/cli.js')\" -- migration:run -d ./src/database/data.source.ts",
    "migration:revert": "node -r dotenv/config -r ts-node/register -r tsconfig-paths/register -e \"process.argv.splice(1, 0, 'typeorm'); require('typeorm/cli.js')\" -- migration:revert -d ./src/database/data.source.ts",
    "migration:show": "node -r dotenv/config -r ts-node/register -r tsconfig-paths/register -e \"process.argv.splice(1, 0, 'typeorm'); require('typeorm/cli.js')\" -- migration:show -d ./src/database/data.source.ts",
    "migration:generate": "node -r dotenv/config -r ts-node/register -r tsconfig-paths/register -e \"process.argv.splice(1, 0, 'typeorm'); require('typeorm/cli.js')\" -- migration:generate -d ./src/database/data.source.ts"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1052.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/microservices": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.18",
    "@react-email/components": "^1.0.11",
    "@react-email/render": "^2.0.5",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nestjs": "^10.12.0",
    "@types/cron": "^2.4.0",
    "ai": "^6.0.199",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.7",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "bwip-js": "^4.6.0",
    "cache-manager": "^7.2.8",
    "cheerio": "^1.0.0-rc.12",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "codebase-shared": "*",
    "csv-stringify": "^6.5.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.1",
    "joi": "^18.1.2",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "nest-winston": "^1.10.2",
    "nodemailer": "^6.9.13",
    "os": "^0.1.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.10.0",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.5",
    "swagger-ui-express": "^5.0.0",
    "tsconfig-paths": "^4.2.0",
    "typeorm-extension": "^3.9.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@react-email/preview-server": "^5.2.10",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.0",
    "@types/twilio": "^3.19.2",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "env-cmd": "^10.1.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.28",
    "typescript": "^6.0.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
